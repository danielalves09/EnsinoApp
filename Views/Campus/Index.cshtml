@model IEnumerable<EnsinoApp.ViewModels.campus.ListarCamposViewModel>
@{
    ViewData["Title"] = "Gerenciar Campus";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="ea-page-title">
            <h1><i class="fas fa-map-marker-alt" style="color:var(--info);margin-right:8px"></i>Gerenciar Campus</h1>
            <p>Cadastre e gerencie os campi disponíveis no sistema</p>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        <div class="ea-toolbar">
            <form asp-action="Index" style="flex:1 1 220px">
                <div class="ea-search-wrap">
                    <i class="fas fa-search ea-search-icon"></i>
                    <input type="text" placeholder="Buscar campus..." name="filtro" value="@ViewBag.Filtro" />
                    <button type="submit" class="ea-btn-search"><i class="fas fa-search"></i></button>
                </div>
            </form>
            <a href="/campus/adicionar" class="ea-btn-new"><i class="fas fa-plus"></i> Novo Campus</a>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="ea-grid">
                @foreach (var p in Model!)
                {
                    <div class="ea-card ea-fade ea-fade-1">
                        <div class="ea-card-accent cyan"></div>
                        <div class="ea-card-body">
                            <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
                                <div
                                    style="width:44px;height:44px;border-radius:var(--radius);background:linear-gradient(135deg,#e0f2fe,#bae6fd);display:flex;align-items:center;justify-content:center;color:var(--info);font-size:1.1rem;flex-shrink:0">
                                    <i class="fas fa-building"></i>
                                </div>
                                <h3
                                    style="font-family:var(--font);font-size:.98rem;font-weight:800;color:var(--gray-800);margin:0">
                                    @p.Nome</h3>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(p.Telefone))
                                {
                                    <span class="ea-meta-pill"><i class="fas fa-phone-alt"></i>@p.Telefone</span>
                                }
                                else
                                {
                                    <span class="ea-meta-pill" style="color:var(--gray-300);font-style:italic"><i
                                        class="fas fa-phone-alt"></i>Sem telefone</span>
                                    }
                                </div>
                                <div class="ea-card-footer">
                                    <a href="/campus/editar/@p.Id" class="ea-action-btn primary" title="Editar"><i
                                        class="fas fa-edit"></i></a>
                                        <a asp-controller="Campus" asp-action="Excluir" asp-route-id="@p.Id"
                                           onclick="return confirm('Excluir o campus @p.Nome?')" class="ea-action-btn danger"
                                           title="Excluir"><i class="fas fa-trash"></i></a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
        else
                    {
                        <div class="ea-empty">
                            <i class="fas fa-building"></i>
                            <h3>Nenhum campus encontrado</h3>
                            <p>Tente outro termo ou cadastre um novo campus.</p>
                        </div>
                    }

                    @if (ViewBag.Totalpaginas > 1)
                    {
                        <div class="ea-pagination">
                            @if (ViewBag.NumeroPagina > 1)
                            {
                                <a class="ea-page-btn"
                                       href="@Url.Action("Index","Campus",new{Filtro=ViewBag.Filtro,Pagina=ViewBag.NumeroPagina-1})"><i
                                    class="fas fa-chevron-left"></i></a>
                                }
                                <span class="ea-page-info">Página @ViewBag.NumeroPagina de @ViewBag.TotalPaginas</span>
                                @if (ViewBag.NumeroPagina < ViewBag.TotalPaginas)
                                {
                                    <a class="ea-page-btn"
                                           href="@Url.Action("Index","Campus",new{Filtro=ViewBag.Filtro,Pagina=ViewBag.NumeroPagina+1})"><i
                                        class="fas fa-chevron-right"></i></a>
                                    }
                                </div>
                            }

                        </div>
                    </section>