@model EnsinoApp.ViewModels.campus.AdicionarCampusViewModel
@{
    ViewData["Title"] = "Cadastrar Campus";
}

<section class="content-header" style="padding-bottom:0">
    <div class="container-fluid">
        <a asp-action="Index" class="ea-btn-back"><i class="fas fa-arrow-left"></i> Voltar para Campus</a>
        <div class="ea-page-title">
            <h1><i class="fas fa-building" style="color:var(--info);margin-right:8px"></i>Cadastrar Campus</h1>
            <p>Preencha os dados de identificação e endereço do novo campus</p>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <form asp-action="Adicionar" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size:.8rem;margin-bottom:12px">
            </div>

            <div class="ea-form-card ea-fade ea-fade-1">
                <div class="ea-form-card-header">
                    <div class="ea-form-header-icon" style="background:var(--info-light);color:var(--info)"><i
                        class="fas fa-building"></i></div>
                        <h3 class="ea-form-card-title">Identificação</h3>
                    </div>
                    <div class="ea-form-card-body">
                        <div class="row g-3">
                            <div class="col-md-8">
                                <div class="ea-field-group">
                                    <label asp-for="Nome" class="ea-field-label"></label>
                                    <input asp-for="Nome" class="ea-field-control" placeholder="Nome do campus" />
                                    <span asp-validation-for="Nome" class="ea-field-error"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="ea-field-group">
                                    <label asp-for="Telefone" class="ea-field-label"></label>
                                    <input asp-for="Telefone" class="ea-field-control" placeholder="(00) 00000-0000" />
                                    <span asp-validation-for="Telefone" class="ea-field-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="ea-form-card ea-fade ea-fade-2">
                    <div class="ea-form-card-header">
                        <div class="ea-form-header-icon" style="background:var(--primary-light);color:var(--primary)"><i
                            class="fas fa-map-marker-alt"></i></div>
                            <h3 class="ea-form-card-title">Endereço</h3>
                        </div>
                        <div class="ea-form-card-body">
                            <div
                                style="display:flex;align-items:center;gap:8px;background:var(--info-light);border:1px solid #a5f3fc;border-radius:var(--radius);padding:10px 14px;font-size:.78rem;color:var(--info);font-weight:600;margin-bottom:18px">
                                <i class="fas fa-info-circle"></i> Preencha o endereço completo para facilitar a localização do
                                campus.
                            </div>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="ea-field-group">
                                        <label asp-for="Rua" class="ea-field-label"></label>
                                        <input asp-for="Rua" class="ea-field-control" placeholder="Nome da rua ou avenida" />
                                        <span asp-validation-for="Rua" class="ea-field-error"></span>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="ea-field-group">
                                        <label asp-for="Numero" class="ea-field-label"></label>
                                        <input asp-for="Numero" class="ea-field-control" placeholder="Nº" />
                                        <span asp-validation-for="Numero" class="ea-field-error"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="ea-field-group">
                                        <label asp-for="Complemento" class="ea-field-label"></label>
                                        <input asp-for="Complemento" class="ea-field-control"
                                               placeholder="Apto, bloco, sala..." />
                                        <span asp-validation-for="Complemento" class="ea-field-error"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="ea-field-group">
                                        <label asp-for="Bairro" class="ea-field-label"></label>
                                        <input asp-for="Bairro" class="ea-field-control" placeholder="Bairro" />
                                        <span asp-validation-for="Bairro" class="ea-field-error"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="ea-field-group">
                                        <label asp-for="Cidade" class="ea-field-label"></label>
                                        <input asp-for="Cidade" class="ea-field-control" placeholder="Cidade" />
                                        <span asp-validation-for="Cidade" class="ea-field-error"></span>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="ea-field-group">
                                        <label asp-for="Estado" class="ea-field-label"></label>
                                        <input asp-for="Estado" class="ea-field-control text-uppercase" maxlength="2"
                                               placeholder="UF" />
                                        <span asp-validation-for="Estado" class="ea-field-error"></span>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="ea-field-group">
                                        <label asp-for="Cep" class="ea-field-label"></label>
                                        <input asp-for="Cep" class="ea-field-control" placeholder="00000-000" />
                                        <span asp-validation-for="Cep" class="ea-field-error"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="ea-form-footer">
                            <a asp-action="Index" class="ea-btn-action cancel"><i class="fas fa-times"></i> Cancelar</a>
                            <button type="submit" class="ea-btn-action save"><i class="fas fa-save"></i> Salvar Campus</button>
                        </div>
                    </div>

                </form>
            </div>
        </section>

        @section Scripts {
            <partial name="_ValidationScriptsPartial" />
        }