@{
    Layout = null;
    ViewData["Title"] = "Cursos CCVideira – Transformando Famílias";
}

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <meta name="description"
          content="Cursos bíblicos para casais e famílias oferecidos pela CCVideira: Casados Para Sempre, ONE e Pais Para Toda a Vida." />

    <!-- Nunito -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
          rel="stylesheet" />
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <!-- Bootstrap grid only -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Landing CSS -->
    <link rel="stylesheet" href="~/css/landing.css" />
</head>

<body>

    <!-- ══ NAVBAR ════════════════════════════════════════ -->
    <nav class="lp-nav" id="lpNav">
        <div class="nav-logo">
            <img src="~/images/logovideira.png" alt="CCVideira" />
            <div>
                <span class="nav-logo-text">CCVideira</span>
                <span class="nav-logo-sub">Ensino</span>
            </div>
        </div>
        <ul class="nav-links">
            <li><a href="#cursos">Cursos</a></li>
            <li><a href="#como-funciona">Como Funciona</a></li>
            <li><a href="#diferenciais">Diferenciais</a></li>
            <li><a href="/auth/login" class="nav-cta"><i class="fas fa-sign-in-alt"
                                                             style="margin-right:5px"></i>Entrar</a></li>
            </ul>
            <div class="nav-hamburger" id="navHamburger">
                <i class="fas fa-bars"></i>
            </div>
        </nav>

        <!-- Mobile menu overlay -->
        <div id="mobileMenu" class="mobile-menu">
            <div class="mobile-menu-header">
                <div class="nav-logo">
                    <img src="~/images/logovideira.png" alt="CCVideira" />
                    <div>
                        <span class="nav-logo-text">CCVideira</span>
                        <span class="nav-logo-sub">Ensino</span>
                    </div>
                </div>
                <button class="mobile-menu-close" id="mobileMenuClose">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <ul class="mobile-menu-links">
                <li><a href="#cursos" class="mobile-menu-link">Cursos</a></li>
                <li><a href="#como-funciona" class="mobile-menu-link">Como Funciona</a></li>
                <li><a href="#diferenciais" class="mobile-menu-link">Diferenciais</a></li>
                <li><a href="/auth/login" class="mobile-menu-link mobile-menu-cta"><i class="fas fa-sign-in-alt"></i>
                    Entrar</a></li>
                </ul>
            </div>
            <div class="mobile-menu-backdrop" id="mobileMenuBackdrop"></div>

            <!-- ══ HERO ══════════════════════════════════════════ -->
            <section class="lp-hero">
                <div class="hero-bg" style="background-image:url('~/images/back.jpg')"></div>
                <div class="hero-content">
                    <div class="hero-text">
                        <div class="hero-badge">
                            <i class="fas fa-church"></i> CCVideira · Ensino
                        </div>
                        <h1 class="hero-title">
                            Transformando famílias<br />
                            através da <span>Palavra de Deus</span>
                        </h1>
                        <p class="hero-desc">
                            Cursos que fortalecem casamentos, preparam noivos e capacitam pais a exercer sua função com
                            sabedoria e amor. Baseados em princípios bíblicos, já transformaram milhares de
                            famílias em todo o mundo.
                        </p>
                        <div class="hero-btns">
                            <a href="/inscricao" class="btn-hero-primary">
                                <i class="fas fa-paper-plane"></i> Inscreva-se Agora
                            </a>
                            <a href="#cursos" class="btn-hero-ghost">
                                <i class="fas fa-book-open"></i> Conhecer os Cursos
                            </a>
                        </div>
                        <div class="hero-stats">
                            <div>
                                <span class="hero-stat-num">3</span>
                                <span class="hero-stat-label">Cursos disponíveis</span>
                            </div>
                            <div>
                                <span class="hero-stat-num">140k+</span>
                                <span class="hero-stat-label">Casais formados no Brasil</span>
                            </div>
                            <div>
                                <span class="hero-stat-num">100+</span>
                                <span class="hero-stat-label">Países alcançados</span>
                            </div>
                        </div>
                    </div>

                    <div class="hero-card">
                        <p class="hero-card-title"><i class="fas fa-graduation-cap" style="margin-right:6px"></i>Nossos Cursos
                        </p>
                        <div class="course-pill">
                            <div class="course-pill-icon" style="background:rgba(225,29,72,.2);color:#fb7185"><i
                                class="fas fa-heart"></i></div>
                                <div>
                                    <p class="course-pill-name">Casados Para Sempre</p>
                                    <p class="course-pill-dur">14 semanas · Para casais</p>
                                </div>
                            </div>
                            <div class="course-pill">
                                <div class="course-pill-icon" style="background:rgba(37,99,235,.2);color:#60a5fa"><i
                                    class="fas fa-ring"></i></div>
                                    <div>
                                        <p class="course-pill-name">ONE – Curso para Noivos</p>
                                        <p class="course-pill-dur">10 semanas · Para noivos</p>
                                    </div>
                                </div>
                                <div class="course-pill">
                                    <div class="course-pill-icon" style="background:rgba(22,163,74,.2);color:#4ade80"><i
                                        class="fas fa-child"></i></div>
                                        <div>
                                            <p class="course-pill-name">Pais Para Toda a Vida</p>
                                            <p class="course-pill-dur">11 semanas · Para pais</p>
                                        </div>
                                    </div>
                                    <a href="/inscricao" class="btn-hero-primary" style="margin-top:8px;justify-content:center">
                                        <i class="fas fa-arrow-right"></i> Quero me inscrever
                                    </a>
                                </div>
                            </div>
                        </section>

                        <!-- ══ CURSOS ════════════════════════════════════════ -->
                        <section class="lp-section" id="cursos">
                            <div class="section-header">
                                <span class="section-eyebrow" style="background:#eff6ff;color:#2563eb">Nossos Cursos</span>
                                <h2 class="section-title">Para cada fase da sua família</h2>
                                <p class="section-desc">Cursos baseados em princípios bíblicos, ministrados semanalmente em pequenos grupos,
                                    com conteúdo interativo e transformador.</p>
                                </div>

                                <div class="courses-grid">

                                    <!-- Casados Para Sempre -->
                                    <div class="course-card">
                                        <div class="course-card-top card-cps">
                                            <div class="course-icon-wrap"><i class="fas fa-heart"></i></div>
                                            <h3 class="course-card-name">Casados Para Sempre</h3>
                                            <p class="course-card-target">Para casais casados de todas as idades</p>
                                        </div>
                                        <div class="course-card-body">
                                            <p class="course-card-desc">
                                                Baseado nos princípios bíblicos, ensina aos casais como andar na
                                                plenitude do relacionamento de uma só carne. Ideal para casamentos em crise, rotineiros ou que
                                                desejam crescer ainda mais no Senhor.
                                            </p>
                                            <div class="course-meta">
                                                <span class="course-meta-tag tag-cps"><i class="fas fa-calendar-alt"></i> 14 semanas</span>
                                                <span class="course-meta-tag tag-cps"><i class="fas fa-book"></i> 13 lições</span>
                                                <span class="course-meta-tag tag-cps"><i class="fas fa-users"></i> Pequenos grupos</span>
                                            </div>
                                            <div style="font-size:.8rem;color:var(--gray-500);line-height:1.7">
                                                <strong style="color:var(--gray-700);display:block;margin-bottom:6px">Temas abordados:</strong>
                                                Aliança · Uma só carne · Papéis · Semeando e Colhendo · Perdão · Visão de fé · Orando Juntos ·
                                                Acordo · Fluindo juntos no Espírito · Intimidade · Batalha espiritual · Estilo de Vida ·
                                                Ministério de Uma Só Carne
                                            </div>
                                        </div>
                                        <div class="course-card-footer">
                                            <a href="/inscricao" class="btn-course-cta cta-cps">
                                                <i class="fas fa-heart"></i> Inscrever-se neste curso
                                            </a>
                                        </div>
                                    </div>

                                    <!-- ONE -->
                                    <div class="course-card">
                                        <div class="course-card-top card-one">
                                            <div class="course-icon-wrap"><i class="fas fa-ring"></i></div>
                                            <h3 class="course-card-name">ONE</h3>
                                            <p class="course-card-target">Curso para Noivos</p>
                                        </div>
                                        <div class="course-card-body">
                                            <p class="course-card-desc">
                                                Escrito especialmente para quem vai se casar pela primeira vez. Apresenta princípios bíblicos
                                                que respondem as perguntas eternas sobre o casamento, preparando os casais para a jornada que
                                                está por vir — de forma interativa e reveladora.
                                            </p>
                                            <div class="course-meta">
                                                <span class="course-meta-tag tag-one"><i class="fas fa-calendar-alt"></i> 10 semanas</span>
                                                <span class="course-meta-tag tag-one"><i class="fas fa-book"></i> 09 Lições</span>
                                                <span class="course-meta-tag tag-one"><i class="fas fa-clock"></i> 2h por semana</span>
                                            </div>
                                            <div style="font-size:.8rem;color:var(--gray-500);line-height:1.7">
                                                <strong style="color:var(--gray-700);display:block;margin-bottom:6px">Temas abordados:</strong>
                                                Um Antes de Serem Dois · Relacionamentos · Concluindo o passado · Completo em Um · O Destino de
                                                Vocês como Um
                                                · Intimidade · A Equipe do lar · Deus e suas Finanças · Casamento e Finanças
                                            </div>
                                        </div>
                                        <div class="course-card-footer">
                                            <a href="/inscricao" class="btn-course-cta cta-one">
                                                <i class="fas fa-ring"></i> Inscrever-se neste curso
                                            </a>
                                        </div>
                                    </div>

                                    <!-- Pais Para Toda a Vida -->
                                    <div class="course-card">
                                        <div class="course-card-top card-pptv">
                                            <div class="course-icon-wrap"><i class="fas fa-child"></i></div>
                                            <h3 class="course-card-name">Pais Para Toda a Vida</h3>
                                            <p class="course-card-target">Para pais com filhos a partir de 3 anos</p>
                                        </div>
                                        <div class="course-card-body">
                                            <p class="course-card-desc">
                                                Oferece conselhos baseados na Palavra de Deus para entender a arte do relacionamento entre pais
                                                e filhos. Aplicáveis a todas as idades, enfoca a influência da paternidade nas gerações futuras
                                                e como preparar os filhos para o destino que Deus planejou.
                                            </p>
                                            <div class="course-meta">
                                                <span class="course-meta-tag tag-pptv"><i class="fas fa-calendar-alt"></i> 11 semanas</span>
                                                <span class="course-meta-tag tag-pptv"><i class="fas fa-baby"></i> Filhos 3+ anos</span>
                                                <span class="course-meta-tag tag-pptv"><i class="fas fa-book"></i> 10 lições</span>
                                            </div>
                                            <div style="font-size:.8rem;color:var(--gray-500);line-height:1.7">
                                                <strong style="color:var(--gray-700);display:block;margin-bottom:6px">Temas abordados:</strong>
                                                No princípio · É necessário dois · Valorize seu filho · Invista · Prepare ·
                                                Discipline · Ensine · Libere · Destino
                                            </div>
                                        </div>
                                        <div class="course-card-footer">
                                            <a href="/inscricao" class="btn-course-cta cta-pptv">
                                                <i class="fas fa-child"></i> Inscrever-se neste curso
                                            </a>
                                        </div>
                                    </div>

                                </div>
                            </section>

                            <!-- ══ COMO FUNCIONA ══════════════════════════════════ -->
                            <section class="lp-section alt" id="como-funciona">
                                <div class="section-header">
                                    <span class="section-eyebrow" style="background:#f5f3ff;color:#7c3aed">Como Funciona</span>
                                    <h2 class="section-title">Do cadastro à formatura</h2>
                                    <p class="section-desc">Um processo simples e acolhedor para garantir que você aproveite ao máximo cada
                                        semana do curso.</p>
                                    </div>

                                    <div class="steps-grid">
                                        <div class="step-item">
                                            <div class="step-num">1</div>
                                            <h4 class="step-title">Inscrição Online</h4>
                                            <p class="step-desc">Preencha o formulário de inscrição com os dados do casal e escolha o curso
                                                desejado. Rápido e simples.</p>
                                            </div>
                                            <div class="step-item">
                                                <div class="step-num">2</div>
                                                <h4 class="step-title">Confirmação de Matrícula</h4>
                                                <p class="step-desc">Nossa equipe analisa a inscrição e entra em contato para confirmar a matrícula e
                                                    informar a turma.</p>
                                                </div>
                                                <div class="step-item">
                                                    <div class="step-num">3</div>
                                                    <h4 class="step-title">Aulas Semanais</h4>
                                                    <p class="step-desc">Encontros semanais de 2 horas com conteúdo interativo, dinâmicas e lição de casa
                                                        para o casal.</p>
                                                    </div>
                                                    <div class="step-item">
                                                        <div class="step-num">4</div>
                                                        <h4 class="step-title">Formatura e Certificado</h4>
                                                        <p class="step-desc">Ao concluir todas as lições, o casal recebe um certificado digital verificável de
                                                            conclusão do curso.</p>
                                                        </div>
                                                    </div>
                                                </section>

                                                <!-- ══ DIFERENCIAIS ═══════════════════════════════════ -->
                                                <section class="lp-section" id="diferenciais">
                                                    <div class="section-header">
                                                        <span class="section-eyebrow" style="background:#f0fdf4;color:#16a34a">Por que escolher</span>
                                                        <h2 class="section-title">O que torna nossos cursos especiais</h2>
                                                        <p class="section-desc">Metodologia comprovada, líderes treinados e conteúdo bíblico aprofundado — tudo para
                                                            transformar sua família.</p>
                                                        </div>

                                                        <div class="features-grid">
                                                            <div class="feature-item">
                                                                <div class="feature-icon" style="background:#eff6ff;color:#2563eb"><i class="fas fa-bible"></i></div>
                                                                <h4 class="feature-title">Fundamento Bíblico</h4>
                                                                <p class="feature-desc">Todos os cursos são baseados em princípios bíblicos eternos que se aplicam a
                                                                    qualquer fase do relacionamento familiar.</p>
                                                                </div>
                                                                <div class="feature-item">
                                                                    <div class="feature-icon" style="background:#f5f3ff;color:#7c3aed"><i class="fas fa-users"></i></div>
                                                                    <h4 class="feature-title">Pequenos Grupos</h4>
                                                                    <p class="feature-desc">Formato de pequenos grupos que favorece o acolhimento, a partilha e a construção
                                                                        de amizades duradouras entre casais.</p>
                                                                    </div>
                                                                    <div class="feature-item">
                                                                        <div class="feature-icon" style="background:#fff0f0;color:#e11d48"><i class="fas fa-heart"></i></div>
                                                                        <h4 class="feature-title">Ministério 2=1 Brasil</h4>
                                                                        <p class="feature-desc">Cursos do Ministério 2=1 Brasil, presente em mais de 100 países e com mais de
                                                                            140.000 casais formados no Brasil.</p>
                                                                        </div>
                                                                        <div class="feature-item">
                                                                            <div class="feature-icon" style="background:#f0fdf4;color:#16a34a"><i class="fas fa-certificate"></i>
                                                                            </div>
                                                                            <h4 class="feature-title">Certificado Digital</h4>
                                                                            <p class="feature-desc">Ao concluir o curso, o casal recebe um certificado digital com código de
                                                                                validação verificável online.</p>
                                                                            </div>
                                                                            <div class="feature-item">
                                                                                <div class="feature-icon" style="background:#fffbeb;color:#d97706"><i
                                                                                    class="fas fa-chalkboard-teacher"></i></div>
                                                                                    <h4 class="feature-title">Líderes Capacitados</h4>
                                                                                    <p class="feature-desc">Casais líderes treinados e dedicados a conduzir cada turma com cuidado,
                                                                                        confidencialidade e amor.</p>
                                                                                    </div>
                                                                                    <div class="feature-item">
                                                                                        <div class="feature-icon" style="background:#ecfeff;color:#0891b2"><i class="fas fa-mobile-alt"></i>
                                                                                        </div>
                                                                                        <h4 class="feature-title">Gestão Digitalizada</h4>
                                                                                        <p class="feature-desc">Inscrição online, acompanhamento de presença e emissão de certificado totalmente
                                                                                            digital, fácil e acessível.</p>
                                                                                        </div>
                                                                                    </div>
                                                                                </section>

                                                                                <!-- ══ CTA BANNER ════════════════════════════════════ -->
                                                                                <section class="lp-cta-banner">
                                                                                    <div class="cta-banner-inner">
                                                                                        <h2 class="cta-banner-title">Pronto para transformar sua família?</h2>
                                                                                        <p class="cta-banner-desc">
                                                                                            Dê o primeiro passo. Inscreva-se em um dos nossos cursos e comece uma jornada de crescimento,
                                                                                            restauração e propósito junto com seu cônjuge.
                                                                                        </p>
                                                                                        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
                                                                                            <a href="/inscricao" class="btn-hero-primary">
                                                                                                <i class="fas fa-paper-plane"></i> Fazer minha inscrição
                                                                                            </a>
                                                                                            <a href="#cursos" class="btn-hero-ghost">
                                                                                                <i class="fas fa-arrow-up"></i> Ver os cursos
                                                                                            </a>
                                                                                        </div>
                                                                                    </div>
                                                                                </section>

                                                                                <!-- ══ FOOTER ════════════════════════════════════════ -->
                                                                                <footer class="lp-footer">
                                                                                    <div class="footer-inner">
                                                                                        <div class="footer-top">
                                                                                            <div class="footer-brand">
                                                                                                <img src="~/images/logoVideira.png" alt="CCVideira" />
                                                                                                <p style="font-size:.85rem;font-weight:800;color:rgba(255,255,255,.7);margin-bottom:8px">CCVideira
                                                                                                </p>
                                                                                                <p>Transformando famílias através dos princípios bíblicos.</p>
                                                                                            </div>
                                                                                            <div>
                                                                                                <p class="footer-col-title">Cursos</p>
                                                                                                <ul class="footer-links">
                                                                                                    <li><a href="#cursos">Casados Para Sempre</a></li>
                                                                                                    <li><a href="#cursos">ONE – Curso para Noivos</a></li>
                                                                                                    <li><a href="#cursos">Pais Para Toda a Vida</a></li>
                                                                                                </ul>
                                                                                            </div>
                                                                                            <div>
                                                                                                <p class="footer-col-title">Links</p>
                                                                                                <ul class="footer-links">
                                                                                                    <li><a href="#como-funciona">Como Funciona</a></li>
                                                                                                    <li><a href="/inscricao">Inscrição Online</a></li>
                                                                                                    <li><a href="/certificado/validar">Validar Certificado</a></li>
                                                                                                    <li><a href="/auth/login">Área Administrativa</a></li>
                                                                                                </ul>
                                                                                            </div>
                                                                                            <div>
                                                                                                <p class="footer-col-title">Ministério</p>
                                                                                                <ul class="footer-links">
                                                                                                    <li><a href="https://www.ccvideira.com.br/" target="_blank">CCVideira</a></li>
                                                                                                </ul>
                                                                                                <ul class="footer-links">
                                                                                                    <li><a href="https://2igual1brasil.com.br" target="_blank">2=1 Brasil</a></li>
                                                                                                </ul>
                                                                                            </div>
                                                                                        </div>
                                                                                        <div class="footer-bottom">
                                                                                            <span>© @DateTime.Now.Year CCVideira · Todos os direitos reservados</span>
                                                                                            <span>Desenvolvido por <strong style="color:rgba(255,255,255,.5)">Daniel Alves Moreira</strong></span>
                                                                                        </div>
                                                                                    </div>
                                                                                </footer>

                                                                                <!-- Scripts -->
                                                                                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
                                                                                <script>
                                                                                    // Navbar scroll effect
                                                                                    window.addEventListener('scroll', function () {
                                                                                    document.getElementById('lpNav').classList.toggle('scrolled', window.scrollY > 40);
                                                                                    });

                                                                                    // Smooth scroll for anchor links
                                                                                    document.querySelectorAll('a[href^="#"]').forEach(a => {
                                                                                    a.addEventListener('click', function (e) {
                                                                                    const target = document.querySelector(this.getAttribute('href'));
                                                                                    if (target) {
                                                                                    e.preventDefault();
                                                                                    closeMobileMenu();
                                                                                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                                                                                    }
                                                                                    });
                                                                                    });

                                                                                    // Mobile menu
                                                                                    const mobileMenu = document.getElementById('mobileMenu');
                                                                                    const mobileBackdrop = document.getElementById('mobileMenuBackdrop');

                                                                                    function openMobileMenu() {
                                                                                    mobileMenu.classList.add('open');
                                                                                    mobileBackdrop.classList.add('open');
                                                                                    document.body.style.overflow = 'hidden';
                                                                                    }

                                                                                    function closeMobileMenu() {
                                                                                    mobileMenu.classList.remove('open');
                                                                                    mobileBackdrop.classList.remove('open');
                                                                                    document.body.style.overflow = '';
                                                                                    }

                                                                                    document.getElementById('navHamburger').addEventListener('click', openMobileMenu);
                                                                                    document.getElementById('mobileMenuClose').addEventListener('click', closeMobileMenu);
                                                                                    mobileBackdrop.addEventListener('click', closeMobileMenu);
                                                                                </script>

                                                                            </body>

                                                                        </html>