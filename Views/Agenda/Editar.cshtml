@model EnsinoApp.ViewModels.Agenda.EditarAgendaViewModel
@{
    ViewData["Title"] = "Editar Local da Aula";
}

<section class="content-header" style="padding-bottom:0">
    <div class="container-fluid">
        <a asp-action="Index" asp-route-idTurma="@Model.IdTurma" class="ea-btn-back">
            <i class="fas fa-arrow-left"></i> Voltar para a Agenda
        </a>
        <div class="ea-page-title">
            <h1><i class="fas fa-map-marker-alt" style="color:var(--primary);margin-right:8px"></i>Editar Local da Aula
            </h1>
            <p>Informe o local onde a aula será realizada para que os casais recebam no lembrete</p>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <form asp-action="Editar" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size:.8rem;margin-bottom:12px">
            </div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="IdTurma" />

            @* ── Info da lição (somente leitura) ── *@
            <div style="background:linear-gradient(135deg,#eff6ff,#dbeafe);border:1px solid #bfdbfe;border-radius:var(--radius-lg);padding:16px 20px;margin-bottom:18px;display:flex;align-items:center;gap:16px"
                 class="ea-fade ea-fade-1">
                <div
                    style="width:48px;height:48px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0">
                    @Model.NumeroLicao
                </div>
                <div>
                    <p
                        style="font-size:.7rem;font-weight:700;color:var(--primary);text-transform:uppercase;letter-spacing:.4px;margin:0 0 2px">
                        Lição @Model.NumeroLicao</p>
                        <p style="font-family:var(--font);font-size:.95rem;font-weight:800;color:var(--gray-800);margin:0">
                            @Model.TituloLicao</p>
                            <p style="font-size:.8rem;color:var(--gray-500);margin:3px 0 0">
                                <i class="fas fa-calendar-alt" style="margin-right:4px"></i>
                                @Model.DataAula.ToString("dddd, dd 'de' MMMM 'de' yyyy")
                            </p>
                        </div>
                    </div>

                    @* ── Formulário ── *@
                    <div class="ea-form-card ea-fade ea-fade-2">
                        <div class="ea-form-card-header">
                            <div class="ea-form-header-icon" style="background:var(--primary-light);color:var(--primary)">
                                <i class="fas fa-map-marker-alt"></i>
                            </div>
                            <h3 class="ea-form-card-title">Localização da Aula</h3>
                        </div>
                        <div class="ea-form-card-body">

                            <div class="ea-field-group">
                                <label asp-for="Local" class="ea-field-label">
                                    Local <span style="color:var(--gray-300);font-weight:400;text-transform:none">(ex: Salão
                                    principal, Rua X, 123 – Bairro)</span>
                                </label>
                                <input asp-for="Local" class="ea-field-control"
                                       placeholder="Informe o endereço ou nome do local da aula" />
                                <span asp-validation-for="Local" class="ea-field-error"></span>
                            </div>

                            <div class="ea-field-group">
                                <label asp-for="Observacoes" class="ea-field-label">
                                    Observações <span
                                    style="color:var(--gray-300);font-weight:400;text-transform:none">(opcional)</span>
                                </label>
                                <textarea asp-for="Observacoes" class="ea-field-control" rows="4"
                                          placeholder="Ex: Trazer caderno, chegar às 19h30, estacionamento na rua..."></textarea>
                                <span asp-validation-for="Observacoes" class="ea-field-error"></span>
                            </div>

                            <div
                                style="display:flex;align-items:center;gap:8px;background:#fffbeb;border:1px solid #fde68a;border-radius:var(--radius);padding:10px 14px;font-size:.78rem;color:#92400e;font-weight:600;margin-top:4px">
                                <i class="fas fa-bell"></i>
                                O lembrete por email será enviado automaticamente 1 dia antes da aula com estas informações.
                            </div>
                        </div>
                        <div class="ea-form-footer">
                            <a asp-action="Index" asp-route-idTurma="@Model.IdTurma" class="ea-btn-action cancel">
                                <i class="fas fa-times"></i> Cancelar
                            </a>
                            <button type="submit" class="ea-btn-action save">
                                <i class="fas fa-save"></i> Salvar
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </section>

        @section Scripts {
            <partial name="_ValidationScriptsPartial" />
        }
