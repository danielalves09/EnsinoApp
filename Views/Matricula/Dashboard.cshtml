@model EnsinoApp.ViewModels.Matricula.MatriculaDashboardViewModel

@{
    ViewData["Title"] = "Dashboard de Matrículas";
}

<div class="container-fluid">
    <h3 class="mb-4">📋 Módulo de Matrículas</h3>

    <!-- Cards -->
    <div class="row mb-4">
        <div class="col-md-2">
            <div class="card shadow-sm text-center p-3">
                <strong>@Model.TotalCasais</strong>
                <small>Casais</small>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card shadow-sm text-center p-3">
                <strong>@Model.TotalInscricoes</strong>
                <small>Inscrições</small>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card shadow-sm text-center p-3">
                <strong>@Model.InscricoesPendentes</strong>
                <small>Pendentes</small>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card shadow-sm text-center p-3">
                <strong>@Model.MatriculasAtivas</strong>
                <small>Matrículas Ativas</small>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card shadow-sm text-center p-3">
                <strong>@Model.TurmasAtivas</strong>
                <small>Turmas</small>
            </div>
        </div>
    </div>

    <!-- Inscrições Pendentes -->
    <div class="card mb-10">
        <div class="card-header">🕓 Inscrições Pendentes</div>
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>Casal</th>
                    <th>Curso</th>
                    <th>Campus</th>
                    <th>Data</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.InscricoesPendentesLista)
                {
                    <tr>
                        <td>@item.NomeCasal</td>
                        <td>@item.Curso</td>
                        <td>@item.Campus</td>
                        <td>@item.DataInscricao.ToShortDateString()</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Casais -->
    <div class="card">
        <div class="card-header">👫 Casais Cadastrados</div>
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Casal</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var casal in Model.Casais)
                {
                    <tr>
                        <td>@casal.NomeCasal</td>
                        <td>
                            @if (casal.PossuiMatriculaAtiva)
                            {
                                <span class="badge bg-success">Matriculado</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Sem matrícula</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>