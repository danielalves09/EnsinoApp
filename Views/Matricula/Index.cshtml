@model EnsinoApp.ViewModels.Matricula.MatriculaDashboardViewModel

@{
    ViewData["Title"] = "Dashboard de Matrículas";
}
<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Gerenciar Matrículas</h1>
            </div>
        </div>
    </div>
</section>
<div class="container-fluid py-4">

    <!-- Cards -->
    <div class="row">
        <div class="col-md-2 col-sm-6 col-12">
            <div class="info-box shadow">
                <span class="info-box-icon bg-info"><i class="fas fa-users"></i></span>

                <div class="info-box-content">
                    <span class="info-box-text">Casais</span>
                    <span class="info-box-number">@Model.TotalCasais</span>
                </div>
                <!-- /.info-box-content -->
            </div>
            <!-- /.info-box -->
        </div>
        <!-- /.col -->
        <div class="col-md-2 col-sm-6 col-12">
            <div class="info-box shadow">
                <span class="info-box-icon bg-primary"><i class="fas fa-file-signature"></i></span>

                <div class="info-box-content">
                    <span class="info-box-text">Inscrições</span>
                    <span class="info-box-number">@Model.TotalInscricoes</span>
                </div>
                <!-- /.info-box-content -->
            </div>
            <!-- /.info-box -->
        </div>
        <!-- /.col -->
        <div class="col-md-2 col-sm-6 col-12">
            <div class="info-box shadow">
                <span class="info-box-icon bg-warning"><i class="fas fa-hourglass-half"></i></span>

                <div class="info-box-content">
                    <span class="info-box-text">Pendentes</span>
                    <span class="info-box-number">@Model.InscricoesPendentes</span>
                </div>
                <!-- /.info-box-content -->
            </div>
            <!-- /.info-box -->
        </div>
        <!-- /.col -->
        <div class="col-md-3 col-sm-6 col-12">
            <div class="info-box shadow">
                <span class="info-box-icon bg-success"><i class="fas fa-user-check"></i></span>

                <div class="info-box-content">
                    <span class="info-box-text">Matriculas Ativas</span>
                    <span class="info-box-number">@Model.MatriculasAtivas</span>
                </div>
                <!-- /.info-box-content -->
            </div>
            <!-- /.info-box -->
        </div>
        <!-- /.col -->
        <div class="col-md-3 col-sm-6 col-12">
            <div class="info-box shadow">
                <span class="info-box-icon bg-dark"><i class="fas fa-layer-group"></i></span>

                <div class="info-box-content">
                    <span class="info-box-text">Turmas</span>
                    <span class="info-box-number">@Model.TurmasAtivas</span>
                </div>
                <!-- /.info-box-content -->
            </div>
            <!-- /.info-box -->
        </div>
        <!-- /.col -->
    </div>



    <!-- Inscrições Pendentes -->
    <div class="card mb-4 card-outline card-warning shadow-sm">
        <div class="card-header"><i class="fas fa-hourglass-half"></i> Inscrições Pendentes</div>
        <div class="table-responsive">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Casal</th>
                        <th>Curso</th>
                        <th>Campus</th>
                        <th>Data Inscrição</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.InscricoesPendentesLista)
                    {
                        <tr>
                            <td>@item.NomeCasal</td>
                            <td>@item.Curso</td>
                            <td>@item.Campus</td>
                            <td>@item.DataInscricao.ToShortDateString()</td>
                            <td>
                                <a class="btn btn-sm btn-primary" asp-controller="Matricula" asp-action="Cadastrar"
                                       asp-route-id="@item.Id">
                                    <i class="fas fa-user-plus"></i> Matricular
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Casais Cadastrados -->
    <div class="card card-outline card-success shadow-sm">
        <div class="card-header "><i class="fas fa-users"></i> Casais Cadastrados</div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Casal</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var casal in Model.Casais)
                    {
                        <tr>
                            <td>@casal.NomeCasal</td>
                            <td>
                                @if (casal.PossuiMatriculaAtiva)
                                {
                                    <span class="badge bg-success"><i class="fas fa-check-circle"></i> Matriculado</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="fas fa-times-circle"></i> Sem matrícula</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/js/all.min.js"></script>
}