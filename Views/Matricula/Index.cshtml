@model EnsinoApp.ViewModels.Matricula.MatriculaDashboardViewModel
@{
    ViewData["Title"] = "Gerenciar Matrículas";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="ea-page-title">
            <h1><i class="fas fa-user-graduate" style="color:var(--primary);margin-right:8px"></i>Gerenciar Matrículas
            </h1>
            <p>Acompanhe inscrições, matrículas ativas e casais cadastrados</p>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        <div class="ea-stat-grid">
            <div class="ea-stat-card ea-fade ea-fade-1">
                <div class="ea-stat-icon cyan"><i class="fas fa-users"></i></div>
                <div>
                    <p class="ea-stat-label">Casais</p>
                    <p class="ea-stat-number">@Model.TotalCasais</p>
                </div>
            </div>
            <div class="ea-stat-card ea-fade ea-fade-2">
                <div class="ea-stat-icon blue"><i class="fas fa-file-signature"></i></div>
                <div>
                    <p class="ea-stat-label">Inscrições</p>
                    <p class="ea-stat-number">@Model.TotalInscricoes</p>
                </div>
            </div>
            <div class="ea-stat-card ea-fade ea-fade-3">
                <div class="ea-stat-icon yellow"><i class="fas fa-hourglass-half"></i></div>
                <div>
                    <p class="ea-stat-label">Pendentes</p>
                    <p class="ea-stat-number">@Model.InscricoesPendentes</p>
                </div>
            </div>
            <div class="ea-stat-card ea-fade ea-fade-4">
                <div class="ea-stat-icon green"><i class="fas fa-user-check"></i></div>
                <div>
                    <p class="ea-stat-label">Matrículas Ativas</p>
                    <p class="ea-stat-number">@Model.MatriculasAtivas</p>
                </div>
            </div>
            <div class="ea-stat-card ea-fade ea-fade-5">
                <div class="ea-stat-icon dark"><i class="fas fa-layer-group"></i></div>
                <div>
                    <p class="ea-stat-label">Turmas</p>
                    <p class="ea-stat-number">@Model.TurmasAtivas</p>
                </div>
            </div>
        </div>

        <div class="ea-toolbar">
            <form method="get" style="flex:1 1 auto">
                <div class="ea-filter-group">
                    <div class="ea-filter-item">
                        <label><i class="fas fa-graduation-cap" style="margin-right:3px"></i>Curso</label>
                        @Html.DropDownList("IdCurso",(SelectList)ViewBag.Cursos,"Todos os cursos",new{@class="ea-filter-select"})
                    </div>
                    <div class="ea-filter-item">
                        <label><i class="fas fa-map-marker-alt" style="margin-right:3px"></i>Campus</label>
                        @Html.DropDownList("IdCampus",(SelectList)ViewBag.Campuses,"Todos os campi",new{@class="ea-filter-select"})
                    </div>
                    <div style="display:flex;align-items:flex-end;gap:6px">
                        <button type="submit" class="ea-btn-filter"><i class="fas fa-filter"></i> Filtrar</button>
                        <a asp-action="Index" class="ea-btn-clear"><i class="fas fa-times"></i> Limpar</a>
                    </div>
                </div>
            </form>
        </div>

        <div class="ea-table-card ea-fade">
            <div class="ea-table-card-header">
                <div class="ea-table-header-icon" style="background:var(--warning-light);color:var(--warning)"><i
                    class="fas fa-hourglass-half"></i></div>
                    <h3 class="ea-table-card-title">Inscrições Pendentes</h3>
                    @if (Model.InscricoesPendentesLista?.Any() == true)
                    {
                        <span class="ea-count-badge"
                              style="background:var(--warning-light);color:var(--warning);border-color:#fde68a">@Model.InscricoesPendentesLista.Count()
                            pendentes</span>
                        }
                    </div>
                    <div style="overflow-x:auto">
                        <table class="ea-table">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th>Casal</th>
                                    <th>Curso</th>
                                    <th>Campus</th>
                                    <th>Data Inscrição</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.InscricoesPendentesLista?.Any() == true)
                                {
                                    @foreach (var item in Model.InscricoesPendentesLista)
                                    {
                                        <tr>
                                            <td>
                                                            <button type="button" class="btn-ver-casal" data-id="@item.Id"
                                                                    title="Ver detalhes do casal">
                                                                <i class="fas fa-eye"></i> Detalhes
                                                            </button>
                                                        </td>
                                            <td>
                                                <div style="display:flex;align-items:center;gap:9px">
                                                    <div
                                                        style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#fff0f0,#fecaca);color:#f87171;display:flex;align-items:center;justify-content:center;font-size:.7rem;flex-shrink:0">
                                                        <i class="fas fa-heart"></i>
                                                    </div>
                                                    <span style="font-weight:700;color:var(--gray-800)">@item.NomeCasal</span>
                                                </div>
                                            </td>
                                            <td><span class="ea-meta-pill"><i class="fas fa-graduation-cap"></i>@item.Curso</span></td>
                                            <td><span class="ea-meta-pill"><i class="fas fa-map-marker-alt"></i>@item.Campus</span></td>
                                            <td><span class="ea-date-pill"><i
                                                class="fas fa-calendar-alt"></i>@item.DataInscricao.ToShortDateString()</span>
                                            </td>
                                            <td>
                                                <a asp-controller="Matricula" asp-action="Cadastrar" asp-route-id="@item.Id"
                                                       style="display:inline-flex;align-items:center;gap:5px;background:var(--primary);color:#fff;border:none;border-radius:var(--radius-sm);padding:6px 12px;font-size:.75rem;font-weight:700;text-decoration:none;transition:background .18s">
                                                    <i class="fas fa-user-plus"></i> Matricular
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5"
                                            style="text-align:center;padding:32px 16px;color:var(--gray-400);font-style:italic;font-size:.82rem">
                                            Nenhuma inscrição pendente.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                     <!-- Paginação -->
                        @if (ViewBag.TotalPaginas > 1)
                        {
                            <div class="ea-pagination">
                                @if (ViewBag.NumeroPagina > 1)
                                {
                                    <a class="ea-page-btn" href="@Url.Action("Index","Matricula",new{idCurso=ViewBag.IdCursoSelecionado,idCampus=ViewBag.IdCampusSelecionado,Pagina=ViewBag.NumeroPagina-1})">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                }
                                <span class="ea-page-info">Página @ViewBag.NumeroPagina de @ViewBag.TotalPaginas</span>
                                @if (ViewBag.NumeroPagina < ViewBag.TotalPaginas)
                                {
                                    <a class="ea-page-btn" href="@Url.Action("Index","Matricula",new{idCurso=ViewBag.IdCursoSelecionado,idCampus=ViewBag.IdCampusSelecionado,Pagina=ViewBag.NumeroPagina+1})">
                                        <i class="fas fa-chevron-right"></i>
                                    </a>
                                }
                            </div>
                        }





                   

    </div>
</section>


<div class="modal fade" id="modalCasal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border:none;border-radius:var(--radius-lg);overflow:hidden">

            
            <div class="modal-header" style="background:linear-gradient(135deg,#1e40af,#2563eb);border:none;padding:20px 24px">
                <div style="display:flex;align-items:center;gap:12px">
                    <div style="width:40px;height:40px;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:.9rem;flex-shrink:0">
                        <i class="fas fa-heart"></i>
                    </div>
                    <div>
                        <h5 class="modal-title" id="modalCasalNome" style="font-family:var(--font);font-size:1rem;font-weight:800;color:#fff;margin:0"></h5>
                        <p id="modalCasalCampus" style="font-size:.75rem;color:rgba(255,255,255,.7);margin:0"></p>
                    </div>
                </div>
                <button type="button" class="close" data-dismiss="modal" style="color:#fff;opacity:.7;font-size:1.4rem;padding:0;margin:0">
                    <span>&times;</span>
                </button>
            </div>

           
            <div class="modal-body" style="padding:0">

                @* {{-- Loading --}} *@
                <div id="modalCasalLoading" style="display:flex;align-items:center;justify-content:center;padding:48px;gap:10px;color:var(--gray-400)">
                    <i class="fas fa-circle-notch fa-spin"></i>
                    <span style="font-size:.85rem">Carregando...</span>
                </div>

                @* {{-- Conteúdo (oculto até carregar) --}} *@
                <div id="modalCasalConteudo" style="display:none">

                    
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-bottom:1px solid var(--gray-100)">

                        
                        <div style="padding:20px 24px;border-right:1px solid var(--gray-100)">
                            <p style="font-size:.68rem;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.4px;margin:0 0 12px">Homem</p>
                            <p id="mc-nome1" style="font-family:var(--font);font-size:.9rem;font-weight:800;color:var(--gray-800);margin:0 0 8px"></p>
                            <div style="display:flex;flex-direction:column;gap:5px">
                                <span id="mc-email1" style="font-size:.78rem;color:var(--gray-500)"></span>
                                <span id="mc-fone1"  style="font-size:.78rem;color:var(--gray-500)"></span>
                            </div>
                        </div>

                        
                        <div style="padding:20px 24px">
                            <p style="font-size:.68rem;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.4px;margin:0 0 12px">Mulher</p>
                            <p id="mc-nome2" style="font-family:var(--font);font-size:.9rem;font-weight:800;color:var(--gray-800);margin:0 0 8px"></p>
                            <div style="display:flex;flex-direction:column;gap:5px">
                                <span id="mc-email2" style="font-size:.78rem;color:var(--gray-500)"></span>
                                <span id="mc-fone2"  style="font-size:.78rem;color:var(--gray-500)"></span>
                            </div>
                        </div>

                    </div>

                    
                    <div style="padding:16px 24px;border-bottom:1px solid var(--gray-100);display:flex;align-items:center;gap:10px">
                        <div style="width:28px;height:28px;background:var(--primary-light);color:var(--primary);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:.7rem;flex-shrink:0">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <span id="mc-endereco" style="font-size:.82rem;color:var(--gray-600)"></span>
                    </div>                  
                    

                </div>
            </div>

        </div>
    </div>
</div>

                     

@section Scripts {
<style>
    .btn-ver-casal {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--primary-light);
        color: var(--primary);
        border: 1px solid var(--primary-mid);
        border-radius: var(--radius-sm);
        padding: 5px 11px;
        font-size: .75rem;
        font-weight: 700;
        cursor: pointer;
        transition: background .18s;
        font-family: var(--font);
    }
    .btn-ver-casal:hover { background: var(--primary-mid); }

    .mc-matricula-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 0;
        border-bottom: 1px solid var(--gray-100);
        font-size: .82rem;
    }
    .mc-matricula-item:last-child { border-bottom: none; }

    .mc-curso-icon {
        width: 32px;
        height: 32px;
        border-radius: var(--radius-sm);
        background: var(--success-light);
        color: var(--success);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .7rem;
        flex-shrink: 0;
    }
    .mc-badge {
        display: inline-flex;
        align-items: center;
        font-size: .68rem;
        font-weight: 700;
        border-radius: 20px;
        padding: 2px 8px;
        margin-left: auto;
        white-space: nowrap;
    }
    .mc-badge.ativa       { background: var(--success-light); color: var(--success);  border: 1px solid #bbf7d0; }
    .mc-badge.concluida   { background: var(--primary-light); color: var(--primary);  border: 1px solid var(--primary-mid); }
    .mc-badge.desistente  { background: var(--danger-light);  color: var(--danger);   border: 1px solid #fca5a5; }
</style>

<script>
    $(function () {

        // ── Abre o modal e busca os dados via fetch ──────────────────────
        $(document).on('click', '.btn-ver-casal', function () {
            var id = $(this).data('id');

            // Reseta o modal antes de abrir
            $('#modalCasalNome').text('Carregando...');
            $('#modalCasalCampus').text('');
            $('#modalCasalLoading').show();
            $('#modalCasalConteudo').hide();

            $('#modalCasal').modal('show');

            // Busca os dados do endpoint JSON
            $.getJSON('/Matricula/Detalhes/' + id)
                .done(function (d) {
                    preencherModal(d);
                })
                .fail(function () {
                    $('#modalCasalLoading').html(
                        '<span style="color:var(--danger);font-size:.85rem">' +
                        '<i class="fas fa-exclamation-circle" style="margin-right:6px"></i>' +
                        'Erro ao carregar os dados. Tente novamente.</span>'
                    );
                });
        });

        // ── Preenche o modal com os dados recebidos ──────────────────────
        function preencherModal(d) {
            // Header
            $('#modalCasalNome').text(d.nomeConjuge1 + ' e ' + d.nomeConjuge2);
            $('#modalCasalCampus').html(
                '<i class="fas fa-map-marker-alt" style="margin-right:4px"></i>' +
                d.nomeCampus + (d.gc ? ' - GC: ' + d.gc : 'Nome GC não informado')
            );

            // Cônjuges
            $('#mc-nome1').text(d.nomeConjuge1);
            $('#mc-email1').html('<i class="fas fa-envelope" style="margin-right:5px;color:var(--gray-300)"></i>' + d.emailConjuge1);
            $('#mc-fone1').html('<i class="fas fa-phone" style="margin-right:5px;color:var(--gray-300)"></i>' + d.telefoneConjuge1);

            $('#mc-nome2').text(d.nomeConjuge2);
            $('#mc-email2').html('<i class="fas fa-envelope" style="margin-right:5px;color:var(--gray-300)"></i>' + d.emailConjuge2);
            $('#mc-fone2').html('<i class="fas fa-phone" style="margin-right:5px;color:var(--gray-300)"></i>' + d.telefoneConjuge2);

            // Endereço
            var partes = [d.rua, d.numero, d.complemento, d.bairro, d.cidade + ' - ' + d.estado, d.cep]
                .filter(function (p) { return p && p.trim() !== ''; });
            $('#mc-endereco').text(partes.join(', '));         

            // Exibe o conteúdo
            $('#modalCasalLoading').hide();
            $('#modalCasalConteudo').show();
        }

        // ── Helpers ──────────────────────────────────────────────────────
        function traduzirStatus(s) {
            var mapa = {
                'Ativo': 'Ativo', 'Ativa': 'Ativa',
                'Desistente': 'Desistente',
                'Concluido': 'Concluído', 'Concluída': 'Concluída',
                'Cancelada': 'Cancelada'
            };
            return mapa[s] || s;
        }

        function formatarData(iso) {
            if (!iso) return '';
            var d = new Date(iso);
            return d.toLocaleDateString('pt-BR');
        }

    });
</script>
}

