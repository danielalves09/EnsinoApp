@model EnsinoApp.ViewModels.Matricula.MatriculaDashboardViewModel
@{ ViewData["Title"] = "Gerenciar Matrículas"; }

<section class="content-header">
    <div class="container-fluid">
        <div class="ea-page-title">
            <h1><i class="fas fa-user-graduate" style="color:var(--primary);margin-right:8px"></i>Gerenciar Matrículas</h1>
            <p>Acompanhe inscrições, matrículas ativas e casais cadastrados</p>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        <div class="ea-stat-grid">
            <div class="ea-stat-card ea-fade ea-fade-1"><div class="ea-stat-icon cyan"><i class="fas fa-users"></i></div><div><p class="ea-stat-label">Casais</p><p class="ea-stat-number">@Model.TotalCasais</p></div></div>
            <div class="ea-stat-card ea-fade ea-fade-2"><div class="ea-stat-icon blue"><i class="fas fa-file-signature"></i></div><div><p class="ea-stat-label">Inscrições</p><p class="ea-stat-number">@Model.TotalInscricoes</p></div></div>
            <div class="ea-stat-card ea-fade ea-fade-3"><div class="ea-stat-icon yellow"><i class="fas fa-hourglass-half"></i></div><div><p class="ea-stat-label">Pendentes</p><p class="ea-stat-number">@Model.InscricoesPendentes</p></div></div>
            <div class="ea-stat-card ea-fade ea-fade-4"><div class="ea-stat-icon green"><i class="fas fa-user-check"></i></div><div><p class="ea-stat-label">Matrículas Ativas</p><p class="ea-stat-number">@Model.MatriculasAtivas</p></div></div>
            <div class="ea-stat-card ea-fade ea-fade-5"><div class="ea-stat-icon dark"><i class="fas fa-layer-group"></i></div><div><p class="ea-stat-label">Turmas</p><p class="ea-stat-number">@Model.TurmasAtivas</p></div></div>
        </div>

        <div class="ea-table-card ea-fade">
            <div class="ea-table-card-header">
                <div class="ea-table-header-icon" style="background:var(--warning-light);color:var(--warning)"><i class="fas fa-hourglass-half"></i></div>
                <h3 class="ea-table-card-title">Inscrições Pendentes</h3>
                @if (Model.InscricoesPendentesLista?.Any() == true)
                { <span class="ea-count-badge" style="background:var(--warning-light);color:var(--warning);border-color:#fde68a">@Model.InscricoesPendentesLista.Count() pendentes</span> }
            </div>
            <div style="overflow-x:auto">
                <table class="ea-table">
                    <thead><tr><th>Casal</th><th>Curso</th><th>Campus</th><th>Data Inscrição</th><th></th></tr></thead>
                    <tbody>
                        @if (Model.InscricoesPendentesLista?.Any() == true)
                        {
                            @foreach (var item in Model.InscricoesPendentesLista)
                            {
                                <tr>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:9px">
                                            <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#fff0f0,#fecaca);color:#f87171;display:flex;align-items:center;justify-content:center;font-size:.7rem;flex-shrink:0"><i class="fas fa-heart"></i></div>
                                            <span style="font-weight:700;color:var(--gray-800)">@item.NomeCasal</span>
                                        </div>
                                    </td>
                                    <td><span class="ea-meta-pill"><i class="fas fa-graduation-cap"></i>@item.Curso</span></td>
                                    <td><span class="ea-meta-pill"><i class="fas fa-map-marker-alt"></i>@item.Campus</span></td>
                                    <td><span class="ea-date-pill"><i class="fas fa-calendar-alt"></i>@item.DataInscricao.ToShortDateString()</span></td>
                                    <td>
                                        <a asp-controller="Matricula" asp-action="Cadastrar" asp-route-id="@item.Id"
                                           style="display:inline-flex;align-items:center;gap:5px;background:var(--primary);color:#fff;border:none;border-radius:var(--radius-sm);padding:6px 12px;font-size:.75rem;font-weight:700;text-decoration:none;transition:background .18s">
                                            <i class="fas fa-user-plus"></i> Matricular
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" style="text-align:center;padding:32px 16px;color:var(--gray-400);font-style:italic;font-size:.82rem">Nenhuma inscrição pendente.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="ea-table-card ea-fade">
            <div class="ea-table-card-header">
                <div class="ea-table-header-icon" style="background:var(--success-light);color:var(--success)"><i class="fas fa-users"></i></div>
                <h3 class="ea-table-card-title">Casais Cadastrados</h3>
                @if (Model.Casais?.Any() == true)
                { <span class="ea-count-badge" style="background:var(--success-light);color:var(--success);border-color:#bbf7d0">@Model.Casais.Count() casais</span> }
            </div>
            <div style="overflow-x:auto">
                <table class="ea-table">
                    <thead><tr><th>Casal</th><th>Status</th></tr></thead>
                    <tbody>
                        @if (Model.Casais?.Any() == true)
                        {
                            @foreach (var casal in Model.Casais)
                            {
                                <tr>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:9px">
                                            <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#fff0f0,#fecaca);color:#f87171;display:flex;align-items:center;justify-content:center;font-size:.7rem;flex-shrink:0"><i class="fas fa-heart"></i></div>
                                            <span style="font-weight:700;color:var(--gray-800)">@casal.NomeCasal</span>
                                        </div>
                                    </td>
                                    <td>
                                        @if (casal.PossuiMatriculaAtiva)
                                        { <span class="ea-badge ativo">Matriculado</span> }
                                        else
                                        { <span class="ea-badge inativo">Sem matrícula</span> }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="2" style="text-align:center;padding:32px 16px;color:var(--gray-400);font-style:italic">Nenhum casal cadastrado.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>
