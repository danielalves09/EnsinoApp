@model IEnumerable<EnsinoApp.ViewModels.Usuario.ListarUsuarioViewModel>
@{
    ViewData["Title"] = "Usuários";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="ea-page-title">
            <h1><i class="fas fa-user-cog" style="color:var(--primary);margin-right:8px"></i>Usuários</h1>
            <p>Gerencie os usuários e líderes cadastrados no sistema</p>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        <div class="ea-toolbar">
            <form method="get" style="flex:1 1 220px">
                <div class="ea-search-wrap">
                    <i class="fas fa-search ea-search-icon"></i>
                    <input type="text" placeholder="Buscar por nome ou email..." name="filtro" />
                    <button type="submit" class="ea-btn-search"><i class="fas fa-search"></i></button>
                </div>
            </form>
            <a href="/Usuarios/adicionar" class="ea-btn-new"><i class="fas fa-plus"></i> Novo Usuário</a>
        </div>

        <div class="ea-table-card">
            <div class="ea-table-card-header">
                <div class="ea-table-header-icon"><i class="fas fa-users"></i></div>
                <h3 class="ea-table-card-title">Lista de Usuários</h3>
                @if (Model != null && Model.Any())
                {
                    <span class="ea-count-badge">@Model.Count() usuários</span>
                }
            </div>
            <div style="overflow-x:auto">
                @if (Model != null && Model.Any())
                {
                    <table class="ea-table">
                        <thead>
                            <tr>
                                <th>Usuário</th>
                                <th>Email</th>
                                <th>Tipo Usuário</th>
                                <th>Campus</th>
                                <th>Supervisão</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var partes = (item.NomeCompleto ?? "?").Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                var iniciais = partes.Length >= 2 ? $"{partes[0][0]}{partes[^1][0]}" : partes[0][0].ToString();
                                <tr>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:10px">
                                            <div
                                                style="width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--primary-light),var(--primary-mid));color:var(--primary);font-size:.75rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:var(--font)">
                                                @iniciais.ToUpper()</div>
                                                <span style="font-weight:700;color:var(--gray-800)">@item.NomeCompleto</span>
                                            </div>
                                        </td>
                                        <td style="color:var(--gray-500);font-size:.78rem"><i class="fas fa-envelope"
                                                                                                  style="margin-right:4px;color:var(--gray-300)"></i>@item.Email</td>
                                           
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(item.TipoUsuario))
                                                {
                                                    <span class="ea-meta-pill"><i class="fas fa-user"></i>@item.TipoUsuario</span>
                                                }
                                                else
                                                {

                                                    <span style="color:var(--gray-300);font-size:.75rem">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(item.Campus))
                                                {
                                                    <span class="ea-meta-pill"><i class="fas fa-map-marker-alt"></i>@item.Campus</span>
                                                }
                                                else
                                                {

                                                    <span style="color:var(--gray-300);font-size:.75rem">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(item.Supervisao))
                                                {
                                                    <span class="ea-meta-pill"><i class="fas fa-sitemap"></i>@item.Supervisao</span>
                                                }
                                                else
                                                {

                                                    <span style="color:var(--gray-300);font-size:.75rem">—</span>
                                                }
                                            </td>
                                            <td><span class="ea-badge @(item.Ativo ? "ativo" : "inativo")">@(item.Ativo ? "Ativo" :
                                                                                                                                                                                                                                                                                                                                    "Inativo")</span></td>
                                                <td>
                                                    <div style="display:flex;gap:6px">
                                                        <a href="/usuarios/editar/@item.Id" class="ea-action-btn primary" title="Editar"><i
                                                            class="fas fa-edit"></i></a>
                                                            <a asp-controller="Usuarios" asp-action="Excluir" asp-route-id="@item.Id"
                                                               onclick="return confirm('Excluir o usuário @item.NomeCompleto?')"
                                                               class="ea-action-btn danger" title="Excluir"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                else
                                {
                                    <div class="ea-empty" style="border:none;border-radius:0">
                                        <i class="fas fa-users"></i>
                                        <h3>Nenhum usuário encontrado</h3>
                                        <p>Tente outro termo ou cadastre um novo usuário.</p>
                                    </div>
                                }
                            </div>
                        </div>

                    </div>
                </section>