<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnsinoApp</title>
    <script type="importmap"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Google Font: Source Sans Pro -->
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/css/fontawesome.min.css">
        <!-- Theme style -->
        <link rel="stylesheet" href="~/css/adminlte.min.css">
        </head>

        <body class="hold-transition sidebar-mini">
            <!-- Site wrapper -->
            <div class="wrapper">
                <!-- Navbar -->
                <nav class="main-header navbar navbar-expand navbar-white navbar-light">
                    <!-- Left navbar links -->
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                        </li>
                    </ul>

                    <!-- Right navbar links -->
                    <ul class="navbar-nav ml-auto">
                        <li class="nav-item dropdown user-menu">
                            <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">
                                <img src="~/images/foto.jpeg" class="user-image img-circle elevation-2" alt="User Image">
                                    <span class="d-none d-md-inline">@ViewBag.NomeUsuario</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-right">
                                    <!-- User image -->
                                    <li class="user-header bg-primary">
                                        <img src="~/images/foto.jpeg" class="img-circle elevation-2" alt="User Image">

                                            <p>
                                                @ViewBag.NomeUsuario
                                                <small>- -</small>
                                            </p>
                                        </li>
                                        <!-- Menu Body -->

                                        <!-- Menu Footer-->
                                        <li class="user-footer">
                                            <a href="#" class="btn btn-default btn-flat">Perfil</a>

                                            <a class="btn btn-default btn-flat float-right" role="button" asp-controller="Auth"
                                                   asp-action="Logout">
                                                <i class="fas fa-sign-out-alt"></i> Sair
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" role="button" asp-controller="Auth" asp-action="Logout">
                                        <i class="fas fa-sign-out-alt"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                        <!-- /.navbar -->
                        <!-- Main Sidebar Container -->
                        <aside class="main-sidebar  sidebar-yelow-lightblue elevation-4">
                            <!-- Brand Logo -->
                            <a href="index3.html" class="brand-link bg-light">
                                <img src="~/images/favicon.png" alt="EnsinoApp Logo" class="brand-image img-circle elevation-3"
                                     style="opacity: .8">
                                    <span class="brand-text font-weight-light">EnsinoApp</span>
                                </a>


                                <!-- Sidebar -->
                                <div class="sidebar">



                                    <!-- Sidebar Menu -->
                                    <nav class="mt-2">
                                        <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu"
                                            data-accordion="false">
                                            <!-- Add icons to the links using the .nav-icon class
                          with font-awesome or any other icon font library -->
                                            <a href="/home/" class="nav-link">
                                                <i class="nav-icon fas fa-home"></i>
                                                <p>
                                                    Início
                                                </p>
                                            </a>
                                            <a href="/curso/" class="nav-link">
                                                <i class="nav-icon fas fa-graduation-cap"></i>
                                                <p>
                                                    Cursos
                                                </p>
                                            </a>
                                            <a href="/turma/" class="nav-link">
                                                <i class="nav-icon fas fa-users"></i>
                                                <p>
                                                    Turmas
                                                </p>
                                            </a>
                                            <a href="/matricula/" class="nav-link">
                                                <i class="fas fa-chalkboard-teacher"></i>
                                                <p>
                                                    Matrículas
                                                </p>
                                            </a>
                                            <li class="nav-item">
                                                <a href="#" class="nav-link">
                                                    <i class="nav-icon fas fa-sitemap"></i>
                                                    <p>
                                                        Estrutura da Igreja
                                                        <i class="right fas fa-angle-left"></i>
                                                    </p>
                                                </a>
                                                <ul class="nav nav-treeview">
                                                    <li class="nav-item">
                                                        <a href="/campus" class="nav-link">
                                                            <i class="fas fa-building nav-icon"></i>
                                                            <p>Campus</p>
                                                        </a>
                                                    </li>
                                                    <li class="nav-item">
                                                        <a href="/supervisao" class="nav-link">
                                                            <i class="fas fa-users nav-icon"></i>
                                                            <p>Supervisões</p>
                                                        </a>
                                                    </li>
                                                    <li class="nav-item">
                                                        <a href="/Usuarios" class="nav-link">
                                                            <i class="fas fa-user nav-icon"></i>
                                                            <p>Líderes</p>
                                                        </a>
                                                    </li>

                                                </ul>
                                            </li>
                                            <li class="nav-item">
                                                <a href="#" class="nav-link">
                                                    <i class="nav-icon fas fa-laptop-medical"></i>
                                                    <p>
                                                        Operações
                                                        <i class="right fas fa-angle-left"></i>
                                                    </p>
                                                </a>
                                                <ul class="nav nav-treeview">
                                                    <li class="nav-item">
                                                        <a href="/consultas" class="nav-link">
                                                            <i class="fas fa-notes-medical nav-icon"></i>
                                                            <p>-</p>
                                                        </a>
                                                    </li>
                                                </ul>
                                            </li>

                                        </ul>
                                    </nav>
                                    <!-- /.sidebar-menu -->
                                </div>
                                <!-- /.sidebar -->
                            </aside>

                            <!-- Content Wrapper. Contains page content -->
                            <div class="content-wrapper">
                                @RenderBody()
                            </div>
                            <!-- /.content-wrapper -->

                            <footer class="main-footer">
                                <div class="float-right d-none d-sm-block">
                                    <b>Versão</b> 1.0.0
                                </div>
                                <strong>Desenvolvido por <a href="#">Daniel Alves</a>. CCVideira</strong>
                            </footer>

                            <!-- Control Sidebar -->
                            <aside class="control-sidebar control-sidebar-dark">
                                <!-- Control sidebar content goes here -->
                            </aside>
                            <!-- /.control-sidebar -->
                        </div>
                        <!-- ./wrapper -->
                        <!-- jQuery -->
                        <script src="~/js/jquery.min.js"></script>
                        <!-- Bootstrap 4 -->
                        <script src="~/js/bootstrap.bundle.min.js"></script>
                        <!-- AdminLTE App -->
                        <script src="~/js/adminlte.min.js"></script>
                        <script src="~/js/jquery.mask.min.js"></script>

                        <script type="text/javascript">
                            $(function () {
                            $('[mask]').each(function (e) {
                            $(this).mask($(this).attr('mask'));
                            });

                            $.validator.methods.number = function (value, element) {
                            return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:\.\d{3})+)(?:,\d+)?$/.test(value);
                            }
                            });
                        </script>
                        @await RenderSectionAsync("Scripts", required: false)
                    </body>

                </html>