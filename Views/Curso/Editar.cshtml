@model EnsinoApp.ViewModels.Cursos.CursoViewModel
@{
    ViewData["Title"] = "Editar Curso";
}

<section class="content-header" style="padding-bottom:0">
    <div class="container-fluid">
        <a asp-action="Index" class="ea-btn-back"><i class="fas fa-arrow-left"></i> Voltar para Cursos</a>
        <div class="ea-page-title">
            <h1><i class="fas fa-graduation-cap" style="color:var(--primary);margin-right:8px"></i>Editar Curso</h1>
            <p>Preencha as informações para editar o curso selecionado</p>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <form asp-action="Editar" method="post">
            <div asp-validation-summary="All" class="text-danger" style="font-size:.8rem;margin-bottom:12px"></div>
            <input type="hidden" asp-for="Id" />

            <!-- Dados do Curso -->
            <div class="ea-form-card ea-fade ea-fade-1">
                <div class="ea-form-card-header">
                    <div class="ea-form-header-icon" style="background:var(--primary-light);color:var(--primary)">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                    <h3 class="ea-form-card-title">Dados do Curso</h3>
                </div>
                <div class="ea-form-card-body">
                    <div class="ea-field-group">
                        <label class="ea-field-label"><i class="fas fa-map-marker-alt"
                                                             style="margin-right:3px"></i>Campus</label>
                            <div class="ea-input-group">
                                <input asp-for="NomeCampus" class="ea-field-control" readonly
                                       placeholder="Selecione um campus" />
                                <input type="hidden" asp-for="IdCampus" />
                                <button type="button" class="ea-btn-buscar" data-toggle="modal" data-target="#ModalCampus">
                                    <i class="fas fa-search"></i> Buscar
                                </button>
                            </div>
                            <span asp-validation-for="IdCampus" class="ea-field-error"></span>
                        </div>
                        <div class="ea-field-group">
                            <label asp-for="Nome" class="ea-field-label"></label>
                            <input asp-for="Nome" class="ea-field-control" placeholder="Nome do curso" />
                            <span asp-validation-for="Nome" class="ea-field-error"></span>
                        </div>
                        <div class="ea-field-group">
                            <label asp-for="Descricao" class="ea-field-label"></label>
                            <textarea asp-for="Descricao" class="ea-field-control"
                                      placeholder="Descreva o curso brevemente..."></textarea>
                            <span asp-validation-for="Descricao" class="ea-field-error"></span>
                        </div>
                    </div>
                </div>

                <!-- Configurações -->
                <div class="ea-form-card ea-fade ea-fade-2">
                    <div class="ea-form-card-header">
                        <div class="ea-form-header-icon" style="background:var(--success-light);color:var(--success)">
                            <i class="fas fa-cog"></i>
                        </div>
                        <h3 class="ea-form-card-title">Configurações</h3>
                    </div>
                    <div class="ea-form-card-body">
                        <div class="ea-toggle-row" style="margin-bottom:20px">
                            <label class="ea-toggle">
                                <input asp-for="Ativo" type="checkbox" />
                                <span class="ea-toggle-slider"></span>
                            </label>
                            <div>
                                <div class="ea-toggle-label">Curso Ativo</div>
                                <div class="ea-toggle-desc">Curso ficará disponível para novas matrículas</div>
                            </div>
                        </div>

                        <!-- Layout de Certificado -->
                        <div class="ea-field-group">
                            <label asp-for="IdLayoutCertificado" class="ea-field-label">
                                <i class="fas fa-certificate" style="margin-right:3px;color:var(--primary)"></i>
                                Layout de Certificado
                            </label>

                            @if (Model.IdLayoutCertificado.HasValue &&
                            !string.IsNullOrWhiteSpace(Model.NomeLayoutCertificado))
                            {
                                <div
                                    style="display:flex;align-items:center;gap:8px;background:var(--primary-light);border:1px solid var(--primary-mid);border-radius:var(--radius);padding:8px 14px;margin-bottom:10px">
                                    <i class="fas fa-certificate" style="color:var(--primary)"></i>
                                    <span style="font-size:.82rem;font-weight:700;color:var(--primary);flex:1">
                                        Layout atual: @Model.NomeLayoutCertificado
                                    </span>
                                    <a asp-controller="LayoutCertificado" asp-action="Preview"
                                       asp-route-id="@Model.IdLayoutCertificado" target="_blank"
                                       style="font-size:.72rem;font-weight:700;color:var(--primary);text-decoration:none">
                                        <i class="fas fa-eye"></i> Visualizar
                                    </a>
                                </div>
                            }

                            <div style="display:flex;gap:8px;align-items:center">
                                <select asp-for="IdLayoutCertificado" asp-items="Model.LayoutsDisponiveis"
                                        class="ea-field-control" id="selectLayout" style="flex:1">
                                    <option value="">— Usar layout padrão do sistema —</option>
                                </select>
                                <a id="btnPreviewLayout"
                                   href="@(Model.IdLayoutCertificado.HasValue ? $"/LayoutCertificado/Preview/{Model.IdLayoutCertificado}" : "#")"
                                   target="_blank" class="ea-btn-buscar" title="Pré-visualizar layout selecionado"
                                   style="@(Model.IdLayoutCertificado.HasValue ? "" : "display:none")">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-controller="LayoutCertificado" asp-action="Index" target="_blank"
                                   class="ea-btn-buscar" title="Gerenciar layouts de certificado">
                                    <i class="fas fa-external-link-alt"></i>
                                </a>
                            </div>
                            <span asp-validation-for="IdLayoutCertificado" class="ea-field-error"></span>
                            <p style="font-size:.72rem;color:var(--gray-400);margin-top:5px">
                                <i class="fas fa-info-circle" style="margin-right:3px"></i>
                                Quando não selecionado, será utilizado o template padrão do sistema ao emitir certificados.
                                <a asp-controller="LayoutCertificado" asp-action="Adicionar" target="_blank"
                                   style="color:var(--primary);font-weight:700">Criar novo layout</a>
                            </p>
                        </div>
                    </div>
                    <div class="ea-form-footer">
                        <a asp-action="Index" class="ea-btn-action cancel"><i class="fas fa-times"></i> Cancelar</a>
                        <button type="submit" class="ea-btn-action save"><i class="fas fa-save"></i> Salvar Edição</button>
                    </div>
                </div>

            </form>
        </div>
    </section>

    <!-- Modal Campus -->
    <div class="modal fade ea-modal" id="ModalCampus" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-building" style="color:var(--primary);margin-right:6px"></i>Buscar Campus
                    </h5>
                    <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                </div>
                <div class="modal-body">
                    <input type="text" id="TxtFiltroCampus" class="ea-modal-search"
                           placeholder="Digite o nome do campus..." />
                    <div style="overflow-y:auto;max-height:300px">
                        <table class="ea-modal-table" id="TbCampus">
                            <tbody></tbody>
                        </table>
                        <div id="DivMensagemCampus" class="ea-modal-empty d-none">Nenhum campus encontrado.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script>
            function buscarCampus() {
                var f = $("#TxtFiltroCampus").val().trim();
                if (!f.length) return;
                $.getJSON("/Campus/Buscar?filtro=" + f, function (r) {
                    $("#DivMensagemCampus").addClass("d-none");
                    if (r.length) {
                        $("#TbCampus tbody").html(
                            r.map(p => "<tr data-id='" + p.id + "'><td>" + p.nome + "</td></tr>").join("")
                        );
                        $("#TbCampus tbody tr").click(function () {
                            $("#IdCampus").val($(this).data("id"));
                            $("#NomeCampus").val($(this).find("td:first").text());
                            $("#ModalCampus").modal("hide");
                        });
                    } else {
                        $("#TbCampus tbody").html("");
                        $("#DivMensagemCampus").removeClass("d-none");
                    }
                });
            }
            $("#TxtFiltroCampus").on("keyup", buscarCampus);

            // Atualiza o botão de preview ao trocar o layout
            $("#selectLayout").on("change", function () {
                var id = $(this).val();
                var btn = $("#btnPreviewLayout");
                if (id) {
                    btn.attr("href", "/LayoutCertificado/Preview/" + id).show();
                } else {
                    btn.hide();
                }
            });
        </script>
    }
