@model IEnumerable<EnsinoApp.ViewModels.Cursos.CursoViewModel>
@{
    ViewData["Title"] = "Gerenciar Cursos";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="ea-page-title">
            <h1><i class="fas fa-graduation-cap" style="color:var(--primary);margin-right:8px"></i>Gerenciar Cursos</h1>
            <p>Visualize, edite e organize os cursos disponíveis</p>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        <div class="ea-toolbar">
            <form asp-action="Index" style="flex:1 1 220px">
                <div class="ea-search-wrap">
                    <i class="fas fa-search ea-search-icon"></i>
                    <input type="text" placeholder="Buscar curso..." name="filtro" value="@ViewBag.Filtro" />
                    <button type="submit" class="ea-btn-search"><i class="fas fa-search"></i></button>
                </div>
            </form>
            <a href="/curso/adicionar" class="ea-btn-new"><i class="fas fa-plus"></i> Novo Curso</a>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="ea-grid">
                @foreach (var c in Model)
                {
                    <div class="ea-card ea-fade ea-fade-1">
                        <div class="ea-card-accent blue"></div>
                        <div class="ea-card-body">
                            <div
                                style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:8px">
                                <h3
                                    style="font-family:var(--font);font-size:.98rem;font-weight:800;color:var(--gray-800);margin:0">
                                    @c.Nome</h3>
                                    <span class="ea-badge @(c.Ativo ? "ativo" : "inativo")">@(c.Ativo ? "Ativo" : "Inativo")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(c.Descricao))
                                {
                                    <p
                                        style="font-size:.8rem;color:var(--gray-500);margin:0 0 10px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                                        @c.Descricao</p>
                                    }
                    else
                                    {
                                        <p style="font-size:.8rem;color:var(--gray-300);font-style:italic;margin:0 0 10px">Sem descrição</p>
                                    }
                                    <span class="ea-meta-pill"><i class="fas fa-map-marker-alt"></i>@c.NomeCampus</span>
                                </div>
                                <div class="ea-card-footer">
                                    <a asp-action="Dashboard" asp-route-id="@c.Id" class="ea-action-btn info" title="Visão Geral"><i
                                        class="fas fa-chart-pie"></i></a>
                                        <a asp-controller="Licao" asp-action="Index" asp-route-cursoId="@c.Id" class="ea-action-btn success"
                                           title="Gerenciar Lições"><i class="fas fa-list"></i></a>
                                        <a asp-action="Editar" asp-route-id="@c.Id" class="ea-action-btn primary" title="Editar"><i
                                            class="fas fa-edit"></i></a>
                                            <a asp-controller="Curso" asp-action="Deletar" asp-route-id="@c.Id"
                                               onclick="return confirm('Excluir o curso @c.Nome?')" class="ea-action-btn danger"
                                               title="Excluir"><i class="fas fa-trash"></i></a>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
        else
                        {
                            <div class="ea-empty">
                                <i class="fas fa-book-open"></i>
                                <h3>Nenhum curso encontrado</h3>
                                <p>Tente outro termo ou crie um novo curso.</p>
                            </div>
                        }

                        @if (ViewBag.TotalPaginas > 1)
                        {
                            <div class="ea-pagination">
                                @if (ViewBag.NumeroPagina > 1)
                                {
                                    <a class="ea-page-btn"
                                           href="@Url.Action("Index","Curso",new{Filtro=ViewBag.Filtro,Pagina=ViewBag.NumeroPagina-1})"><i
                                        class="fas fa-chevron-left"></i></a>
                                    }
                                    <span class="ea-page-info">Página @ViewBag.NumeroPagina de @ViewBag.TotalPaginas</span>
                                    @if (ViewBag.NumeroPagina < ViewBag.TotalPaginas)
                                    {
                                        <a class="ea-page-btn"
                                               href="@Url.Action("Index","Curso",new{Filtro=ViewBag.Filtro,Pagina=ViewBag.NumeroPagina+1})"><i
                                            class="fas fa-chevron-right"></i></a>
                                        }
                                    </div>
                                }

                            </div>
                        </section>