@model EnsinoApp.ViewModels.Cursos.CursoViewModel;
@{
    ViewData["Title"] = "Cadastrar Novo Curso";
}
<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Cadastrar Curso</h1>
            </div>
        </div>
    </div>
</section>

<section class=content>
    <div class=row>
        <div class=col-12>
            <div class="card shadow">
                <div class="card-body">
                    <form asp-action="Adicionar" method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <div class="mb-3">
                            <label asp-for="IdCampus" class="form-label">Campus</label>
                            <div class="input-group">
                                <input asp-for="NomeCampus" class="form-control" readonly
                                       placeholder="Selecione um Campus" />
                                <input type="hidden" asp-for="IdCampus" />
                                <button type="button" id="BtnBuscarCampus" class="btn btn-primary" data-toggle="modal"
                                        data-target="#ModalCampus">Buscar</button>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label"></label>
                            <input asp-for="Nome" class="form-control" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descricao" class="form-label"></label>
                            <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Descricao" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="Ativo" class="form-check-input" type="checkbox" />
                            <label asp-for="Ativo" class="form-check-label">Ativo</label>
                        </div>
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Voltar
                            </a>
                            <button type="submit" class="btn btn-primary">Salvar</button>
                        </div>


                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ================= MODAL CAMPUS ================= -->
<div class="modal fade" id="ModalCampus" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Buscar Campus</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Fechar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="text" id="TxtFiltroCampus" class="form-control mb-2"
                       placeholder="Digite o nome do campus" />
                <table class="table table-hover" id="TbCampus">
                    <tbody></tbody>
                </table>
                <div id="DivMensagemCampus" class="d-none">Nenhum campus encontrado.</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script>
                                                                   function buscarCampus() {
    var filtro = $("#TxtFiltroCampus").val().trim();
    if(filtro.length === 0) return;

    $.getJSON("/Campus/Buscar?filtro=" + filtro, function(resultado){
        if(resultado.length > 0) {
            var linhas = resultado.map(p => "<tr style='cursor:pointer' data-id='" + p.id + "'><td>" + p.nome + "</td></tr>").join("");
            $("#TbCampus tbody").html(linhas);

            $("#TbCampus tbody tr").click(function(){
                var id = $(this).attr("data-id");
                var nome = $(this).children()[0].innerText;
                $("#IdCampus").val(id);
                $("#NomeCampus").val(nome);
                $("#ModalCampus").modal('hide');
            });
        } else {
            $("#TbCampus tbody").html("");
            $("#DivMensagemCampus").removeClass("d-none");
        }
    });
}

$("#TxtFiltroCampus").on("keyup", function(){ buscarCampus(); });
    </script>
}