@using EnsinoApp.Models.Enums
@model EnsinoApp.ViewModels.Cursos.CursoDashboardViewModel
@{
    ViewData["Title"] = "Dashboard do Curso";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<section class="content-header mb-3">
    <div class="container-fluid">
        <h1>@Model.Nome</h1>
        <p>@Model.Descricao</p>
        <p><strong>Campus:</strong> @Model.NomeCampus</p>
    </div>
</section>

<!-- Resumo geral -->
<div class="container-fluid mb-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card text-white bg-primary shadow">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-building"></i> Total de Turmas</h5>
                    <p class="card-text display-6">@Model.TotalTurmas</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success shadow">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-people"></i> Total de Casais</h5>
                    <p class="card-text display-6">@Model.TotalCasais</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-warning shadow">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-person-check"></i> Casais Ativos</h5>
                    <p class="card-text display-6">@Model.CasaisAtivos</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Turmas -->
<div class="container-fluid">
    <div class="row">
        @foreach (var turma in Model.Turmas)
        {
            var cardColor = turma.Status == StatusTurma.Acomecar ? "bg-warning" :
                            turma.Status == StatusTurma.EmAndamento ? "bg-success" : "bg-secondary";

            <div class="col-md-6 mb-4">
                <div class="card shadow @cardColor text-white">
                    <div class="card-header">
                        <h5>@turma.NomeLider</h5>
                        <small>@turma.DataInicio.ToString("dd/MM/yyyy") - @turma.DataFim.ToString("dd/MM/yyyy")</small>
                        <span class="badge float-end">@turma.Status</span>
                    </div>
                    <div class="card-body bg-white text-dark">
                        <h6>Casais Matriculados:</h6>
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Marido</th>
                                    <th>Esposa</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var casal in turma.Casais)
                                {
                                    var badgeColor = casal.Status == StatusPresenca.Presente ? "bg-success" :
                                                     casal.Status == StatusPresenca.Ausente ? "bg-danger" : "bg-secondary";

                                    <tr>
                                        <td>@casal.NomeMarido</td>
                                        <td>@casal.NomeEsposa</td>
                                        <td><span class="badge @badgeColor">@casal.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <!-- Gráfico de presença -->
                        <canvas id="chartTurma@turma.Id" width="100%" height="50"></canvas>
                        <script>
                            const ctx@turma.Id = document.getElementById('chartTurma@turma.Id').getContext('2d');
                            new Chart(ctx@turma.Id, {
                            type: 'pie',
                            data: {
                            labels: ['Presente', 'Ausente', 'Desistente'],
                            datasets: [{
                            data: [
                            @turma.Casais.Count(c => c.Status == EnsinoApp.Models.Enums.StatusPresenca.Presente),
                            @turma.Casais.Count(c => c.Status == EnsinoApp.Models.Enums.StatusPresenca.Ausente),
                            @turma.Casais.Count(c => c.Status == EnsinoApp.Models.Enums.StatusPresenca.Desistente)
                            ],
                            backgroundColor: ['#198754', '#dc3545', '#6c757d']
                            }]
                            },
                            options: {
                            responsive: true,
                            plugins: {
                            legend: { position: 'bottom' }
                            }
                            }
                            });
                        </script>
                    </div>
                </div>
            </div>
        }
    </div>
</div>