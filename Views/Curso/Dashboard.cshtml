@using EnsinoApp.Models.Enums
@model EnsinoApp.ViewModels.Cursos.CursoDashboardViewModel
@{
    ViewData["Title"] = "Dashboard do Curso";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<section class="content-header mb-3">
    <a asp-action="Index" class="btn  btn-xs">
        <i class="fas fa-arrow-left"></i> Voltar
    </a>
    <div class="container-fluid">
        <h1>@Model.Nome</h1>
        <p>@Model.Descricao</p>
        <p><strong>Campus:</strong> @Model.NomeCampus</p>
    </div>
</section>

<!-- Resumo geral -->
<div class="container-fluid mb-4">
    <div class="row">
        <div class="col-md-4">
            <div class="info-box shadow">
                <span class="info-box-icon bg-primary"><i class="bi bi-building"></i></span>

                <div class="info-box-content">
                    <span class="info-box-text">Total de Turmas</span>
                    <span class="info-box-number">@Model.TotalTurmas</span>
                </div>
                <!-- /.info-box-content -->
            </div>
            @* <div class="card text-white bg-primary shadow">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-building"></i> Total de Turmas</h5>
                    <p class="card-text display-6">@Model.TotalTurmas</p>
                </div>
            </div> *@
        </div>
        <div class="col-md-4">
            <div class="info-box shadow">
                <span class="info-box-icon bg-success"><i class="bi bi-people"></i></span>

                <div class="info-box-content">
                    <span class="info-box-text">Total de Casais</span>
                    <span class="info-box-number">@Model.TotalCasais</span>
                </div>
                <!-- /.info-box-content -->
            </div>
            @* <div class="card text-white bg-success shadow">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-people"></i> Total de Casais</h5>
                    <p class="card-text display-6">@Model.TotalCasais</p>
                </div>
            </div> *@
        </div>
        <div class="col-md-4">
            <div class="info-box shadow">
                <span class="info-box-icon bg-warning"><i class="bi bi-person-check"></i></span>

                <div class="info-box-content">
                    <span class="info-box-text">Casais Ativos</span>
                    <span class="info-box-number">@Model.CasaisAtivos</span>
                </div>
                <!-- /.info-box-content -->
            </div>
            @*   <div class="card text-white bg-warning shadow">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-person-check"></i> Casais Ativos</h5>
                    <p class="card-text display-6">@Model.CasaisAtivos</p>
                </div>
            </div> *@
        </div>
    </div>
</div>

<!-- Turmas -->
<div class="container-fluid">
    <div class="row">
        @foreach (var turma in Model.Turmas)
        {
            var cardColor = turma.Status == StatusTurma.Acomecar ? "bg-warning" :
                            turma.Status == StatusTurma.EmAndamento ? "bg-primary" : "bg-success";

            <div class="col-md-6 mb-4">
                <div class="card shadow @cardColor text-white">
                    <div class="card-header">
                        <h5>Turma #@turma.Id - Líderes: @turma.NomeLider</h5>
                        <small>@turma.DataInicio.ToString("dd/MM/yyyy") - @turma.DataFim.ToString("dd/MM/yyyy")</small>
                        <span class="badge float-end">@turma.Status</span>
                    </div>
                    <div class="card-body bg-white text-dark">
                        <h6>Casais Matriculados:</h6>
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Marido</th>
                                    <th>Esposa</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var casal in turma.Casais)
                                {
                                    var badgeColor = casal.StatusCasal == StatusCasal.Ativo ? "bg-success" :
                                                     casal.StatusCasal == StatusCasal.Desistente ? "bg-danger" : "bg-secondary";

                                    <tr>
                                        <td>@casal.NomeMarido</td>
                                        <td>@casal.NomeEsposa</td>
                                        <td><span class="badge @badgeColor">@casal.StatusCasal</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <!-- Gráfico de presença -->
                        @*  <div class="row " style="margin:20px 0;height: 200px; width: 200px;">
                            <canvas id="@turma.Id"></canvas>
                        </div>
                        <script>

                            document.addEventListener("DOMContentLoaded", function () {
                            console.log('Entrou no script');
                            const ctx = document.getElementById('@turma.Id').getContext('2d');
                            new Chart(ctx, {
                            type: 'pie',
                            data: {
                            labels: ['Presente', 'Ausente', 'Desistente'],
                            datasets: [{
                            data: [
                            @turma.Casais.Count(c => c.StatusPresenca == EnsinoApp.Models.Enums.StatusPresenca.Presente),
                            @turma.Casais.Count(c => c.StatusPresenca == EnsinoApp.Models.Enums.StatusPresenca.Ausente),
                            @turma.Casais.Count(c => c.StatusPresenca == EnsinoApp.Models.Enums.StatusPresenca.Desistente)
                            ],
                            backgroundColor: ['#198754', '#dc3545', '#6c757d']
                            }]
                            },
                            options: {
                            responsive: true,
                            plugins: {
                            legend: {
                            position: 'bottom'
                            }
                            }
                            }
                            });
                            });
                        </script> *@
                    </div>
                </div>
            </div>
        }
    </div>
</div>