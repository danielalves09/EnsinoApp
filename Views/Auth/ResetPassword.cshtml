@{
    Layout = "";
    ViewData["Title"] = "Nova senha";
    var email = ViewBag.Email as string ?? "";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnsinoApp</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: 'Nunito', sans-serif;
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg,#1e3a8a 0%,#1e40af 50%,#2563eb 100%);
            padding: 20px; margin: 0;
        }
        .card {
            width: 100%; max-width: 440px;
            background: #fff; border-radius: 18px;
            box-shadow: 0 20px 60px rgba(0,0,0,.15);
            overflow: hidden;
        }
        .card-header {
            background: linear-gradient(135deg,#15803d,#16a34a);
            padding: 32px 28px 24px; text-align: center;
        }
        .card-header .icon-wrap {
            width: 56px; height: 56px;
            background: rgba(255,255,255,.2); border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 14px; font-size: 1.4rem; color: #fff;
        }
        .card-header h1 { font-size: 1.25rem; font-weight: 800; color: #fff; margin: 0 0 6px; }
        .card-header p  { font-size: .8rem; color: rgba(255,255,255,.75); margin: 0; }
        .card-body { padding: 28px; }

        .field { margin-bottom: 18px; }
        .label {
            display: block; font-size: .72rem; font-weight: 700;
            color: #64748b; text-transform: uppercase;
            letter-spacing: .4px; margin-bottom: 6px;
        }
        .input-wrap { position: relative; }
        .input {
            width: 100%;
            border: 1.5px solid #e2e8f0; border-radius: 10px;
            padding: 11px 42px 11px 42px;
            font-size: .88rem; color: #334155;
            background: #f8fafc;
            font-family: 'Nunito', sans-serif;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
        }
        .input:focus { border-color: #16a34a; background: #fff; box-shadow: 0 0 0 3px rgba(22,163,74,.12); }
        .input.invalid { border-color: #dc2626; }
        .input-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: .85rem; }
        .toggle-pw {
            position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
            color: #94a3b8; cursor: pointer; font-size: .85rem;
            background: none; border: none; padding: 0; outline: none;
        }
        .toggle-pw:hover { color: #475569; }

        /* Medidor de força */
        .strength-track {
            height: 5px; background: #e2e8f0; border-radius: 10px;
            margin-top: 8px; overflow: hidden;
        }
        .strength-fill {
            height: 100%; border-radius: 10px;
            transition: width .3s, background .3s;
        }
        .strength-label { font-size: .7rem; font-weight: 700; margin-top: 4px; }

        .match-msg { font-size: .75rem; font-weight: 700; margin-top: 4px; }

        .btn {
            width: 100%; padding: 12px;
            background: linear-gradient(135deg,#15803d,#16a34a);
            color: #fff; border: none; border-radius: 10px;
            font-size: .9rem; font-weight: 700;
            font-family: 'Nunito', sans-serif;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            transition: opacity .2s, transform .15s;
            margin-top: 4px;
        }
        .btn:hover:not(:disabled) { opacity: .92; transform: translateY(-1px); }
        .btn:disabled { opacity: .5; cursor: not-allowed; }

        .error-box {
            background: #fef2f2; border: 1px solid #fca5a5;
            border-radius: 10px; padding: 10px 14px;
            font-size: .8rem; color: #dc2626; margin-bottom: 16px;
        }
        .rules {
            background: #f0fdf4; border: 1px solid #bbf7d0;
            border-radius: 10px; padding: 12px 14px;
            font-size: .78rem; color: #15803d;
            line-height: 1.8; margin-bottom: 20px;
        }
    </style>
</head>
<body>

    <div class="card">
        <div class="card-header">
            <div class="icon-wrap"><i class="fas fa-key"></i></div>
            <h1>Criar nova senha</h1>
            <p>Defina uma senha segura para sua conta</p>
        </div>

        <div class="card-body">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-box">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <div class="rules">
                <strong>Requisitos:</strong><br/>
                ✔ Mínimo 6 caracteres &nbsp;&nbsp;
                ✔ Letra maiúscula &nbsp;&nbsp;
                ✔ Letra minúscula &nbsp;&nbsp;
                ✔ Número
            </div>

            <form asp-action="ResetPassword" method="post" id="resetForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@email" />

                <div class="field">
                    <label class="label">Nova senha</label>
                    <div class="input-wrap">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="novaSenha" id="novaSenha"
                               class="input" placeholder="••••••••"
                               autocomplete="new-password" required />
                        <button type="button" class="toggle-pw" data-target="novaSenha">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <div class="strength-track"><div class="strength-fill" id="strengthFill" style="width:0"></div></div>
                    <div class="strength-label" id="strengthLabel" style="color:#94a3b8">Digite sua senha</div>
                </div>

                <div class="field">
                    <label class="label">Confirmar nova senha</label>
                    <div class="input-wrap">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="confirmarSenha" id="confirmarSenha"
                               class="input" placeholder="••••••••"
                               autocomplete="new-password" required />
                        <button type="button" class="toggle-pw" data-target="confirmarSenha">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <div class="match-msg" id="matchMsg"></div>
                </div>

                <button type="submit" class="btn" id="submitBtn" disabled>
                    <i class="fas fa-check"></i> Salvar nova senha
                </button>
            </form>

        </div>
    </div>

    <script>
        /* ── Toggle visibilidade ── */
        document.querySelectorAll('.toggle-pw').forEach(btn => {
            btn.addEventListener('click', () => {
                const input = document.getElementById(btn.dataset.target);
                const icon  = btn.querySelector('i');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.replace('fa-eye', 'fa-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.replace('fa-eye-slash', 'fa-eye');
                }
            });
        });

        /* ── Medidor de força ── */
        const novaSenha      = document.getElementById('novaSenha');
        const confirmarSenha = document.getElementById('confirmarSenha');
        const fill           = document.getElementById('strengthFill');
        const label          = document.getElementById('strengthLabel');
        const matchMsg       = document.getElementById('matchMsg');
        const submitBtn      = document.getElementById('submitBtn');

        const levels = [
            { pct: 0,   color: '#e2e8f0', text: 'Digite sua senha',    textColor: '#94a3b8' },
            { pct: 25,  color: '#dc2626', text: 'Muito fraca',         textColor: '#dc2626' },
            { pct: 50,  color: '#d97706', text: 'Fraca',               textColor: '#d97706' },
            { pct: 75,  color: '#2563eb', text: 'Boa',                 textColor: '#2563eb' },
            { pct: 100, color: '#16a34a', text: 'Forte',               textColor: '#16a34a' },
        ];

        function calcStrength(pw) {
            if (!pw) return 0;
            let score = 0;
            if (pw.length >= 6)  score++;
            if (pw.length >= 10) score++;
            if (/[A-Z]/.test(pw)) score++;
            if (/[0-9]/.test(pw)) score++;
            if (/[^A-Za-z0-9]/.test(pw)) score++;
            return Math.min(4, score);
        }

        function validate() {
            const pw    = novaSenha.value;
            const conf  = confirmarSenha.value;
            const score = calcStrength(pw);
            const l     = levels[score];

            fill.style.width      = l.pct + '%';
            fill.style.background = l.color;
            label.textContent     = l.text;
            label.style.color     = l.textColor;

            const minOk    = pw.length >= 6;
            const upperOk  = /[A-Z]/.test(pw);
            const lowerOk  = /[a-z]/.test(pw);
            const digitOk  = /[0-9]/.test(pw);
            const matchOk  = pw && pw === conf;

            if (conf) {
                matchMsg.textContent  = matchOk ? '✔ Senhas coincidem' : '✖ Senhas não coincidem';
                matchMsg.style.color  = matchOk ? '#16a34a' : '#dc2626';
                confirmarSenha.classList.toggle('invalid', !matchOk);
            } else {
                matchMsg.textContent = '';
                confirmarSenha.classList.remove('invalid');
            }

            submitBtn.disabled = !(minOk && upperOk && lowerOk && digitOk && matchOk);
        }

        novaSenha.addEventListener('input',      validate);
        confirmarSenha.addEventListener('input', validate);
    </script>

</body>
</html>
