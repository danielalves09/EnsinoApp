@model LoginViewModel
@{
    Layout = "";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EnsinoApp | CCVideira</title>

    <!-- Nunito -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
          rel="stylesheet" />
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <!-- Login CSS -->
    <link rel="stylesheet" href="~/css/login.css" />
</head>

<body>
    <div class="login-wrap">

        <!-- ── Painel esquerdo (imagem) ───────────────── -->
        <div class="login-panel-left">
            <div class="bg-image" style="background-image:url('@Url.Content("~/images/back.jpg")')"></div>
            <div class="overlay-content">
                <img src="~/images/logoVideira2.png" class="panel-logo" alt="Logo CCVideira" />
                <h2>Plataforma de Gestão<br />dos Cursos CCVideira</h2>
                <p>Gerencie turmas, matrículas e relatórios<br />em um só lugar.</p>
                <div class="login-courses">
                    <span class="login-course-pill"><i class="fas fa-heart" style="margin-right:4px"></i>Casados Para
                        Sempre</span>
                        <span class="login-course-pill"><i class="fas fa-ring" style="margin-right:4px"></i>One</span>
                        <span class="login-course-pill"><i class="fas fa-child" style="margin-right:4px"></i>Pais Para Toda
                            Vida</span>
                        </div>
                    </div>
                </div>

                <!-- ── Painel direito (formulário) ───────────── -->
                <div class="login-panel-right">

                    <img src="~/images/logo.png" class="login-logo" alt="Logo EnsinoApp" />
                    <p class="login-subtitle">Acesse o sistema com suas credenciais</p>

                    <form asp-action="Login" method="post" novalidate class="login-form">
                        <div asp-validation-summary="ModelOnly" class="l-error"
                             style="margin-bottom:14px;padding:10px 14px;background:#fef2f2;border:1px solid #fca5a5;border-radius:var(--radius)">
                        </div>

                        <!-- Email -->
                        <div class="l-field-group">
                            <div class="l-field-wrap">
                                <input asp-for="Email" class="l-field-control"                 placeholder="Seu email" />
                                <i class="fas fa-envelope l-field-icon"></i>
                            </div>
                            <span asp-validation-for="Email" class="l-error"></span>
                        </div>

                        <!-- Senha -->
                        <div class="l-field-group">
                            <div class="l-field-wrap">
                                <input asp-for="Password"                 type="password"               class="l-field-control"             placeholder="Sua senha" />
                                <i class="fas fa-lock l-field-icon"></i>
                            </div>
                            <span asp-validation-for="Password" class="l-error"></span>
                        </div>

                        <!-- Lembrar -->
                        <label class="l-remember">
                            <input asp-for="RememberMe" type="checkbox" />
                            Lembrar minha senha
                        </label>

                        <!-- Botão -->
                        <button type="submit" class="btn-login">
                            <i class="fas fa-sign-in-alt"></i> Entrar
                        </button>

                        <!-- Esqueceu -->
                        <a asp-action="ForgotPassword" class="l-forgot">
                            Esqueceu a senha? Clique aqui
                        </a>

                        <hr class="l-divider" />

                        <p class="l-footer">
                            © @DateTime.Now.Year <strong>EnsinoApp · Versão 1.0</strong>
                        </p>
                    </form>

                </div>
            </div>

            <script src="~/loginResources/jquery.min.js"></script>
            <partial name="_ValidationScriptsPartial" />
        </body>

    </html>