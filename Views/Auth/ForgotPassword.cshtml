@{
    Layout = "";
    ViewData["Title"] = "Esqueci minha senha";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnsinoApp</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/login.css" />
    <style>
        .recovery-card {
            width: 100%;
            max-width: 420px;
            margin: auto;
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 20px 60px rgba(0,0,0,.15);
            overflow: hidden;
        }
        .recovery-header {
            background: linear-gradient(135deg, #1e40af, #2563eb);
            padding: 32px 28px 24px;
            text-align: center;
        }
        .recovery-header .icon-wrap {
            width: 56px; height: 56px;
            background: rgba(255,255,255,.2);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 14px;
            font-size: 1.4rem; color: #fff;
        }
        .recovery-header h1 {
            font-family: 'Nunito', sans-serif;
            font-size: 1.25rem; font-weight: 800;
            color: #fff; margin: 0 0 6px;
        }
        .recovery-header p {
            font-size: .8rem; color: rgba(255,255,255,.7); margin: 0;
        }
        .recovery-body { padding: 28px; }
        .r-field { margin-bottom: 18px; }
        .r-label {
            display: block;
            font-size: .72rem; font-weight: 700; color: #64748b;
            text-transform: uppercase; letter-spacing: .4px;
            margin-bottom: 6px;
        }
        .r-input-wrap { position: relative; }
        .r-input {
            width: 100%; box-sizing: border-box;
            border: 1.5px solid #e2e8f0; border-radius: 10px;
            padding: 11px 14px 11px 42px;
            font-size: .88rem; color: #334155;
            background: #f8fafc;
            font-family: 'Nunito', sans-serif;
            transition: border-color .2s, box-shadow .2s;
            outline: none;
        }
        .r-input:focus { border-color: #2563eb; background: #fff; box-shadow: 0 0 0 3px rgba(37,99,235,.12); }
        .r-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: .85rem; }
        .r-error { font-size: .75rem; color: #dc2626; margin-top: 4px; display: block; }
        .r-btn {
            width: 100%; padding: 12px;
            background: linear-gradient(135deg, #1e40af, #2563eb);
            color: #fff; border: none; border-radius: 10px;
            font-size: .9rem; font-weight: 700;
            font-family: 'Nunito', sans-serif;
            cursor: pointer;
            transition: opacity .2s, transform .15s;
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .r-btn:hover { opacity: .92; transform: translateY(-1px); }
        .r-back {
            display: flex; align-items: center; gap: 6px;
            font-size: .8rem; font-weight: 700; color: #64748b;
            text-decoration: none; margin-top: 16px;
            justify-content: center;
            transition: color .18s;
        }
        .r-back:hover { color: #2563eb; }
        .r-info {
            background: #eff6ff; border: 1px solid #bfdbfe;
            border-radius: 10px; padding: 12px 14px;
            font-size: .8rem; color: #1e40af; line-height: 1.6;
            margin-bottom: 20px;
            display: flex; gap: 8px; align-items: flex-start;
        }
        .validation-error {
            background: #fef2f2; border: 1px solid #fca5a5;
            border-radius: 10px; padding: 10px 14px;
            font-size: .8rem; color: #dc2626; margin-bottom: 16px;
        }
    </style>
</head>
<body style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#e2e8f0;padding:20px">

    <div class="recovery-card">

        <div class="recovery-header">
            <div class="icon-wrap"><i class="fas fa-lock"></i></div>
            <h1>Esqueci minha senha</h1>
            <p>Informe seu e-mail para receber o código de recuperação</p>
        </div>

        <div class="recovery-body">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-error">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <div class="r-info">
                <i class="fas fa-info-circle" style="margin-top:2px;flex-shrink:0"></i>
                <span>Enviaremos um código de 6 dígitos para o e-mail cadastrado. O código é válido por <strong>15 minutos</strong>.</span>
            </div>

            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()

                <div class="r-field">
                    <label class="r-label">E-mail</label>
                    <div class="r-input-wrap">
                        <i class="fas fa-envelope r-icon"></i>
                        <input type="email" name="email" class="r-input"
                               placeholder="seu@email.com" autocomplete="email" required />
                    </div>
                </div>

                <button type="submit" class="r-btn">
                    <i class="fas fa-paper-plane"></i> Enviar código
                </button>
            </form>

            <a asp-action="Login" class="r-back">
                <i class="fas fa-arrow-left"></i> Voltar para o login
            </a>

        </div>
    </div>

</body>
</html>
