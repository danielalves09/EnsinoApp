@{
    Layout = "";
    ViewData["Title"] = "Verificar código";
    var email = ViewBag.Email as string ?? "";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnsinoApp</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: 'Nunito', sans-serif;
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg,#1e3a8a 0%,#1e40af 50%,#2563eb 100%);
            padding: 20px; margin: 0;
        }
        .card {
            width: 100%; max-width: 440px;
            background: #fff; border-radius: 18px;
            box-shadow: 0 20px 60px rgba(0,0,0,.15);
            overflow: hidden;
        }
        .card-header {
            background: linear-gradient(135deg,#1e40af,#2563eb);
            padding: 32px 28px 24px; text-align: center;
        }
        .card-header .icon-wrap {
            width: 56px; height: 56px;
            background: rgba(255,255,255,.2); border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 14px; font-size: 1.4rem; color: #fff;
        }
        .card-header h1 { font-size: 1.25rem; font-weight: 800; color: #fff; margin: 0 0 6px; }
        .card-header p  { font-size: .8rem; color: rgba(255,255,255,.7); margin: 0; }
        .card-body { padding: 28px; }

        /* Campos de dígito */
        .digits-wrap {
            display: flex; gap: 10px; justify-content: center;
            margin: 20px 0;
        }
        .digit-input {
            width: 48px; height: 56px;
            border: 2px solid #e2e8f0; border-radius: 10px;
            text-align: center; font-size: 1.4rem; font-weight: 800;
            color: #1e293b; background: #f8fafc;
            font-family: 'Nunito', sans-serif;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
        }
        .digit-input:focus { border-color: #2563eb; background: #fff; box-shadow: 0 0 0 3px rgba(37,99,235,.12); }
        .digit-input.filled { border-color: #2563eb; background: #eff6ff; }

        .email-badge {
            background: #f1f5f9; border: 1px solid #e2e8f0;
            border-radius: 8px; padding: 8px 14px;
            font-size: .8rem; color: #64748b;
            display: flex; align-items: center; gap: 7px;
            margin-bottom: 18px; word-break: break-all;
        }
        .btn {
            width: 100%; padding: 12px;
            background: linear-gradient(135deg,#1e40af,#2563eb);
            color: #fff; border: none; border-radius: 10px;
            font-size: .9rem; font-weight: 700;
            font-family: 'Nunito', sans-serif;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            transition: opacity .2s, transform .15s;
        }
        .btn:hover { opacity: .92; transform: translateY(-1px); }
        .link-row {
            display: flex; justify-content: space-between; align-items: center;
            margin-top: 16px;
        }
        .link {
            font-size: .8rem; font-weight: 700; color: #64748b;
            text-decoration: none; display: flex; align-items: center; gap: 5px;
            transition: color .18s;
        }
        .link:hover { color: #2563eb; }
        .link.primary { color: #2563eb; }
        .error-box {
            background: #fef2f2; border: 1px solid #fca5a5;
            border-radius: 10px; padding: 10px 14px;
            font-size: .8rem; color: #dc2626; margin-bottom: 16px;
        }
        .timer {
            text-align: center; font-size: .78rem;
            color: #94a3b8; margin-top: 8px;
        }
        .timer strong { color: #2563eb; }
    </style>
</head>
<body>

    <div class="card">
        <div class="card-header">
            <div class="icon-wrap"><i class="fas fa-shield-alt"></i></div>
            <h1>Verificar código</h1>
            <p>Digite os 6 dígitos enviados por e-mail</p>
        </div>

        <div class="card-body">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-box">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(email))
            {
                <div class="email-badge">
                    <i class="fas fa-envelope" style="color:#2563eb;flex-shrink:0"></i>
                    Código enviado para <strong>@email</strong>
                </div>
            }

            <form asp-action="VerifyCode" method="post" id="verifyForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@email" />
                <input type="hidden" name="codigo" id="codigoHidden" />

                <div class="digits-wrap" id="digitsWrap">
                    @for (int i = 0; i < 6; i++)
                    {
                        <input class="digit-input" type="text" maxlength="1"
                               inputmode="numeric" pattern="[0-9]"
                               data-index="@i" autocomplete="off" />
                    }
                </div>

                <div class="timer" id="timerEl">Código expira em <strong id="countdown">15:00</strong></div>

                <button type="submit" class="btn" style="margin-top:20px" id="submitBtn" disabled>
                    <i class="fas fa-check-circle"></i> Verificar código
                </button>
            </form>

            <div class="link-row">
                <a asp-action="Login" class="link">
                    <i class="fas fa-arrow-left"></i> Login
                </a>
                <a asp-action="ForgotPassword" class="link primary">
                    <i class="fas fa-redo"></i> Reenviar código
                </a>
            </div>

        </div>
    </div>

    <script>
        /* ── Navegação entre dígitos ── */
        const inputs  = Array.from(document.querySelectorAll('.digit-input'));
        const hidden  = document.getElementById('codigoHidden');
        const submitBtn = document.getElementById('submitBtn');

        function updateHidden() {
            const val = inputs.map(i => i.value).join('');
            hidden.value = val;
            submitBtn.disabled = val.length < 6;
        }

        inputs.forEach((inp, idx) => {
            inp.addEventListener('input', e => {
                // Aceita apenas dígitos
                inp.value = inp.value.replace(/\D/g, '').slice(-1);
                inp.classList.toggle('filled', inp.value !== '');
                if (inp.value && idx < 5) inputs[idx + 1].focus();
                updateHidden();
            });

            inp.addEventListener('keydown', e => {
                if (e.key === 'Backspace' && !inp.value && idx > 0) {
                    inputs[idx - 1].focus();
                    inputs[idx - 1].value = '';
                    inputs[idx - 1].classList.remove('filled');
                    updateHidden();
                }
            });

            // Colar código de 6 dígitos no primeiro campo
            inp.addEventListener('paste', e => {
                e.preventDefault();
                const pasted = (e.clipboardData || window.clipboardData)
                    .getData('text').replace(/\D/g, '').slice(0, 6);
                pasted.split('').forEach((ch, i) => {
                    if (inputs[i]) {
                        inputs[i].value = ch;
                        inputs[i].classList.add('filled');
                    }
                });
                if (inputs[pasted.length]) inputs[pasted.length].focus();
                else inputs[5].focus();
                updateHidden();
            });
        });

        inputs[0].focus();

        /* ── Countdown 15 min ── */
        let seconds = 15 * 60;
        const el = document.getElementById('countdown');
        const interval = setInterval(() => {
            seconds--;
            if (seconds <= 0) {
                clearInterval(interval);
                el.textContent = '00:00';
                el.style.color = '#dc2626';
                document.getElementById('submitBtn').disabled = true;
                return;
            }
            const m = String(Math.floor(seconds / 60)).padStart(2, '0');
            const s = String(seconds % 60).padStart(2, '0');
            el.textContent = `${m}:${s}`;
        }, 1000);
    </script>

</body>
</html>
