@model EnsinoApp.ViewModels.Turmas.TurmaDashboardViewModel;

<section class="content-header">
    <a asp-action="Index" class="btn  btn-xs">
        <i class="fas fa-arrow-left"></i> Voltar
    </a>
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>@Model.NomeCurso - Dashboard</h1>
                <small>Campus: @Model.NomeCampus | Líderes: @Model.NomeLider</small>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="row">
        <div class="col-md-4">
            <div class="card card-outline card-primary mb-3">
                <div class="card-header">Casais Matriculados</div>
                <div class="card-body">
                    <h3 class="card-title">@Model.CasaisMatriculados.Count</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-outline card-success mb-3">
                <div class="card-header">Progresso de Presença</div>
                <div class="card-body">
                    <canvas id="chartPresenca"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-outline card-warning mb-3">
                <div class="card-header">Status da Turma</div>
                <div class="card-body">
                    <p>@Model.Status</p>
                    <p>Data Início: @Model.DataInicio.ToShortDateString()</p>
                    <p>Data Fim: @Model.DataFim.ToShortDateString()</p>
                </div>
            </div>
        </div>
    </div>

    <h4>Casais Matriculados</h4>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Casal</th>
                <th>Última Lição</th>
                <th>Presença</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var casal in Model.CasaisMatriculados)
            {
                <tr>
                    <td>@casal.Nome</td>
                    <td>@casal.UltimaLicao?.ToShortDateString()</td>
                    <td>@casal.Presenca</td>
                </tr>
            }
        </tbody>
    </table>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('chartPresenca').getContext('2d');
        const data = {
        labels: @Html.Raw(Json.Serialize(Model.CasaisMatriculados.Select(c => c.Nome))),
        datasets: [{
        label: 'Presença',
        data: @Html.Raw(Json.Serialize(Model.CasaisMatriculados.Select(c => c.Presenca == 0 ? 1 : 0))),
        backgroundColor: 'rgba(54, 162, 235, 0.6)'
        }]
        };
        const chart = new Chart(ctx, {
        type: 'bar',
        data: data,
        options: { responsive: true, scales: { y: { beginAtZero: true } } }
        });
    </script>
}