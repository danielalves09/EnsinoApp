@model IEnumerable<EnsinoApp.Models.Entities.RelatorioSemanal>

@{
    ViewData["Title"] = "Relatórios";
}

<section class="content-header">
    <a asp-action="Dashboard" asp-route-id="@Model.First().Matricula.IdTurma" class="btn  btn-xs">
        <i class="fas fa-arrow-left"></i> Voltar
    </a>
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Historico de Relatórios</h1>
            </div>
        </div>
    </div>
</section>

<div class="container-fluid">
    <div class="card">
        <div class="card-header">📚 Relatório das Lições</div>
        <div class="card-body table-responsive p-0">
            <table class="table table-striped table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Data</th>
                        <th>Lição</th>
                        <th>Casal</th>
                        <th>Presença</th>
                        <th>Observações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>@r.DataRegistro.ToString("dd/MM/yyyy")</td>
                            <td>@r.Licao.Titulo</td>
                            <td>@r.Matricula.Casal.NomeConjuge1 e @r.Matricula.Casal.NomeConjuge2</td>
                            <td>@r.Presenca</td>
                            <td>@r.Observacoes</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <a asp-action="Turma" asp-route-id="@Model.First().Matricula.IdTurma" class="btn btn-secondary">
        Voltar para Turma
    </a>
</div>