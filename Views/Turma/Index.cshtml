@using EnsinoApp.Models.Enums
@model IEnumerable<EnsinoApp.ViewModels.Turmas.TurmaViewModel>
@{
    ViewData["Title"] = "Gerenciar Turmas";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Gerenciar Turmas</h1>
            </div>
            <div>

            </div>
        </div>
    </div>
</section>
<section class="content">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header col-12">
                    <div class="d-flex justify-content-between">
                        <form method="get">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    @Html.DropDownList(
                                    "IdCurso",
                                    (SelectList)ViewBag.Cursos,
                                    "Selecione um curso",
                                    new { @class = "form-control" }
                                    )

                                </div>
                                <div class="col-md-3">

                                    @Html.DropDownList(
                                    "IdCampus",
                                    (SelectList)ViewBag.Campuses,
                                    "Selecione um campus",
                                    new { @class = "form-control" }
                                    )

                                </div>
                                <div class="col-md-2">
                                    @Html.DropDownList(
                                    "Status",
                                    (SelectList)ViewBag.Status,
                                    "Status",
                                    new { @class = "form-control" })


                                </div>
                                <div class="col-md-3">
                                    <button type="submit" class="btn btn-primary">Filtrar</button>
                                    <a asp-action="Index" class="btn btn-secondary">Limpar</a>
                                </div>
                            </div>
                        </form>

                        <a href="/turma/adicionar" class="btn btn-outline-primary btn-sm">Nova Turma <i
                            class="fas fa-plus"></i></a>

                        </div>
                    </div>
                    <!-- /.card-header -->
                </div>
                <!-- /.card -->
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body table-responsive p-0">
                        <table class="table table-striped mt-3">
                            <thead>
                                <tr>
                                    <th>Curso</th>
                                    <th>Campus</th>
                                    <th>Líderes</th>
                                    <th>Data Início</th>
                                    <th>Data Fim</th>
                                    <th>Status</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model)
                                {
                                    <tr>
                                        <td>@t.NomeCurso</td>
                                        <td>@t.NomeCampus</td>
                                        <td>@t.NomeLider</td>
                                        <td>@t.DataInicio.ToShortDateString()</td>
                                        <td>@t.DataFim.ToShortDateString()</td>
                                        <td> @if (t.Status == StatusTurma.Acomecar)
                                            {
                                                <span class="badge bg-primary">A começar</span>
                                            }
                                    else if (t.Status == StatusTurma.EmAndamento)
                                            {
                                                <span class="badge bg-primary">Em Andamento</span>
                                            }
                                            else if (t.Status == StatusTurma.Concluida)
                                            {
                                                <span class="badge bg-success">Concluída</span>
                                            }
                                            else if (t.Status == StatusTurma.Cancelada)
                                            {
                                                <span class="badge bg-danger">Cancelada</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-action="Dashboard" asp-route-id="@t.Id" class="btn btn-sm btn-info"><i
                                                class="fa fa-search"></i></a>
                                                <a asp-action="Editar" asp-route-id="@t.Id" class="btn btn-sm btn-primary"><i
                                                    class="fa fa-edit"></i></a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </section>
            <!-- /.content -->