@model IEnumerable<EnsinoApp.ViewModels.Licao.LicaoViewModel>
@{
    ViewData["Title"] = "Lições do Curso";
    var cursoNome = ViewBag.CursoNome as string;
    var cursoId = ViewBag.CursoId;
}

<section class="content-header" style="padding-bottom:0">
    <div class="container-fluid">
        <a asp-controller="Curso" asp-action="Index" class="ea-btn-back">
            <i class="fas fa-arrow-left"></i> Voltar para Cursos
        </a>
        <div class="ea-page-title">
            <h1>
                <i class="fas fa-book-open" style="color:var(--primary);margin-right:8px"></i>
                Lições — @cursoNome
            </h1>
            <p>Gerencie o conteúdo programático deste curso</p>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        <div class="ea-toolbar">
            <div style="flex:1"></div>
            <a asp-action="Adicionar" asp-route-cursoId="@cursoId" class="ea-btn-new">
                <i class="fas fa-plus"></i> Nova Lição
            </a>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="ea-table-card ea-fade">
                <div class="ea-table-card-header">
                    <div class="ea-table-header-icon" style="background:var(--primary-light);color:var(--primary)">
                        <i class="fas fa-book-open"></i>
                    </div>
                    <h3 class="ea-table-card-title">Lições Cadastradas</h3>
                    <span class="ea-count-badge">@Model.Count() lições</span>
                </div>

                <div style="overflow-x:auto">
                    <table class="ea-table">
                        <thead>
                            <tr>
                                <th style="width:60px">Nº</th>
                                <th>Título</th>
                                <th>Descrição</th>
                                <th style="width:120px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var licao in Model.OrderBy(l => l.Numero))
                            {
                                <tr>
                                    <td>
                                        <div
                                            style="width:32px;height:32px;border-radius:var(--radius-sm);background:var(--primary-light);color:var(--primary);display:flex;align-items:center;justify-content:center;font-size:.82rem;font-weight:800;font-family:var(--font)">
                                            @licao.Numero
                                        </div>
                                    </td>
                                    <td style="font-weight:700;color:var(--gray-800)">
                                        @licao.Titulo
                                    </td>
                                    <td style="font-size:.8rem;color:var(--gray-500);max-width:360px">
                                        @if (!string.IsNullOrWhiteSpace(licao.Descricao))
                                        {
                                            <span
                                                style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                                                @licao.Descricao
                                            </span>
                                        }
                                        else
                                        {
                                            <span style="color:var(--gray-300);font-style:italic">Sem descrição</span>
                                        }
                                    </td>
                                    <td>
                                        <div style="display:flex;gap:6px">
                                            <a asp-action="Editar" asp-route-id="@licao.Id" class="ea-action-btn primary"
                                                   title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Deletar" asp-route-id="@licao.Id" class="ea-action-btn danger"
                                                   title="Excluir">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="ea-empty">
                <i class="fas fa-book-open"></i>
                <h3>Nenhuma lição cadastrada</h3>
                <p>Crie a primeira lição para este curso clicando em "Nova Lição".</p>
            </div>
        }

    </div>
</section>
