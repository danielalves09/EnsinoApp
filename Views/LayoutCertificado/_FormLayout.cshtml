@model EnsinoApp.ViewModels.LayoutCertificado.LayoutCertificadoFormViewModel

<style>
    .editor-wrap {
        border: 1.5px solid var(--gray-200);
        border-radius: var(--radius);
        overflow: hidden;
        background: #1e1e2e;
    }

    .editor-toolbar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        background: #2a2a3d;
        border-bottom: 1px solid #3a3a50;
        flex-wrap: wrap;
    }

    .editor-toolbar-label {
        font-size: .72rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: .4px;
    }

    .editor-toolbar-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #3a3a50;
        color: #cbd5e1;
        border: none;
        border-radius: 6px;
        padding: 4px 10px;
        font-size: .72rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s;
        font-family: var(--font);
    }

    .editor-toolbar-btn:hover {
        background: #4a4a60;
        color: #fff;
    }

    .editor-textarea {
        width: 100%;
        min-height: 420px;
        background: #1e1e2e;
        color: #e2e8f0;
        border: none;
        padding: 16px;
        font-family: 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
        font-size: .82rem;
        line-height: 1.7;
        resize: vertical;
        outline: none;
        box-sizing: border-box;
        tab-size: 2;
    }

    .var-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: var(--primary-light);
        color: var(--primary);
        border: 1px solid var(--primary-mid);
        border-radius: 20px;
        padding: 3px 10px;
        font-size: .72rem;
        font-weight: 700;
        cursor: pointer;
        transition: background .15s, transform .12s;
        font-family: monospace;
        white-space: nowrap;
    }

    .var-chip:hover {
        background: var(--primary-mid);
        transform: translateY(-1px);
    }

    .var-chip i {
        font-size: .6rem;
    }

    .preview-frame {
        width: 100%;
        border: none;
        border-radius: var(--radius);
        background: var(--gray-50);
        min-height: 400px;
    }

    .orientacao-opt {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        border: 2px solid var(--gray-200);
        border-radius: var(--radius);
        padding: 14px 20px;
        cursor: pointer;
        transition: border-color .18s, background .18s;
        background: var(--gray-50);
    }

    .orientacao-opt:hover {
        border-color: var(--primary);
        background: var(--primary-light);
    }

    .orientacao-opt.selecionado {
        border-color: var(--primary);
        background: var(--primary-light);
    }

    .orientacao-opt input {
        display: none;
    }

    .orientacao-opt .icon-wrap {
        width: 48px;
        height: 48px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        background: rgba(37, 99, 235, .1);
        color: var(--primary);
    }

    .orientacao-opt .label {
        font-size: .8rem;
        font-weight: 700;
        color: var(--gray-700);
    }
</style>

<section class="content">
    <div class="container-fluid">
        <form asp-action="@(Model.Id == 0 ? "Adicionar" : "Editar")" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size:.8rem;margin-bottom:12px">
            </div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImagemFundoUrl" />

            <div class="row g-3">

                <!-- ── Coluna principal (2/3) ──────────────────────── -->
                <div class="col-lg-8">

                    <!-- Identificação -->
                    <div class="ea-form-card ea-fade ea-fade-1" style="margin-bottom:16px">
                        <div class="ea-form-card-header">
                            <div class="ea-form-header-icon"
                                 style="background:var(--primary-light);color:var(--primary)">
                                <i class="fas fa-tag"></i>
                            </div>
                            <h3 class="ea-form-card-title">Identificação</h3>
                        </div>
                        <div class="ea-form-card-body">
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <div class="ea-field-group">
                                        <label asp-for="Nome" class="ea-field-label"></label>
                                        <input asp-for="Nome" class="ea-field-control"
                                               placeholder="Ex: Layout Padrão CCVideira" />
                                        <span asp-validation-for="Nome" class="ea-field-error"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="ea-field-group">
                                        <label class="ea-field-label">Status</label>
                                        <div class="ea-toggle-row" style="margin-top:6px">
                                            <label class="ea-toggle">
                                                <input asp-for="Ativo" type="checkbox" />
                                                <span class="ea-toggle-slider"></span>
                                            </label>
                                            <div>
                                                <div class="ea-toggle-label">Layout Ativo</div>
                                                <div class="ea-toggle-desc">Disponível para seleção</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="ea-field-group">
                                        <label asp-for="Descricao" class="ea-field-label"></label>
                                        <input asp-for="Descricao" class="ea-field-control"
                                               placeholder="Descrição opcional do layout" />
                                        <span asp-validation-for="Descricao" class="ea-field-error"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Editor de Template HTML -->
                    <div class="ea-form-card ea-fade ea-fade-2" style="margin-bottom:16px">
                        <div class="ea-form-card-header">
                            <div class="ea-form-header-icon" style="background:#1e1e2e;color:#a5f3fc">
                                <i class="fas fa-code"></i>
                            </div>
                            <h3 class="ea-form-card-title">Template HTML</h3>
                            <div style="margin-left:auto;display:flex;gap:6px">
                                <button type="button" id="btnFormatarHtml" class="editor-toolbar-btn">
                                    <i class="fas fa-magic"></i> Formatar
                                </button>
                                <button type="button" id="btnAtualizarPreview" class="editor-toolbar-btn"
                                        style="background:var(--primary);color:#fff">
                                    <i class="fas fa-eye"></i> Atualizar Preview
                                </button>
                            </div>
                        </div>

                        <div style="padding:0 22px 10px">
                            <!-- Chips de variáveis -->
                            <div style="margin:12px 0 8px;display:flex;flex-wrap:wrap;gap:6px;align-items:center">
                                <span
                                    style="font-size:.72rem;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.4px;margin-right:4px">
                                    <i class="fas fa-code" style="margin-right:3px"></i>Variáveis — clique para inserir:
                                </span>
                                @foreach (var v in Model.VariaveisDisponiveis)
                                {
                                    <span class="var-chip" onclick="inserirVariavel('@v.Variavel')" title="@v.Descricao">
                                        <i class="fas fa-plus-circle"></i> @v.Variavel
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Textarea dark (editor) -->
                        <div style="padding:0 22px 22px">
                            <div class="editor-wrap">
                                <div class="editor-toolbar">
                                    <span class="editor-toolbar-label"><i class="fas fa-circle"
                                                                              style="color:#ff5f57;margin-right:3px"></i><i class="fas fa-circle"
                                                                                      style="color:#febc2e;margin-right:3px"></i><i class="fas fa-circle"
                                                                                      style="color:#28c840"></i></span>
                                        <span class="editor-toolbar-label" style="margin-left:8px">template.html</span>
                                    </div>
                                    <textarea id="TemplateHtml" name="TemplateHtml" class="editor-textarea"
                                              spellcheck="false" autocomplete="off">@Model.TemplateHtml</textarea>
                                </div>
                                <span asp-validation-for="TemplateHtml" class="ea-field-error"></span>
                                <p style="font-size:.72rem;color:var(--gray-400);margin-top:6px">
                                    <i class="fas fa-info-circle" style="margin-right:3px"></i>
                                    Use as variáveis acima no HTML. Elas serão substituídas pelos dados reais na hora de
                                    gerar o certificado.
                                    O template completo é convertido para PDF via DinkToPdf.
                                </p>
                            </div>
                        </div>

                    </div>

                    <!-- ── Coluna lateral (1/3) ────────────────────────── -->
                    <div class="col-lg-4">

                        <!-- Orientação -->
                        <div class="ea-form-card ea-fade ea-fade-1" style="margin-bottom:16px">
                            <div class="ea-form-card-header">
                                <div class="ea-form-header-icon"
                                     style="background:var(--success-light);color:var(--success)">
                                    <i class="fas fa-expand-arrows-alt"></i>
                                </div>
                                <h3 class="ea-form-card-title">Orientação do PDF</h3>
                            </div>
                            <div class="ea-form-card-body">
                                <div style="display:flex;gap:12px">
                                    <label class="orientacao-opt @(Model.Orientacao == "Landscape" ? "selecionado" : "")"
                                           id="opt-landscape">
                                        <input type="radio" asp-for="Orientacao" value="Landscape" />
                                        <div class="icon-wrap"><i class="fas fa-arrows-alt-h"></i></div>
                                        <span class="label">Paisagem</span>
                                        <span style="font-size:.68rem;color:var(--gray-400)">A4 horizontal</span>
                                    </label>
                                    <label class="orientacao-opt @(Model.Orientacao == "Portrait" ? "selecionado" : "")"
                                           id="opt-portrait">
                                        <input type="radio" asp-for="Orientacao" value="Portrait" />
                                        <div class="icon-wrap"><i class="fas fa-arrows-alt-v"></i></div>
                                        <span class="label">Retrato</span>
                                        <span style="font-size:.68rem;color:var(--gray-400)">A4 vertical</span>
                                    </label>
                                </div>
                                <span asp-validation-for="Orientacao" class="ea-field-error"></span>
                            </div>
                        </div>

                        <!-- Imagem de Fundo -->
                        <div class="ea-form-card ea-fade ea-fade-2" style="margin-bottom:16px">
                            <div class="ea-form-card-header">
                                <div class="ea-form-header-icon"
                                     style="background:var(--warning-light);color:var(--warning)">
                                    <i class="fas fa-image"></i>
                                </div>
                                <h3 class="ea-form-card-title">Imagem de Fundo</h3>
                            </div>
                            <div class="ea-form-card-body">
                                @if (!string.IsNullOrWhiteSpace(Model.ImagemFundoUrl))
                                {
                                    <div
                                        style="margin-bottom:12px;border-radius:var(--radius);overflow:hidden;border:1px solid var(--gray-200)">
                                        <img src="@Model.ImagemFundoUrl" alt="Fundo atual"
                                             style="width:100%;max-height:120px;object-fit:cover;display:block" />
                                    </div>
                                    <p style="font-size:.72rem;color:var(--gray-400);margin-bottom:8px">
                                        <i class="fas fa-info-circle"></i> Imagem atual. Faça novo upload para substituir.
                                    </p>
                                }
                                else
                                {
                                    <div
                                        style="width:100%;height:90px;border:2px dashed var(--gray-200);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;color:var(--gray-300);font-size:.8rem;margin-bottom:12px">
                                        <div style="text-align:center">
                                            <i class="fas fa-image"
                                               style="font-size:1.4rem;display:block;margin-bottom:4px"></i>
                                            Sem imagem de fundo
                                        </div>
                                    </div>
                                }
                                <div class="ea-field-group">
                                    <label asp-for="NovaImagemFundo" class="ea-field-label"></label>
                                    <input asp-for="NovaImagemFundo" type="file" class="ea-field-control"
                                           accept="image/png,image/jpeg,image/webp" onchange="previewFundo(this)" />
                                    <span asp-validation-for="NovaImagemFundo" class="ea-field-error"></span>
                                    <p style="font-size:.72rem;color:var(--gray-400);margin-top:4px">
                                        PNG, JPG ou WEBP. Recomendado: 1122×794px (A4 paisagem).
                                    </p>
                                </div>
                                <div id="previewFundoWrap"
                                     style="display:none;margin-top:8px;border-radius:var(--radius);overflow:hidden;border:1px solid var(--gray-200)">
                                    <img id="previewFundoImg" alt="Pré-visualização"
                                         style="width:100%;max-height:120px;object-fit:cover;display:block" />
                                </div>
                            </div>
                        </div>

                        <!-- Variáveis Disponíveis (referência) -->
                        <div class="ea-form-card ea-fade ea-fade-3" style="margin-bottom:16px">
                            <div class="ea-form-card-header">
                                <div class="ea-form-header-icon" style="background:#f5f3ff;color:#7c3aed">
                                    <i class="fas fa-brackets-curly" style="font-size:.7rem"></i>
                                </div>
                                <h3 class="ea-form-card-title">Referência de Variáveis</h3>
                            </div>
                            <div style="padding:12px 16px">
                                <table style="width:100%;font-size:.75rem;border-collapse:collapse">
                                    <thead>
                                        <tr>
                                            <th
                                                style="padding:5px 8px;text-align:left;color:var(--gray-400);font-weight:700;border-bottom:1px solid var(--gray-100)">
                                                Variável</th>
                                                <th
                                                    style="padding:5px 8px;text-align:left;color:var(--gray-400);font-weight:700;border-bottom:1px solid var(--gray-100)">
                                                    Descrição</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var v in Model.VariaveisDisponiveis)
                                                {
                                                    <tr style="border-bottom:1px solid var(--gray-100)">
                                                        <td style="padding:6px 8px">
                                                            <code
                                                            style="background:var(--primary-light);color:var(--primary);border-radius:4px;padding:2px 5px;font-size:.7rem">@v.Variavel</code>
                                                        </td>
                                                        <td style="padding:6px 8px;color:var(--gray-500)">@v.Descricao</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <!-- Preview ao vivo -->
                                <div class="ea-form-card ea-fade ea-fade-4" style="margin-bottom:16px">
                                    <div class="ea-form-card-header">
                                        <div class="ea-form-header-icon" style="background:var(--info-light);color:var(--info)">
                                            <i class="fas fa-eye"></i>
                                        </div>
                                        <h3 class="ea-form-card-title">Preview ao Vivo</h3>
                                    </div>
                                    <div style="padding:14px 16px">
                                        <p style="font-size:.75rem;color:var(--gray-400);margin:0 0 10px">
                                            Clique em <strong>Atualizar Preview</strong> para renderizar o template com dados de
                                            exemplo.
                                        </p>
                                        <div id="previewContainer" style="display:none">
                                            <iframe id="previewIframe" class="preview-frame"
                                                    style="height:320px;border-radius:var(--radius);border:1px solid var(--gray-200)">
                                            </iframe>
                                        </div>
                                        <div id="previewPlaceholder"
                                             style="height:200px;border:2px dashed var(--gray-200);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;color:var(--gray-300)">
                                            <div style="text-align:center">
                                                <i class="fas fa-file-alt"
                                                   style="font-size:2rem;display:block;margin-bottom:8px"></i>
                                                <span style="font-size:.8rem">Preview aparecerá aqui</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- Footer de ações -->
                        <div class="ea-form-footer" style="margin-top:8px">
                            <a asp-action="Index" class="ea-btn-action cancel">
                                <i class="fas fa-times"></i> Cancelar
                            </a>
                            <button type="submit" class="ea-btn-action save">
                                <i class="fas fa-save"></i> Salvar Layout
                            </button>
                        </div>

                    </form>
                </div>
            </section>

            <script>

                document.addEventListener('DOMContentLoaded', function () {

                    document.querySelectorAll('.orientacao-opt').forEach(function (label) {
                        label.addEventListener('click', function () {
                            document.querySelectorAll('.orientacao-opt').forEach(function (el) {
                                el.classList.remove('selecionado');
                            });
                            this.classList.add('selecionado');

                           
                            var radio = this.querySelector('input[type=radio]');
                            if (radio) radio.checked = true;
                        });
                    });

                    // ── 2. Botão Formatar HTML ─────────────────────────────────────────
                    var btnFormatar = document.getElementById('btnFormatarHtml');
                    if (btnFormatar) {
                        btnFormatar.addEventListener('click', function () {
                            var ta = document.getElementById('TemplateHtml');
                            if (!ta) return;
                            try {
                                var html = ta.value;

                                // Adiciona quebras entre tags e remove espaços iniciais excessivos
                                html = html
                                    .replace(/>\s*</g, '>\n<')
                                    .replace(/^\s+/gm, '')
                                    .trim();

                                // Re-indenta baseado na abertura/fechamento de tags
                                var level = 0;
                                var selfClosing = /^<(area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)/i;
                                var lines = html.split('\n');
                                var result = lines.map(function (line) {
                                    line = line.trim();
                                    if (!line) return '';

                                    // Fecha antes de indentar se for tag de fechamento
                                    if (/^<\//.test(line)) level = Math.max(0, level - 1);

                                    var indented = '  '.repeat(level) + line;

                                    // Abre nível se for tag de abertura (não vazia, não auto-fechada)
                                    if (/^<[^/!?]/.test(line)
                                        && !/\/>$/.test(line)
                                        && !/<\//.test(line)
                                        && !selfClosing.test(line)) {
                                        level++;
                                    }
                                    return indented;
                                });

                                ta.value = result.filter(function (l) { return l !== ''; }).join('\n');
                            } catch (e) {
                                // Silencioso — nunca interrompe o usuário
                            }
                        });
                    }

                    // ── 3. Botão Atualizar Preview ────────────────────────────────────
                    var btnPreview = document.getElementById('btnAtualizarPreview');
                    if (btnPreview) {
                        btnPreview.addEventListener('click', function () {
                            var ta = document.getElementById('TemplateHtml');
                            if (!ta) return;

                            var html = ta.value;

                            // Mapa de variáveis com dados de exemplo
                            var varMap = {
                                '{{NomeCasal}}': 'João Silva e Maria Silva',
                                '{{NomeCurso}}': 'Casados Para Sempre',
                                '{{DataConclusao}}': new Date().toLocaleDateString('pt-BR'),
                                '{{NomeLider}}': 'Pedro e Ana',
                                '{{NomeCampus}}': 'Campus Central',
                                '{{LogoUrl}}': '/images/logo.png',
                                '{{FundoUrl}}': '@(string.IsNullOrWhiteSpace(Model.ImagemFundoUrl) ? "/images/bordaCertificado4.png" : Model.ImagemFundoUrl)',
                                '{{CodigoValidacao}}': 'CERT-PREVIEW-2024',
                                '{{QRCodeBase64}}': 'data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==',
                                '{{FontWoff2Url}}': '/fonts/greatvibes-regular.woff2',
                                '{{FontWoffUrl}}': '/fonts/greatvibes-regular.woff',
                                '{{FontTtfUrl}}': '/fonts/greatvibes-regular.ttf'
                            };

                            // Substitui todas as ocorrências de cada variável
                            Object.keys(varMap).forEach(function (chave) {
                                // replaceAll não existe em todos os browsers — usa split/join
                                html = html.split(chave).join(varMap[chave]);
                            });

                            var iframe = document.getElementById('previewIframe');
                            var container = document.getElementById('previewContainer');
                            var placeholder = document.getElementById('previewPlaceholder');

                            if (iframe && container && placeholder) {
                                iframe.srcdoc = html;
                                placeholder.style.display = 'none';
                                container.style.display = 'block';
                            }
                        });
                    }

                });

                // ── 4. Inserir variável na posição do cursor (chamado pelo onclick do chip) ──
                // Fica fora do DOMContentLoaded para ser acessível pelo atributo onclick inline.
                function inserirVariavel(variavel) {
                    var ta = document.getElementById('TemplateHtml');
                    if (!ta) return;
                    var start = ta.selectionStart;
                    var end = ta.selectionEnd;
                    var before = ta.value.substring(0, start);
                    var after = ta.value.substring(end);
                    ta.value = before + variavel + after;
                    ta.focus();
                    ta.selectionStart = ta.selectionEnd = start + variavel.length;
                }

                // ── 5. Preview da imagem de fundo antes do upload ─────────────────────────
                function previewFundo(input) {
                    if (input.files && input.files[0]) {
                        var reader = new FileReader();
                        reader.onload = function (e) {
                            var img = document.getElementById('previewFundoImg');
                            var wrap = document.getElementById('previewFundoWrap');
                            if (img) img.src = e.target.result;
                            if (wrap) wrap.style.display = 'block';
                        };
                        reader.readAsDataURL(input.files[0]);
                    }
                }
            </script>
