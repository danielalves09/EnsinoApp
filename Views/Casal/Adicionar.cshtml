@model EnsinoApp.ViewModels.Casal.AdicionarCasalViewModel
@{
    ViewData["Title"] = "Cadastrar Casal";
}

<section class="content-header" style="padding-bottom:0">
    <div class="container-fluid">
        <a asp-action="Index" class="ea-btn-back"><i class="fas fa-arrow-left"></i> Voltar para Casais</a>
        <div class="ea-page-title">
            <h1><i class="fas fa-heart" style="color:#f43f5e;margin-right:8px"></i>Cadastrar Casal</h1>
            <p>Preencha os dados dos dois cônjuges para realizar o cadastro</p>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <form asp-action="Adicionar" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size:.8rem;margin-bottom:12px">
            </div>

            <!-- Dados do Casal -->
            <div class="ea-form-card ea-fade ea-fade-1">
                <div class="ea-form-card-header">
                    <div class="ea-form-header-icon" style="background:#fff0f0;color:#f43f5e">
                        <i class="fas fa-heart"></i>
                    </div>
                    <h3 class="ea-form-card-title">Dados do Casal</h3>
                </div>
                <div class="ea-form-card-body">
                    <div class="row g-3">
                        <!-- Cônjuge 1 -->
                        <div class="col-12">
                            <p
                                style="font-size:.72rem;font-weight:700;color:var(--primary);text-transform:uppercase;letter-spacing:.5px;margin:0 0 12px;display:flex;align-items:center;gap:6px">
                                <i class="fas fa-user"></i> Cônjuge 1 (Homem)
                            </p>
                        </div>
                        <div class="col-md-6">
                            <div class="ea-field-group">
                                <label asp-for="NomeConjuge1" class="ea-field-label"></label>
                                <input asp-for="NomeConjuge1" class="ea-field-control" placeholder="Nome completo" />
                                <span asp-validation-for="NomeConjuge1" class="ea-field-error"></span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="ea-field-group">
                                <label asp-for="TelefoneConjuge1" class="ea-field-label"></label>
                                <input asp-for="TelefoneConjuge1" class="ea-field-control telefone"
                                       placeholder="(00) 00000-0000" />
                                <span asp-validation-for="TelefoneConjuge1" class="ea-field-error"></span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="ea-field-group">
                                <label asp-for="EmailConjuge1" class="ea-field-label"></label>
                                <input asp-for="EmailConjuge1" class="ea-field-control"
                                       placeholder="email@exemplo.com" />
                                <span asp-validation-for="EmailConjuge1" class="ea-field-error"></span>
                            </div>
                        </div>

                        <!-- Divisor -->
                        <div class="col-12">
                            <hr style="border-color:var(--gray-100);margin:4px 0 12px" />
                            <p
                                style="font-size:.72rem;font-weight:700;color:#f43f5e;text-transform:uppercase;letter-spacing:.5px;margin:0 0 12px;display:flex;align-items:center;gap:6px">
                                <i class="fas fa-user"></i> Cônjuge 2 (Mulher)
                            </p>
                        </div>
                        <div class="col-md-6">
                            <div class="ea-field-group">
                                <label asp-for="NomeConjuge2" class="ea-field-label"></label>
                                <input asp-for="NomeConjuge2" class="ea-field-control" placeholder="Nome completo" />
                                <span asp-validation-for="NomeConjuge2" class="ea-field-error"></span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="ea-field-group">
                                <label asp-for="TelefoneConjuge2" class="ea-field-label"></label>
                                <input asp-for="TelefoneConjuge2" class="ea-field-control telefone"
                                       placeholder="(00) 00000-0000" />
                                <span asp-validation-for="TelefoneConjuge2" class="ea-field-error"></span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="ea-field-group">
                                <label asp-for="EmailConjuge2" class="ea-field-label"></label>
                                <input asp-for="EmailConjuge2" class="ea-field-control"
                                       placeholder="email@exemplo.com" />
                                <span asp-validation-for="EmailConjuge2" class="ea-field-error"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Vínculo -->
            <div class="ea-form-card ea-fade ea-fade-2">
                <div class="ea-form-card-header">
                    <div class="ea-form-header-icon" style="background:var(--primary-light);color:var(--primary)">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <h3 class="ea-form-card-title">Vínculo e Status</h3>
                </div>
                <div class="ea-form-card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="ea-field-group">
                                <label class="ea-field-label"><i class="fas fa-map-marker-alt"
                                                                     style="margin-right:3px"></i>Campus</label>
                                    <div class="ea-input-group">
                                        <input asp-for="NomeCampus" class="ea-field-control" readonly
                                               placeholder="Selecione um campus" />
                                        <input type="hidden" asp-for="IdCampus" />
                                        <button type="button" class="ea-btn-buscar" data-toggle="modal"
                                                data-target="#ModalCampus">
                                            <i class="fas fa-search"></i> Buscar
                                        </button>
                                    </div>
                                    <span asp-validation-for="IdCampus" class="ea-field-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="ea-field-group">
                                    <label asp-for="Status" class="ea-field-label"></label>
                                    <select asp-for="Status"
                                            asp-items="Html.GetEnumSelectList<EnsinoApp.Models.Enums.StatusCasal>()"
                                            class="ea-field-control"></select>
                                    <span asp-validation-for="Status" class="ea-field-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Endereço -->
                <div class="ea-form-card ea-fade ea-fade-3">
                    <div class="ea-form-card-header">
                        <div class="ea-form-header-icon" style="background:var(--success-light);color:var(--success)">
                            <i class="fas fa-map-pin"></i>
                        </div>
                        <h3 class="ea-form-card-title">Endereço</h3>
                    </div>
                    <div class="ea-form-card-body">
                        <div
                            style="display:flex;align-items:center;gap:8px;background:var(--info-light);border:1px solid #a5f3fc;border-radius:var(--radius);padding:10px 14px;font-size:.78rem;color:var(--info);font-weight:600;margin-bottom:18px">
                            <i class="fas fa-info-circle"></i> Preencha o CEP para autocompletar o endereço.
                        </div>
                        <div class="row g-3">
                            <div class="col-md-3">
                                <div class="ea-field-group">
                                    <label asp-for="Cep" class="ea-field-label"></label>
                                    <div style="position:relative">
                                        <input asp-for="Cep" class="ea-field-control" id="Cep" placeholder="00000-000" />
                                        <i class="fas fa-spinner fa-spin" id="cepSpin"
                                           style="display:none;position:absolute;right:12px;top:50%;transform:translateY(-50%);color:var(--gray-400)"></i>
                                    </div>
                                    <span asp-validation-for="Cep" class="ea-field-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="ea-field-group">
                                    <label asp-for="Rua" class="ea-field-label"></label>
                                    <input asp-for="Rua" class="ea-field-control" id="Rua"
                                           placeholder="Nome da rua ou avenida" />
                                    <span asp-validation-for="Rua" class="ea-field-error"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="ea-field-group">
                                    <label asp-for="Numero" class="ea-field-label"></label>
                                    <input asp-for="Numero" class="ea-field-control" placeholder="Nº" />
                                    <span asp-validation-for="Numero" class="ea-field-error"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="ea-field-group">
                                    <label asp-for="Complemento" class="ea-field-label"></label>
                                    <input asp-for="Complemento" class="ea-field-control"
                                           placeholder="Apto, bloco, sala..." />
                                    <span asp-validation-for="Complemento" class="ea-field-error"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="ea-field-group">
                                    <label asp-for="Bairro" class="ea-field-label"></label>
                                    <input asp-for="Bairro" class="ea-field-control" id="Bairro" placeholder="Bairro" />
                                    <span asp-validation-for="Bairro" class="ea-field-error"></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="ea-field-group">
                                    <label asp-for="Estado" class="ea-field-label"></label>
                                    <select asp-for="Estado" class="ea-field-control" id="Estado">
                                        <option value="">UF</option>
                                        <option value="AC">AC</option>
                                        <option value="AL">AL</option>
                                        <option value="AP">AP</option>
                                        <option value="AM">AM</option>
                                        <option value="BA">BA</option>
                                        <option value="CE">CE</option>
                                        <option value="DF">DF</option>
                                        <option value="ES">ES</option>
                                        <option value="GO">GO</option>
                                        <option value="MA">MA</option>
                                        <option value="MT">MT</option>
                                        <option value="MS">MS</option>
                                        <option value="MG">MG</option>
                                        <option value="PA">PA</option>
                                        <option value="PB">PB</option>
                                        <option value="PR">PR</option>
                                        <option value="PE">PE</option>
                                        <option value="PI">PI</option>
                                        <option value="RJ">RJ</option>
                                        <option value="RN">RN</option>
                                        <option value="RS">RS</option>
                                        <option value="RO">RO</option>
                                        <option value="RR">RR</option>
                                        <option value="SC">SC</option>
                                        <option value="SP">SP</option>
                                        <option value="SE">SE</option>
                                        <option value="TO">TO</option>
                                    </select>
                                    <span asp-validation-for="Estado" class="ea-field-error"></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="ea-field-group">
                                    <label asp-for="Cidade" class="ea-field-label"></label>
                                    <input asp-for="Cidade" class="ea-field-control" id="Cidade" placeholder="Cidade" />
                                    <span asp-validation-for="Cidade" class="ea-field-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="ea-form-footer">
                        <a asp-action="Index" class="ea-btn-action cancel"><i class="fas fa-times"></i> Cancelar</a>
                        <button type="submit" class="ea-btn-action save"><i class="fas fa-save"></i> Salvar Casal</button>
                    </div>
                </div>

            </form>
        </div>
    </section>

    <!-- Modal Campus -->
    <div class="modal fade ea-modal" id="ModalCampus" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-building" style="color:var(--primary);margin-right:6px"></i>Buscar Campus
                    </h5>
                    <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                </div>
                <div class="modal-body">
                    <input type="text" id="TxtFiltroCampus" class="ea-modal-search"
                           placeholder="Digite o nome do campus..." />
                    <div style="overflow-y:auto;max-height:300px">
                        <table class="ea-modal-table" id="TbCampus">
                            <tbody></tbody>
                        </table>
                        <div id="DivMensagemCampus" class="ea-modal-empty d-none">Nenhum campus encontrado.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script>
            // Busca de campus
            function buscarCampus() {
                var f = $("#TxtFiltroCampus").val().trim(); if (!f.length) return;
                $.getJSON("/Campus/Buscar?filtro=" + encodeURIComponent(f), function (r) {
                    $("#DivMensagemCampus").addClass("d-none");
                    if (r.length) {
                        $("#TbCampus tbody").html(r.map(p => "<tr data-id='" + p.id + "'><td>" + p.nome + "</td></tr>").join(""));
                        $("#TbCampus tbody tr").click(function () {
                            $("#IdCampus").val($(this).data("id"));
                            $("#NomeCampus").val($(this).find("td:first").text());
                            $("#ModalCampus").modal("hide");
                        });
                    } else { $("#TbCampus tbody").html(""); $("#DivMensagemCampus").removeClass("d-none"); }
                });
            }
            $("#TxtFiltroCampus").on("keyup input", buscarCampus);

            // CEP autocomplete
            $("#Cep").on("blur", function () {
                var cep = $(this).val().replace(/\D/g, "");
                if (cep.length === 8) {
                    $("#cepSpin").show();
                    $.getJSON("https://viacep.com.br/ws/" + cep + "/json/", function (data) {
                        if (!("erro" in data)) {
                            $("#Rua").val(data.logradouro);
                            $("#Bairro").val(data.bairro);
                            $("#Cidade").val(data.localidade);
                            $("#Estado").val(data.uf);
                        }
                    }).always(function () { $("#cepSpin").hide(); });
                }
            });

            // Máscara telefone
            $(function () { $(".telefone").mask("(00) 00000-0000"); });
        </script>
    }
