@using EnsinoApp.Models.Enums
@model IEnumerable<EnsinoApp.Models.Entities.Casal>
@{
    ViewData["Title"] = "Gerenciar Casais";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="ea-page-title">
            <h1><i class="fas fa-heart" style="color:#f43f5e;margin-right:8px"></i>Gerenciar Casais</h1>
            <p>Visualize e gerencie os casais cadastrados no sistema</p>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        <!-- Stats -->
        <div class="ea-stat-grid" style="margin-bottom:20px">
            <div class="ea-stat-card ea-fade ea-fade-1">
                <div class="ea-stat-icon" style="background:#fff0f0;color:#f43f5e"><i class="fas fa-heart"></i></div>
                <div>
                    <p class="ea-stat-label">Total de Casais</p>
                    <p class="ea-stat-number">@Model.Count()</p>
                </div>
            </div>
            <div class="ea-stat-card ea-fade ea-fade-2">
                <div class="ea-stat-icon" style="background:var(--success-light);color:var(--success)"><i class="fas fa-check-circle"></i></div>
                <div>
                    <p class="ea-stat-label">Ativos</p>
                    <p class="ea-stat-number">@Model.Count(c => c.Status == StatusCasal.Ativo)</p>
                </div>
            </div>
            <div class="ea-stat-card ea-fade ea-fade-3">
                <div class="ea-stat-icon" style="background:var(--primary-light);color:var(--primary)"><i class="fas fa-graduation-cap"></i></div>
                <div>
                    <p class="ea-stat-label">Concluídos</p>
                    <p class="ea-stat-number">@Model.Count(c => c.Status == StatusCasal.Concluido)</p>
                </div>
            </div>
            <div class="ea-stat-card ea-fade ea-fade-4">
                <div class="ea-stat-icon" style="background:var(--danger-light);color:var(--danger)"><i class="fas fa-user-times"></i></div>
                <div>
                    <p class="ea-stat-label">Desistentes</p>
                    <p class="ea-stat-number">@Model.Count(c => c.Status == StatusCasal.Desistente)</p>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="ea-toolbar">
            <form method="get" style="flex:1 1 auto">
                <div class="ea-filter-group">
                    <div class="ea-filter-item">
                        <label><i class="fas fa-map-marker-alt" style="margin-right:3px"></i>Campus</label>
                        @Html.DropDownList("IdCampus", (SelectList)ViewBag.Campuses, "Todos os campi", new { @class = "ea-filter-select" })
                    </div>
                    <div class="ea-filter-item" style="flex:0 1 150px">
                        <label><i class="fas fa-circle" style="margin-right:3px"></i>Status</label>
                        @Html.DropDownList("Status", (SelectList)ViewBag.Status, "Todos", new { @class = "ea-filter-select" })
                    </div>
                    <div class="ea-filter-item" style="flex:1 1 220px">
                        <label><i class="fas fa-search" style="margin-right:3px"></i>Buscar</label>
                        <input type="text" name="filtro" value="@ViewBag.Filtro" class="ea-filter-select"
                               placeholder="Nome, email..." style="border-radius:var(--radius);border:1.5px solid var(--gray-200);padding:8px 12px;font-size:.82rem;font-family:var(--font);color:var(--gray-700);background:var(--gray-50)"/>
                    </div>
                    <div style="display:flex;align-items:flex-end;gap:6px">
                        <button type="submit" class="ea-btn-filter"><i class="fas fa-filter"></i> Filtrar</button>
                        <a asp-action="Index" class="ea-btn-clear"><i class="fas fa-times"></i> Limpar</a>
                    </div>
                </div>
            </form>
            <a asp-action="Adicionar" class="ea-btn-new"><i class="fas fa-plus"></i> Novo Casal</a>
        </div>

        <!-- Table -->
        <div class="ea-table-card ea-fade">
            <div class="ea-table-card-header">
                <div class="ea-table-header-icon" style="background:#fff0f0;color:#f43f5e"><i class="fas fa-heart"></i></div>
                <h3 class="ea-table-card-title">Casais Cadastrados</h3>
                @if (Model.Any())
                {
                    <span class="ea-count-badge">@Model.Count() casais</span>
                }
            </div>

            <div style="overflow-x:auto">
                @if (Model.Any())
                {
                    <table class="ea-table">
                        <thead>
                            <tr>
                                <th>Casal</th>
                                <th>Contato</th>
                                <th>Campus</th>
                                <th>Endereço</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var casal in Model)
                            {
                                string badgeClass = casal.Status == StatusCasal.Ativo ? "ativo"
                                    : casal.Status == StatusCasal.Concluido ? "concluida"
                                    : "cancelada";

                                string statusLabel = casal.Status == StatusCasal.Ativo ? "Ativo"
                                    : casal.Status == StatusCasal.Concluido ? "Concluído"
                                    : "Desistente";

                                var iniciais1 = casal.NomeConjuge1?.Length > 0 ? casal.NomeConjuge1[0].ToString().ToUpper() : "?";
                                var iniciais2 = casal.NomeConjuge2?.Length > 0 ? casal.NomeConjuge2[0].ToString().ToUpper() : "?";

                                <tr>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:10px">
                                            <div style="display:flex;gap:-4px">
                                                <div style="width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#fff0f0,#fecaca);color:#f43f5e;font-size:.72rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:var(--font);border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.08)">
                                                    @iniciais1@iniciais2
                                                </div>
                                            </div>
                                            <div>
                                                <p style="font-weight:700;color:var(--gray-800);margin:0;font-size:.85rem">
                                                    @casal.NomeConjuge1
                                                </p>
                                                <p style="font-weight:600;color:var(--gray-500);margin:0;font-size:.78rem">
                                                    <i class="fas fa-heart" style="color:#fca5a5;font-size:.6rem;margin-right:3px"></i>@casal.NomeConjuge2
                                                </p>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div style="font-size:.78rem;color:var(--gray-500)">
                                            <div style="margin-bottom:2px">
                                                <i class="fas fa-envelope" style="color:var(--gray-300);margin-right:4px;width:12px"></i>@casal.EmailConjuge1
                                            </div>
                                            <div>
                                                <i class="fas fa-phone-alt" style="color:var(--gray-300);margin-right:4px;width:12px"></i>@casal.TelefoneConjuge1
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (casal.Campus != null)
                                        {
                                            <span class="ea-meta-pill"><i class="fas fa-map-marker-alt"></i>@casal.Campus.Nome</span>
                                        }
                                        else
                                        {
                                            <span style="color:var(--gray-300);font-size:.75rem">—</span>
                                        }
                                    </td>
                                    <td style="font-size:.78rem;color:var(--gray-500);max-width:200px">
                                        @if (!string.IsNullOrWhiteSpace(casal.Rua))
                                        {
                                            <span>@casal.Rua, @casal.Numero — @casal.Cidade/@casal.Estado</span>
                                        }
                                        else
                                        {
                                            <span style="color:var(--gray-300);font-style:italic">Sem endereço</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="ea-badge @badgeClass">@statusLabel</span>
                                    </td>
                                    <td>
                                                            <button type="button" class="btn-ver-casal" data-id="@casal.Id"
                                                                    title="Ver detalhes do casal">
                                                                <i class="fas fa-eye"></i> Detalhes
                                                            </button>
                                                        </td>
                                    <td>
                                        <div style="display:flex;gap:6px">
                                            <a asp-action="Editar" asp-route-id="@casal.Id" class="ea-action-btn primary" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Excluir" asp-route-id="@casal.Id"
                                               onclick="return confirm('Excluir o casal @casal.NomeConjuge1 e @casal.NomeConjuge2?')"
                                               class="ea-action-btn danger" title="Excluir">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="ea-empty" style="border:none;border-radius:0">
                        <i class="fas fa-heart"></i>
                        <h3>Nenhum casal encontrado</h3>
                        <p>Ajuste os filtros ou cadastre um novo casal.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPaginas > 1)
        {
            <div class="ea-pagination">
                @if (ViewBag.NumeroPagina > 1)
                {
                    <a class="ea-page-btn" href="@Url.Action("Index","Casal",new{Filtro=ViewBag.Filtro,Pagina=ViewBag.NumeroPagina-1})">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                }
                <span class="ea-page-info">Página @ViewBag.NumeroPagina de @ViewBag.TotalPaginas</span>
                @if (ViewBag.NumeroPagina < ViewBag.TotalPaginas)
                {
                    <a class="ea-page-btn" href="@Url.Action("Index","Casal",new{Filtro=ViewBag.Filtro,Pagina=ViewBag.NumeroPagina+1})">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                }
            </div>
        }

    </div>
</section>

 @* {{-- ══ MODAL DETALHES DO CASAL ══════════════════════════════════ --}} *@
                        <div class="modal fade" id="modalCasal" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-lg modal-dialog-centered">
                                <div class="modal-content" style="border:none;border-radius:var(--radius-lg);overflow:hidden">

                                    @* {{-- Header --}} *@
                                    <div class="modal-header"
                                         style="background:linear-gradient(135deg,#1e40af,#2563eb);border:none;padding:20px 24px">
                                        <div style="display:flex;align-items:center;gap:12px">
                                            <div
                                                style="width:40px;height:40px;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:.9rem;flex-shrink:0">
                                                <i class="fas fa-heart"></i>
                                            </div>
                                            <div>
                                                <h5 class="modal-title" id="modalCasalNome"
                                                    style="font-family:var(--font);font-size:1rem;font-weight:800;color:#fff;margin:0"></h5>
                                                <p id="modalCasalCampus" style="font-size:.75rem;color:rgba(255,255,255,.7);margin:0"></p>
                                            </div>
                                        </div>
                                        <button type="button" class="close" data-dismiss="modal"
                                                style="color:#fff;opacity:.7;font-size:1.4rem;padding:0;margin:0">
                                            <span>&times;</span>
                                        </button>
                                    </div>

                                    @* {{-- Body --}} *@
                                    <div class="modal-body" style="padding:0">

                                        @* {{-- Loading --}} *@
                                        <div id="modalCasalLoading"
                                             style="display:flex;align-items:center;justify-content:center;padding:48px;gap:10px;color:var(--gray-400)">
                                            <i class="fas fa-circle-notch fa-spin"></i>
                                            <span style="font-size:.85rem">Carregando...</span>
                                        </div>

                                        @* {{-- Conteúdo (oculto até carregar) --}} *@
                                        <div id="modalCasalConteudo" style="display:none">

                                            @* {{-- Grid principal: contato + endereço --}} *@
                                            <div
                                                style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-bottom:1px solid var(--gray-100)">

                                                @* {{-- Cônjuge 1 --}} *@
                                                <div style="padding:20px 24px;border-right:1px solid var(--gray-100)">
                                                    <p
                                                        style="font-size:.68rem;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.4px;margin:0 0 12px">
                                                        Homem</p>
                                                        <p id="mc-nome1"
                                                               style="font-family:var(--font);font-size:.9rem;font-weight:800;color:var(--gray-800);margin:0 0 8px">
                                                        </p>
                                                        <div style="display:flex;flex-direction:column;gap:5px">
                                                            <span id="mc-email1" style="font-size:.78rem;color:var(--gray-500)"></span>
                                                            <span id="mc-fone1" style="font-size:.78rem;color:var(--gray-500)"></span>
                                                        </div>
                                                    </div>

                                                    @* {{-- Cônjuge 2 --}} *@
                                                    <div style="padding:20px 24px">
                                                        <p
                                                            style="font-size:.68rem;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.4px;margin:0 0 12px">
                                                            Mulher</p>
                                                            <p id="mc-nome2"
                                                                   style="font-family:var(--font);font-size:.9rem;font-weight:800;color:var(--gray-800);margin:0 0 8px">
                                                            </p>
                                                            <div style="display:flex;flex-direction:column;gap:5px">
                                                                <span id="mc-email2" style="font-size:.78rem;color:var(--gray-500)"></span>
                                                                <span id="mc-fone2" style="font-size:.78rem;color:var(--gray-500)"></span>
                                                            </div>
                                                        </div>

                                                    </div>

                                                    @* {{-- Endereço --}} *@
                                                    <div
                                                        style="padding:16px 24px;border-bottom:1px solid var(--gray-100);display:flex;align-items:center;gap:10px">
                                                        <div
                                                            style="width:28px;height:28px;background:var(--primary-light);color:var(--primary);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:.7rem;flex-shrink:0">
                                                            <i class="fas fa-map-marker-alt"></i>
                                                        </div>
                                                        <span id="mc-endereco" style="font-size:.82rem;color:var(--gray-600)"></span>
                                                    </div>

                                                    @* {{-- Histórico de matrículas --}} *@
                                                    <div style="padding:16px 24px 4px">
                                                        <p
                                                            style="font-size:.68rem;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.4px;margin:0 0 10px">
                                                            Histórico de matrículas</p>
                                                            <div id="mc-matriculas"></div>
                                                        </div>

                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                    </div>

                                    @section Scripts {
<style>
    .btn-ver-casal {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--primary-light);
        color: var(--primary);
        border: 1px solid var(--primary-mid);
        border-radius: var(--radius-sm);
        padding: 5px 11px;
        font-size: .75rem;
        font-weight: 700;
        cursor: pointer;
        transition: background .18s;
        font-family: var(--font);
    }
    .btn-ver-casal:hover { background: var(--primary-mid); }

    .mc-matricula-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 0;
        border-bottom: 1px solid var(--gray-100);
        font-size: .82rem;
    }
    .mc-matricula-item:last-child { border-bottom: none; }

    .mc-curso-icon {
        width: 32px;
        height: 32px;
        border-radius: var(--radius-sm);
        background: var(--success-light);
        color: var(--success);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .7rem;
        flex-shrink: 0;
    }
    .mc-badge {
        display: inline-flex;
        align-items: center;
        font-size: .68rem;
        font-weight: 700;
        border-radius: 20px;
        padding: 2px 8px;
        margin-left: auto;
        white-space: nowrap;
    }
    .mc-badge.ativa       { background: var(--success-light); color: var(--success);  border: 1px solid #bbf7d0; }
    .mc-badge.concluida   { background: var(--primary-light); color: var(--primary);  border: 1px solid var(--primary-mid); }
    .mc-badge.desistente  { background: var(--danger-light);  color: var(--danger);   border: 1px solid #fca5a5; }
</style>

<script>
    $(function () {

        // ── Abre o modal e busca os dados via fetch ──────────────────────
        $(document).on('click', '.btn-ver-casal', function () {
            var id = $(this).data('id');

            // Reseta o modal antes de abrir
            $('#modalCasalNome').text('Carregando...');
            $('#modalCasalCampus').text('');
            $('#modalCasalLoading').show();
            $('#modalCasalConteudo').hide();

            $('#modalCasal').modal('show');

            // Busca os dados do endpoint JSON
            $.getJSON('/Casal/Detalhes/' + id)
                .done(function (d) {
                    preencherModal(d);
                })
                .fail(function () {
                    $('#modalCasalLoading').html(
                        '<span style="color:var(--danger);font-size:.85rem">' +
                        '<i class="fas fa-exclamation-circle" style="margin-right:6px"></i>' +
                        'Erro ao carregar os dados. Tente novamente.</span>'
                    );
                });
        });

        // ── Preenche o modal com os dados recebidos ──────────────────────
        function preencherModal(d) {
            // Header
            $('#modalCasalNome').text(d.nomeConjuge1 + ' e ' + d.nomeConjuge2);
            $('#modalCasalCampus').html(
                '<i class="fas fa-map-marker-alt" style="margin-right:4px"></i>' +
                d.nomeCampus + ' &nbsp;·&nbsp; ' + traduzirStatus(d.status)
            );

            // Cônjuges
            $('#mc-nome1').text(d.nomeConjuge1);
            $('#mc-email1').html('<i class="fas fa-envelope" style="margin-right:5px;color:var(--gray-300)"></i>' + d.emailConjuge1);
            $('#mc-fone1').html('<i class="fas fa-phone" style="margin-right:5px;color:var(--gray-300)"></i>' + d.telefoneConjuge1);

            $('#mc-nome2').text(d.nomeConjuge2);
            $('#mc-email2').html('<i class="fas fa-envelope" style="margin-right:5px;color:var(--gray-300)"></i>' + d.emailConjuge2);
            $('#mc-fone2').html('<i class="fas fa-phone" style="margin-right:5px;color:var(--gray-300)"></i>' + d.telefoneConjuge2);

            // Endereço
            var partes = [d.rua, d.numero, d.complemento, d.bairro, d.cidade + ' - ' + d.estado, d.cep]
                .filter(function (p) { return p && p.trim() !== ''; });
            $('#mc-endereco').text(partes.join(', '));

            // Histórico de matrículas
            var $container = $('#mc-matriculas');
            $container.empty();

            if (!d.matriculas || d.matriculas.length === 0) {
                $container.html(
                    '<p style="font-size:.8rem;color:var(--gray-400);font-style:italic;padding:8px 0 16px">' +
                    'Nenhuma matrícula registrada.</p>'
                );
            } else {
                d.matriculas.forEach(function (m) {
                    var badgeClass = m.status.toLowerCase() === 'ativa' ? 'ativa'
                        : m.status.toLowerCase().includes('conclu') ? 'concluida'
                        : 'desistente';

                    var certificadoHtml = m.certificadoEmitido
                        ? '<span style="font-size:.7rem;color:var(--success);margin-left:6px">' +
                          '<i class="fas fa-certificate"></i> Certificado</span>'
                        : '';

                    var dataHtml = '<span style="font-size:.75rem;color:var(--gray-400);margin-left:6px">' +
                        formatarData(m.dataMatricula) +
                        (m.dataConclusao ? ' → ' + formatarData(m.dataConclusao) : '') +
                        '</span>';

                    $container.append(
                        '<div class="mc-matricula-item">' +
                            '<div class="mc-curso-icon"><i class="fas fa-graduation-cap"></i></div>' +
                            '<div style="flex:1;min-width:0">' +
                                '<span style="font-weight:700;color:var(--gray-800)">' + m.nomeCurso + '</span>' +
                                certificadoHtml +
                                '<br>' + dataHtml +
                            '</div>' +
                            '<span class="mc-badge ' + badgeClass + '">' + traduzirStatus(m.status) + '</span>' +
                        '</div>'
                    );
                });
                $container.css('padding-bottom', '8px');
            }

            // Exibe o conteúdo
            $('#modalCasalLoading').hide();
            $('#modalCasalConteudo').show();
        }

        // ── Helpers ──────────────────────────────────────────────────────
        function traduzirStatus(s) {
            var mapa = {
                'Ativo': 'Ativo', 'Ativa': 'Ativa',
                'Desistente': 'Desistente',
                'Concluido': 'Concluído', 'Concluída': 'Concluída',
                'Cancelada': 'Cancelada'
            };
            return mapa[s] || s;
        }

        function formatarData(iso) {
            if (!iso) return '';
            var d = new Date(iso);
            return d.toLocaleDateString('pt-BR');
        }

    });
</script>
}


