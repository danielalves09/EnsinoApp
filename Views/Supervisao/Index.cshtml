@model IEnumerable<EnsinoApp.ViewModels.Supervisao.ListarSupervisaoViewModel>
@{
    ViewData["Title"] = "Gerenciar Supervisões";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="ea-page-title">
            <h1><i class="fas fa-sitemap" style="color:var(--primary);margin-right:8px"></i>Gerenciar Supervisões</h1>
            <p>Cadastre e gerencie os grupos de supervisão</p>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        <div class="ea-toolbar">
            <form asp-action="Index" style="flex:1 1 220px">
                <div class="ea-search-wrap">
                    <i class="fas fa-search ea-search-icon"></i>
                    <input type="text" placeholder="Buscar supervisão..." name="filtro" value="@ViewBag.Filtro" />
                    <button type="submit" class="ea-btn-search"><i class="fas fa-search"></i></button>
                </div>
            </form>
            <a href="/supervisao/adicionar" class="ea-btn-new"><i class="fas fa-plus"></i> Nova Supervisão</a>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="ea-grid">
                @foreach (var p in Model!)
                {
                    <div class="ea-card ea-fade ea-fade-1">
                        <div class="ea-card-accent blue"></div>
                        <div class="ea-card-body">
                            <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
                                <div
                                    style="width:44px;height:44px;border-radius:var(--radius);background:linear-gradient(135deg,var(--primary-light),var(--primary-mid));display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:1.1rem;flex-shrink:0">
                                    <i class="fas fa-users"></i>
                                </div>
                                <h3
                                    style="font-family:var(--font);font-size:.98rem;font-weight:800;color:var(--gray-800);margin:0">
                                    @p.Nome</h3>
                                </div>
                                <span class="ea-meta-pill"><i class="fas fa-map-marker-alt"></i>@p.NomeCampus</span>
                            </div>
                            <div class="ea-card-footer">
                                <a href="/supervisao/editar/@p.Id" class="ea-action-btn primary" title="Editar"><i
                                    class="fas fa-edit"></i></a>
                                    <a asp-controller="Supervisao" asp-action="Excluir" asp-route-id="@p.Id"
                                       onclick="return confirm('Excluir a supervisão @p.Nome?')" class="ea-action-btn danger"
                                       title="Excluir"><i class="fas fa-trash"></i></a>
                                </div>
                            </div>
                        }
                    </div>
                }
        else
                {
                    <div class="ea-empty">
                        <i class="fas fa-sitemap"></i>
                        <h3>Nenhuma supervisão encontrada</h3>
                        <p>Tente outro termo ou cadastre uma nova supervisão.</p>
                    </div>
                }

                @if (ViewBag.Totalpaginas > 1)
                {
                    <div class="ea-pagination">
                        @if (ViewBag.NumeroPagina > 1)
                        {
                            <a class="ea-page-btn"
                                   href="@Url.Action("Index","Supervisao",new{Filtro=ViewBag.Filtro,Pagina=ViewBag.NumeroPagina-1})"><i
                                class="fas fa-chevron-left"></i></a>
                            }
                            <span class="ea-page-info">Página @ViewBag.NumeroPagina de @ViewBag.TotalPaginas</span>
                            @if (ViewBag.NumeroPagina < ViewBag.TotalPaginas)
                            {
                                <a class="ea-page-btn"
                                       href="@Url.Action("Index","Supervisao",new{Filtro=ViewBag.Filtro,Pagina=ViewBag.NumeroPagina+1})"><i
                                    class="fas fa-chevron-right"></i></a>
                                }
                            </div>
                        }

                    </div>
                </section>