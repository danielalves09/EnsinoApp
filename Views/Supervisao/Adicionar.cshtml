@model EnsinoApp.ViewModels.Supervisao.AdicionarSupervisaoViewModel
@{
    ViewData["Title"] = "Cadastrar Supervisão";
}

<section class="content-header" style="padding-bottom:0">
    <div class="container-fluid">
        <a asp-action="Index" class="ea-btn-back"><i class="fas fa-arrow-left"></i> Voltar para Supervisões</a>
        <div class="ea-page-title">
            <h1><i class="fas fa-sitemap" style="color:var(--primary);margin-right:8px"></i>Cadastrar Supervisão</h1>
            <p>Preencha os dados para criar um novo grupo de supervisão</p>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <form asp-action="Adicionar" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size:.8rem;margin-bottom:12px">
            </div>

            <div class="ea-form-card ea-fade ea-fade-1">
                <div class="ea-form-card-header">
                    <div class="ea-form-header-icon" style="background:var(--primary-light);color:var(--primary)"><i
                        class="fas fa-sitemap"></i></div>
                        <h3 class="ea-form-card-title">Dados da Supervisão</h3>
                    </div>
                    <div class="ea-form-card-body">
                        <div class="row g-3">
                            <div class="col-md-8">
                                <div class="ea-field-group">
                                    <label asp-for="Nome" class="ea-field-label"></label>
                                    <input asp-for="Nome" class="ea-field-control" placeholder="Nome da supervisão" />
                                    <span asp-validation-for="Nome" class="ea-field-error"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="ea-field-group">
                                    <label class="ea-field-label"><i class="fas fa-map-marker-alt"
                                                                         style="margin-right:3px"></i>Campus</label>
                                        <div class="ea-input-group">
                                            <input type="text" class="ea-field-control" placeholder="Selecione um campus"
                                                   id="NomeCampus" readonly />
                                            <input asp-for="IdCampus" type="hidden" id="IdCampus" />
                                            <button type="button" class="ea-btn-buscar" data-toggle="modal"
                                                    data-target="#ModalCampus">
                                                <i class="fas fa-search"></i> Buscar
                                            </button>
                                        </div>
                                        <span asp-validation-for="IdCampus" class="ea-field-error"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="ea-form-footer">
                            <a asp-action="Index" class="ea-btn-action cancel"><i class="fas fa-times"></i> Cancelar</a>
                            <button type="submit" class="ea-btn-action save"><i class="fas fa-save"></i> Salvar
                                Supervisão</button>
                            </div>
                        </div>

                    </form>
                </div>
            </section>

            <!-- ═══ MODAL CAMPUS ═══════════════════════════════ -->
            <div class="modal fade ea-modal" id="ModalCampus" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                <i class="fas fa-building" style="color:var(--primary);margin-right:6px"></i>Buscar Campus
                            </h5>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Fechar">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <input type="text" id="TxtFiltro" class="ea-modal-search" placeholder="Digite o nome do campus..." />
                            <div style="overflow-y:auto;max-height:300px">
                                <table class="ea-modal-table d-none" id="TbCampus">
                                    <thead>
                                        <tr>
                                            <th>Nome</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                                <div id="DivMensagem" class="ea-modal-empty d-none">Nenhum campus encontrado.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @section Scripts {
                <partial name="_ValidationScriptsPartial" />
                <script>
                                        function buscarCampus() {
                                            var f = $("#TxtFiltro").val().trim();
                                            if (!f.length) return;
                                            $.getJSON("/campus/buscar?filtro=" + f, function (r) {
                                                if (r.length) {
                                                    $("#TbCampus tbody").html(r.map(p =>
                                                        "<tr data-id='" + p.id + "'><td>" + p.nome + "</td></tr>"
                                                    ).join(""));
                                                    $("#TbCampus tbody tr").click(function () {
                                                        $("#IdCampus").val($(this).data("id"));
                                                        $("#NomeCampus").val($(this).find("td").text());
                                                        $("#ModalCampus").modal("hide");
                                                    });
                                                    $("#TbCampus").removeClass("d-none");
                                                    $("#DivMensagem").addClass("d-none");
                                                } else {
                                                    $("#TbCampus").addClass("d-none");
                                                    $("#DivMensagem").removeClass("d-none");
                                                }
                                            });
                                        }

                                        $("#TxtFiltro").on("keyup", function (e) { if (e.keyCode === 13) buscarCampus(); });
                                        $("#TxtFiltro").on("input", function () { buscarCampus(); });
                </script>
            }