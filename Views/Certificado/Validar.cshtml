@{
    Layout = null;
    ViewData["Title"] = "Validar Certificado";
}


<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

    <!-- jQuery + jQuery Mask -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>

    <style>
        body {
        background: linear-gradient(135deg, #f8f9fa, #e9ecef);
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
        }

        .card {
        border-radius: 12px;
        }

        .section-title {
        font-weight: 600;
        margin-top: 30px;
        margin-bottom: 15px;
        }

        .logo {
        font-size: 28px;
        font-weight: 700;
        color: #0d6efd;
        }
    </style>
</head>

<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <!-- Cabeçalho -->
                <div class="text-center mb-4">
                    <div class="logo mb-2"><i class="fas fa-heart"></i> EnsinoApp</div>
                    <div class="logo mb-2"><img class="rounded-circle" width="100px" src="~/images/logoVideira.png" />
                    </div>
                    <h4>Validação de Certificado</h4>
                    <p class="text-muted">
                        Preencha o código presente no seu certificado.
                    </p>
                </div>

                <!-- Card do Formulário -->
                <div class="card shadow">
                    <div class="card-body p-4">
                        @if (ViewBag.Mensagem != null)
                        {
                            <p>@ViewBag.Mensagem</p>
                        }

                        <form method="post">
                            <input type="text" class="form-control" name="codigo"
                                   placeholder="Digite o código do certificado" required />
                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-paper-plane"></i> Validar
                                </button>
                            </div>
                        </form>

                    </div>
                </div>

                <!-- Rodapé -->
                <div class="text-center mt-4 text-muted small">
                    © @DateTime.Now.Year - EnsinoApp • Todos os direitos reservados
                </div>

            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <partial name="_ValidationScriptsPartial" />




</body>

</html>