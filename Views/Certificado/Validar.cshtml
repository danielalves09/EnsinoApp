@{
    Layout = null;
    ViewData["Title"] = "Validar Certificado";
}

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnsinoApp</title>

    <!-- Nunito -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
          rel="stylesheet" />
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <!-- Bootstrap (apenas grid) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- CSS da página -->
    <link rel="stylesheet" href="~/css/validar-certificado.css" />
</head>

<body>
    <div class="val-page">

        <div class="val-card">

            <!-- Header azul -->
            <div class="val-card-header">
                <img src="~/images/logoVideira.png" class="val-logo" alt="Logo" />
                <h1><i class="fas fa-certificate" style="margin-right:7px;opacity:.85"></i>Validar Certificado</h1>
                <p>Digite o código presente no seu certificado para verificar sua autenticidade.</p>
            </div>

            <!-- Body -->
            <div class="val-card-body">

                @if (ViewBag.Mensagem != null)
                {
                    <!-- Detecta tipo de mensagem pelo conteúdo -->
                    string msg = ViewBag.Mensagem?.ToString() ?? "";
                    string resultClass = msg.ToLower().Contains("válido") || msg.ToLower().Contains("encontrado") &&
                    !msg.ToLower().Contains("não")
                        ? "success"
                        : msg.ToLower().Contains("não") || msg.ToLower().Contains("inválido") || msg.ToLower().Contains("erro")
                            ? "error"
                            : "warning";
                    string resultIcon = resultClass == "success" ? "fas fa-check"
                        : resultClass == "error" ? "fas fa-times"
                        : "fas fa-exclamation";

                    <div class="val-result @resultClass">
                        <div class="val-result-icon">
                            <i class="@resultIcon"></i>
                        </div>
                        <div>@ViewBag.Mensagem</div>
                    </div>
                }

                <form asp-action="Verificar" method="post">
                    <label class="val-label">
                        <i class="fas fa-hashtag" style="margin-right:4px"></i>Código do Certificado
                    </label>
                    <div class="val-input-wrap">
                        <input type="text" name="codigo" class="val-input" placeholder="Ex: CERT-2024-XXXXX"
                               autocomplete="off" required />
                        <i class="fas fa-qrcode val-input-icon"></i>
                    </div>

                    <button type="submit" class="val-btn">
                        <i class="fas fa-shield-alt"></i> Validar Certificado
                    </button>
                </form>

            </div>

        </div>

        <div class="val-footer">
            © @DateTime.Now.Year EnsinoApp · Todos os direitos reservados
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>

</html>