@model EnsinoApp.Models.Entities.Matricula
@{
    Layout = null;
    ViewData["Title"] = "Certificado Válido";
}

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnsinoApp</title>

    <!-- Nunito -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
          rel="stylesheet" />
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <!-- CSS compartilhado -->
    <link rel="stylesheet" href="~/css/validar-certificado.css" />
</head>

<body>
    <div class="val-page">

        <div class="cert-card">

            <!-- Topo verde -->
            <div class="cert-top">
                <img src="~/images/logoVideira.png" class="cert-logo" alt="Logo" />
                <div class="cert-check-icon">
                    <i class="fas fa-check"></i>
                </div>
                <h1>Certificado Válido!</h1>
                <p>
                    Emitido para <strong>@Model.Casal.NomeConjuge1</strong>
                    e <strong>@Model.Casal.NomeConjuge2</strong>
                </p>
            </div>

            <!-- Body -->
            <div class="cert-body">

                <!-- Detalhes -->
                <div class="cert-list">

                    <div class="cert-list-item">
                        <div class="cert-list-icon"><i class="fas fa-building"></i></div>
                        <div>
                            <p class="cert-list-label">Campus</p>
                            <p class="cert-list-value">@Model.Turma.Campus.Nome</p>
                        </div>
                    </div>

                    <div class="cert-list-item">
                        <div class="cert-list-icon"><i class="fas fa-graduation-cap"></i></div>
                        <div>
                            <p class="cert-list-label">Curso</p>
                            <p class="cert-list-value">@Model.Turma.Curso.Nome</p>
                        </div>
                    </div>

                    <div class="cert-list-item">
                        <div class="cert-list-icon"><i class="fas fa-calendar-check"></i></div>
                        <div>
                            <p class="cert-list-label">Data de Conclusão</p>
                            <p class="cert-list-value">@Model.DataConclusao</p>
                        </div>
                    </div>

                </div>

                <!-- Código de validação em destaque -->
                <div class="cert-code-wrap">
                    <div class="cert-code-icon"><i class="fas fa-shield-alt"></i></div>
                    <div>
                        <p class="cert-code-label">Código de Validação</p>
                        <p class="cert-code-value">@Model.CodigoValidacao</p>
                    </div>
                </div>

                <a href="/" class="btn-cert-home">
                    <i class="fas fa-arrow-left"></i> Voltar para a página inicial
                </a>

            </div>
        </div>

        <div class="val-footer" style="margin-top:20px">
            © @DateTime.Now.Year EnsinoApp · Todos os direitos reservados
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>