@{
    Layout = null;
    ViewData["Title"] = "Inscrições Fechadas";
}

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnsinoApp</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
          rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/inscricao-online.css" />
    <style>
            body {
                background: var(--gray-50, #f8fafc);
                font-family: 'Nunito', sans-serif;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 24px;
            }

            :root {
                --primary: #2563eb;
                --primary-light: #eff6ff;
                --gray-50: #f8fafc;
                --gray-100: #f1f5f9;
                --gray-200: #e2e8f0;
                --gray-400: #94a3b8;
                --gray-500: #64748b;
                --gray-700: #334155;
                --gray-800: #1e293b;
                --radius: 10px;
                --radius-lg: 14px;
            }

            .closed-card {
                background: #fff;
                border: 1px solid var(--gray-200);
                border-radius: var(--radius-lg);
                box-shadow: 0 4px 24px rgba(0, 0, 0, .07);
                max-width: 520px;
                width: 100%;
                overflow: hidden;
                text-align: center;
            }

            .closed-top {
                background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);
                padding: 36px 32px 28px;
            }

            .closed-top img {
                height: 48px;
                margin-bottom: 20px;
            }

            .closed-icon {
                width: 72px;
                height: 72px;
                border-radius: 50%;
                background: rgba(255, 255, 255, .15);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.8rem;
                color: #fff;
                margin: 0 auto 16px;
            }

            .closed-top h1 {
                font-size: 1.35rem;
                font-weight: 900;
                color: #fff;
                margin: 0 0 6px;
            }

            .closed-top p {
                font-size: .85rem;
                color: rgba(255, 255, 255, .75);
                margin: 0;
            }

            .closed-body {
                padding: 32px;
            }

            .closed-info {
                background: var(--primary-light);
                border: 1px solid #bfdbfe;
                border-radius: var(--radius);
                padding: 16px 20px;
                font-size: .85rem;
                color: #1e40af;
                font-weight: 600;
                margin-bottom: 24px;
                line-height: 1.6;
            }

            .closed-body p {
                font-size: .85rem;
                color: var(--gray-500);
                margin: 0 0 20px;
                line-height: 1.65;
            }

            .btn-back-home {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: var(--primary);
                color: #fff !important;
                border-radius: var(--radius);
                padding: 11px 22px;
                font-size: .88rem;
                font-weight: 700;
                text-decoration: none;
                transition: background .18s;
            }

            .btn-back-home:hover {
                background: #1d4ed8;
            }

            .closed-footer {
                font-size: .72rem;
                color: var(--gray-400);
                margin-top: 24px;
            }
    </style>
</head>

<body>
    <div class="closed-card">
        <div class="closed-top">
            
            <div class="closed-icon">
                <i class="fas fa-calendar-times"></i>
            </div>
            <h1>Inscrições Encerradas</h1>
            <p>Não há inscrições abertas no momento</p>
        </div>

        <div class="closed-body">
            <div class="closed-info">
                <i class="fas fa-info-circle" style="margin-right:6px"></i>
                As inscrições são abertas periodicamente para cada curso e campus.
                Fique atento às novidades nas redes sociais da CCVideira ou através dos comunicados enviados pelos
                líderes ou coordenadores.
            </div>

            <p>
                Quando houver um novo período de inscrições, você poderá acessar este formulário
                e realizar sua inscrição com facilidade. Entre em contato com o seu campus
                para mais informações sobre as próximas turmas.
            </p>

            <a href="/" class="btn-back-home">
                <i class="fas fa-arrow-left"></i> Voltar para a página inicial
            </a>

            <p class="closed-footer">© @DateTime.Now.Year EnsinoApp · CCVideira</p>
        </div>
    </div>
</body>

</html>
