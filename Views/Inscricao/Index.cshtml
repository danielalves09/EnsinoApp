@model EnsinoApp.ViewModels.Inscricao.InscricaoOnlineViewModel
@{
    Layout = null;
    ViewData["Title"] = "Inscrição Online";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnsinoApp</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <!-- Nunito -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
          rel="stylesheet" />
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- jQuery Mask -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>

    <!-- Estilos da página de inscrição -->
    <link rel="stylesheet" href="~/css/inscricao-online.css" />


</head>

<body>
    <div class="page-bg">
        <div class="page-content">

            <!-- Header -->
            <div class="insc-header">
                <img src="~/images/logoVideira.png" class="insc-logo-img" alt="Logo" />
                <h1
                    style="font-family:var(--font);font-size:1.5rem;font-weight:900;color:var(--gray-800);margin:0 0 6px;letter-spacing:-.3px">
                    Inscrição Online</h1>
                    <p style="font-size:.85rem;color:var(--gray-500);margin:0">Preencha os dados abaixo para realizar sua
                        inscrição nos cursos.</p>
                    </div>

                    <form asp-action="Cadastrar" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"
                             style="font-size:.8rem;margin-bottom:12px;background:#fff;border-radius:var(--radius);padding:12px 16px;border:1px solid #fca5a5">
                        </div>

                        <!-- Dados do Casal -->
                        <div class="insc-card">
                            <div class="insc-section-header">
                                <div class="insc-section-icon" style="background:#fff0f0;color:#f43f5e"><i
                                    class="fas fa-heart"></i></div>
                                    <h3 class="insc-section-title">Dados do Casal</h3>
                                </div>
                                <div class="insc-section-body">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="f-group">
                                                <label class="f-label">Homem — Nome</label>
                                                <input asp-for="NomeMarido" class="f-control" placeholder="Nome completo" />
                                                <span asp-validation-for="NomeMarido" class="f-error"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="f-group">
                                                <label class="f-label">Mulher — Nome</label>
                                                <input asp-for="NomeEsposa" class="f-control" placeholder="Nome completo" />
                                                <span asp-validation-for="NomeEsposa" class="f-error"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Contato -->
                            <div class="insc-card">
                                <div class="insc-section-header">
                                    <div class="insc-section-icon" style="background:var(--primary-light);color:var(--primary)"><i
                                        class="fas fa-phone-alt"></i></div>
                                        <h3 class="insc-section-title">Contato</h3>
                                    </div>
                                    <div class="insc-section-body">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <div class="f-group">
                                                    <label class="f-label">Homem — Telefone</label>
                                                    <input asp-for="TelefoneMarido" class="f-control telefone"
                                                           placeholder="(00) 00000-0000" />
                                                    <span asp-validation-for="TelefoneMarido" class="f-error"></span>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="f-group">
                                                    <label class="f-label">Mulher — Telefone</label>
                                                    <input asp-for="TelefoneEsposa" class="f-control telefone"
                                                           placeholder="(00) 00000-0000" />
                                                    <span asp-validation-for="TelefoneEsposa" class="f-error"></span>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="f-group">
                                                    <label class="f-label">Homem — Email</label>
                                                    <input asp-for="EmailMarido" class="f-control" placeholder="email@exemplo.com" />
                                                    <span asp-validation-for="EmailMarido" class="f-error"></span>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="f-group">
                                                    <label class="f-label">Mulher — Email</label>
                                                    <input asp-for="EmailEsposa" class="f-control" placeholder="email@exemplo.com" />
                                                    <span asp-validation-for="EmailEsposa" class="f-error"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Endereço -->
                                <div class="insc-card">
                                    <div class="insc-section-header">
                                        <div class="insc-section-icon" style="background:#f0fdf4;color:#16a34a"><i
                                            class="fas fa-map-marker-alt"></i></div>
                                            <h3 class="insc-section-title">Endereço</h3>
                                        </div>
                                        <div class="insc-section-body">
                                            <div class="row g-3">
                                                <div class="col-md-4">
                                                    <div class="f-group">
                                                        <label asp-for="Cep" class="f-label"></label>
                                                        <div class="f-cep-wrap">
                                                            <input asp-for="Cep" class="f-control" id="Cep" placeholder="00000-000" />
                                                            <i class="fas fa-spinner fa-spin f-cep-spin" id="cepSpin"></i>
                                                        </div>
                                                        <span asp-validation-for="Cep" class="f-error"></span>
                                                    </div>
                                                </div>
                                                <div class="col-md-8">
                                                    <div class="f-group">
                                                        <label asp-for="Rua" class="f-label"></label>
                                                        <input asp-for="Rua" class="f-control" id="Rua"
                                                               placeholder="Preenchido automaticamente pelo CEP" />
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <div class="f-group">
                                                        <label asp-for="Numero" class="f-label"></label>
                                                        <input asp-for="Numero" class="f-control" placeholder="Nº" />
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <div class="f-group">
                                                        <label asp-for="Complemento" class="f-label"></label>
                                                        <input asp-for="Complemento" class="f-control" placeholder="Apto, bloco..." />
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <div class="f-group">
                                                        <label asp-for="Bairro" class="f-label"></label>
                                                        <input asp-for="Bairro" class="f-control" id="Bairro" placeholder="Bairro" />
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <div class="f-group">
                                                        <label asp-for="Cidade" class="f-label"></label>
                                                        <input asp-for="Cidade" class="f-control" id="Cidade" placeholder="Cidade" />
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="f-group">
                                                        <label asp-for="Estado" class="f-label"></label>
                                                        <select asp-for="Estado" class="f-control" id="Estado">
                                                            <option value="">Selecione o Estado</option>
                                                            <option value="AC">AC</option>
                                                            <option value="AL">AL</option>
                                                            <option value="AP">AP</option>
                                                            <option value="AM">AM</option>
                                                            <option value="BA">BA</option>
                                                            <option value="CE">CE</option>
                                                            <option value="DF">DF</option>
                                                            <option value="ES">ES</option>
                                                            <option value="GO">GO</option>
                                                            <option value="MA">MA</option>
                                                            <option value="MT">MT</option>
                                                            <option value="MS">MS</option>
                                                            <option value="MG">MG</option>
                                                            <option value="PA">PA</option>
                                                            <option value="PB">PB</option>
                                                            <option value="PR">PR</option>
                                                            <option value="PE">PE</option>
                                                            <option value="PI">PI</option>
                                                            <option value="RJ">RJ</option>
                                                            <option value="RN">RN</option>
                                                            <option value="RS">RS</option>
                                                            <option value="RO">RO</option>
                                                            <option value="RR">RR</option>
                                                            <option value="SC">SC</option>
                                                            <option value="SP">SP</option>
                                                            <option value="SE">SE</option>
                                                            <option value="TO">TO</option>
                                                        </select>
                                                        <span asp-validation-for="Estado" class="f-error"></span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Informações Adicionais -->
                                    <div class="insc-card">
                                        <div class="insc-section-header">
                                            <div class="insc-section-icon" style="background:#f5f3ff;color:#7c3aed"><i
                                                class="fas fa-church"></i></div>
                                                <h3 class="insc-section-title">Informações Adicionais</h3>
                                            </div>
                                            <div class="insc-section-body">
                                                <div class="row g-3">
                                                    <div class="col-md-6">
                                                        <div class="f-group">
                                                            <label asp-for="IdCampus" class="f-label"></label>
                                                            @Html.DropDownList("IdCampus", (SelectList)ViewBag.Campuses, "Selecione um Campus",
                                                                new { @class = "f-control" })
                                                            <span asp-validation-for="IdCampus" class="f-error"></span>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="f-group">
                                                            <label asp-for="IdCurso" class="f-label"></label>
                                                            <select asp-for="IdCurso" class="f-control" id="IdCurso">
                                                                <option value="">Selecione um Campus primeiro</option>
                                                            </select>
                                                            <span asp-validation-for="IdCurso" class="f-error"></span>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="f-group">
                                                            <label class="f-label">Participa de GC?</label>
                                                            <select asp-for="ParticipaGC" class="f-control" id="ParticipaGC">
                                                                <option value="">Selecione</option>
                                                                <option value="true">Sim</option>
                                                                <option value="false">Não</option>
                                                            </select>
                                                            <span asp-validation-for="ParticipaGC" class="f-error"></span>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6" id="nomeGCContainer">
                                                        <div class="f-group">
                                                            <label asp-for="NomeGC" class="f-label"></label>
                                                            <input asp-for="NomeGC" class="f-control" placeholder="Nome do seu GC" />
                                                            <span asp-validation-for="NomeGC" class="f-error"></span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Submit -->
                                        <button type="submit" class="btn-submit">
                                            <i class="fas fa-paper-plane"></i> Enviar Inscrição
                                        </button>

                                    </form>

                                    <!-- Footer -->
                                    <div class="insc-footer">
                                        © @DateTime.Now.Year EnsinoApp · Todos os direitos reservados
                                    </div>

                                </div>
                            </div>

                            <!-- Scripts -->
                            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
                            <partial name="_ValidationScriptsPartial" />

                            <script>
                                $(document).ready(function () {

                                /* Máscara telefone */
                                $('.telefone').mask('(00) 00000-0000');

                                /* GC toggle */
                                function toggleNomeGC() {
                                $('#nomeGCContainer').toggle($('#ParticipaGC').val() === "true");
                                if ($('#ParticipaGC').val() !== "true") $('#NomeGC').val('');
                                }
                                toggleNomeGC();
                                $('#ParticipaGC').on('change', toggleNomeGC);

                                /* CEP autocomplete */
                                $('#Cep').on('blur', function () {
                                var cep = $(this).val().replace(/\D/g, '');
                                if (cep.length === 8) {
                                $('#cepSpin').show();
                                $.getJSON("https://viacep.com.br/ws/" + cep + "/json/", function (data) {
                                if (!("erro" in data)) {
                                $('#Rua').val(data.logradouro);
                                $('#Bairro').val(data.bairro);
                                $('#Cidade').val(data.localidade);
                                $('#Estado').val(data.uf);
                                }
                                }).always(function () { $('#cepSpin').hide(); });
                                }
                                });

                                /* Cursos por campus */
                                $('#IdCampus').on('change', function () {
                                var campusId = $(this).val();
                                var $curso = $('#IdCurso');
                                $curso.empty().append('<option value="">Carregando...</option>');
                                if (campusId) {
                                $.getJSON('@Url.Action("GetCursosPorCampus","Inscricao")', { campusId: campusId }, function (data) {
                                $curso.empty().append('<option value="">Selecione um Curso</option>');
                                $.each(data, function (i, c) {
                                $curso.append('<option value="' + c.id + '">' + c.nome + '</option>');
                                });
                                });
                                } else {
                                $curso.empty().append('<option value="">Selecione um Campus primeiro</option>');
                                }
                                });

                                });
                            </script>

                        </body>

                    </html>