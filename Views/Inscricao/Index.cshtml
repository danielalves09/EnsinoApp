@model EnsinoApp.ViewModels.Inscricao.InscricaoOnlineViewModel
@{
    Layout = null;
    ViewData["Title"] = "EnsinoApp | Inscrição Online";
}

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CCVideira</title>

    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
          rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    <link rel="stylesheet" href="~/css/inscricao-online.css" />
</head>

<body>

    <!-- ══ TOPBAR ═══════════════════════════════════════════════════ -->
    <header class="insc-topbar">
        <img src="~/images/logoVideira.png" alt="Logo CCVideira" />
        <span class="insc-topbar-title">Inscrição Online</span>
        <span class="insc-topbar-sub">CCVideira · Ensino</span>
    </header>

    <div class="insc-wrapper">

        <!-- ══ STEPPER ═════════════════════════════════════════════ -->
        <div class="insc-stepper" id="stepper">
            <div class="insc-step active" id="dot-1">
                <div class="step-dot" id="dot-num-1">1</div>
                <div class="step-info">
                    <p class="step-label">Passo 1</p>
                    <p class="step-value" id="dot-val-1">Escolha o campus</p>
                </div>
            </div>
            <div class="insc-step" id="dot-2">
                <div class="step-dot" id="dot-num-2">2</div>
                <div class="step-info">
                    <p class="step-label">Passo 2</p>
                    <p class="step-value" id="dot-val-2">Escolha o curso</p>
                </div>
            </div>
            <div class="insc-step" id="dot-3">
                <div class="step-dot" id="dot-num-3">3</div>
                <div class="step-info">
                    <p class="step-label">Passo 3</p>
                    <p class="step-value" id="dot-val-3">Seus dados</p>
                </div>
            </div>
        </div>

        <!-- ══ BREADCRUMB de escolhas anteriores ═══════════════════ -->
        <div class="insc-breadcrumb" id="breadcrumb">
            <span class="bc-item" id="bc-campus" onclick="goToStep(1)" style="display:none">
                <i class="fas fa-map-marker-alt"></i>
                <span id="bc-campus-nome"></span>
            </span>
            <span class="bc-sep" id="bc-sep-1" style="display:none">›</span>
            <span class="bc-item" id="bc-curso" onclick="goToStep(2)" style="display:none">
                <i class="fas fa-graduation-cap"></i>
                <span id="bc-curso-nome"></span>
            </span>
            <span class="bc-change" id="bc-change-hint"></span>
        </div>

        <!-- ══ PANE 1 — Seleção de Campus ═══════════════════════════ -->
        <div class="insc-pane active" id="pane-1">
            <h2 class="insc-section-title">Em qual campus você está?</h2>
            <p class="insc-section-sub">Selecione o campus da CCVideira onde deseja fazer o curso.</p>

            <div id="campus-loading" class="insc-loading">
                <i class="fas fa-circle-notch spin"></i> Carregando campus disponíveis…
            </div>
            <div id="campus-grid" class="campus-grid" style="display:none"></div>
            <div id="campus-empty" class="insc-empty" style="display:none">
                <i class="fas fa-map-marker-alt"></i>
                <p>Nenhum campus com inscrições abertas no momento.</p>
            </div>
        </div>

        <!-- ══ PANE 2 — Seleção de Curso ════════════════════════════ -->
        <div class="insc-pane" id="pane-2">
            <h2 class="insc-section-title">Em qual curso você deseja se inscrever?</h2>
            <p class="insc-section-sub" id="pane2-sub">Selecione um dos cursos disponíveis.</p>

            <div id="curso-loading" class="insc-loading" style="display:none">
                <i class="fas fa-circle-notch spin"></i> Carregando cursos…
            </div>
            <div id="curso-grid" class="curso-grid"></div>
            <div id="curso-empty" class="insc-empty" style="display:none">
                <i class="fas fa-graduation-cap"></i>
                <p>Nenhum curso disponível para inscrição neste campus.</p>
            </div>

            <div style="margin-top:20px">
                <button class="btn-step-back" onclick="goToStep(1)">
                    <i class="fas fa-arrow-left"></i> Trocar campus
                </button>
            </div>
        </div>

        <!-- ══ PANE 3 — Formulário ═══════════════════════════════════ -->
        <div class="insc-pane" id="pane-3">

            <h2 class="insc-section-title">Preencha seus dados</h2>
            <p class="insc-section-sub">Informe os dados do casal para finalizar a inscrição.</p>

            <form asp-controller="Inscricao" asp-action="Cadastrar" method="post" id="formInscricao">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"
                     style="font-size:.8rem;margin-bottom:12px;background:#fff;border-radius:var(--radius);padding:12px 16px;border:1px solid #fca5a5;display:none"
                     id="validation-summary"></div>

                <!-- Campos ocultos preenchidos pelo JS -->
                <input type="hidden" asp-for="IdCampus" id="hid-campus" />
                <input type="hidden" asp-for="IdCurso" id="hid-curso" />
                <input type="hidden" name="ParticipaGC" id="hid-participa-gc" value="false" />

                <!-- ── Dados do casal ──────────────────────────── -->
                <div class="insc-form-card">
                    <div class="insc-form-header">
                        <div class="insc-form-header-icon" style="background:#fff0f0;color:#f43f5e">
                            <i class="fas fa-heart"></i>
                        </div>
                        <h3>Dados do Casal</h3>
                    </div>
                    <div class="insc-form-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="f-group">
                                    <label class="f-label">Homem — Nome completo</label>
                                    <input asp-for="NomeMarido" class="f-control" placeholder="Nome completo" />
                                    <span asp-validation-for="NomeMarido" class="f-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="f-group">
                                    <label class="f-label">Mulher — Nome completo</label>
                                    <input asp-for="NomeEsposa" class="f-control" placeholder="Nome completo" />
                                    <span asp-validation-for="NomeEsposa" class="f-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── Contato ─────────────────────────────────── -->
                <div class="insc-form-card">
                    <div class="insc-form-header">
                        <div class="insc-form-header-icon" style="background:var(--primary-light);color:var(--primary)">
                            <i class="fas fa-phone-alt"></i>
                        </div>
                        <h3>Contato</h3>
                    </div>
                    <div class="insc-form-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="f-group">
                                    <label class="f-label">Homem — Telefone</label>
                                    <input asp-for="TelefoneMarido" class="f-control telefone"
                                           placeholder="(00) 00000-0000" />
                                    <span asp-validation-for="TelefoneMarido" class="f-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="f-group">
                                    <label class="f-label">Mulher — Telefone</label>
                                    <input asp-for="TelefoneEsposa" class="f-control telefone"
                                           placeholder="(00) 00000-0000" />
                                    <span asp-validation-for="TelefoneEsposa" class="f-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="f-group">
                                    <label class="f-label">Homem — Email</label>
                                    <input asp-for="EmailMarido" class="f-control" placeholder="email@exemplo.com" />
                                    <span asp-validation-for="EmailMarido" class="f-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="f-group">
                                    <label class="f-label">Mulher — Email</label>
                                    <input asp-for="EmailEsposa" class="f-control" placeholder="email@exemplo.com" />
                                    <span asp-validation-for="EmailEsposa" class="f-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── Endereço ────────────────────────────────── -->
                <div class="insc-form-card">
                    <div class="insc-form-header">
                        <div class="insc-form-header-icon" style="background:#f0fdf4;color:#16a34a">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <h3>Endereço</h3>
                    </div>
                    <div class="insc-form-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="f-group">
                                    <label asp-for="Cep" class="f-label"></label>
                                    <div class="f-cep-wrap">
                                        <input asp-for="Cep" class="f-control" id="Cep" placeholder="00000-000" />
                                        <i class="fas fa-spinner fa-spin f-cep-spin" id="cepSpin"></i>
                                    </div>
                                    <span asp-validation-for="Cep" class="f-error"></span>
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="f-group">
                                    <label asp-for="Rua" class="f-label"></label>
                                    <input asp-for="Rua" class="f-control" id="Rua"
                                           placeholder="Preenchido automaticamente pelo CEP" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="f-group">
                                    <label asp-for="Numero" class="f-label"></label>
                                    <input asp-for="Numero" class="f-control" placeholder="Nº" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="f-group">
                                    <label asp-for="Complemento" class="f-label"></label>
                                    <input asp-for="Complemento" class="f-control" placeholder="Apto, bloco…" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="f-group">
                                    <label asp-for="Bairro" class="f-label"></label>
                                    <input asp-for="Bairro" class="f-control" id="Bairro" placeholder="Bairro" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="f-group">
                                    <label asp-for="Cidade" class="f-label"></label>
                                    <input asp-for="Cidade" class="f-control" id="Cidade" placeholder="Cidade" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="f-group">
                                    <label asp-for="Estado" class="f-label"></label>
                                    <select asp-for="Estado" class="f-control" id="Estado">
                                        <option value="">Selecione o Estado</option>
                                        @foreach (var uf in
                                                                                                                                                                                                                                                                                                                                new[] { "AC", "AL", "AP", "AM", "BA", "CE", "DF", "ES", "GO", "MA", "MT", "MS",
                                  "MG", "PA", "PB", "PR", "PE", "PI", "RJ", "RN", "RS", "RO", "RR", "SC", "SP",
                  "SE", "TO" })
                                        {
                                            <option value="@uf">@uf</option>
                                        }
                                    </select>
                                    <span asp-validation-for="Estado" class="f-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── GC ──────────────────────────────────────── -->
                <div class="insc-form-card">
                    <div class="insc-form-header">
                        <div class="insc-form-header-icon" style="background:#f5f3ff;color:#7c3aed">
                            <i class="fas fa-users"></i>
                        </div>
                        <h3>Grupo de Crescimento</h3>
                    </div>
                    <div class="insc-form-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="f-group">
                                    <label class="f-label">Participa de GC?</label>
                                    <select id="ParticipaGC" class="f-control">
                                        <option value="">Selecione</option>
                                        <option value="true">Sim</option>
                                        <option value="false">Não</option>
                                    </select>
                                    <span asp-validation-for="ParticipaGC" class="f-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6" id="nomeGCContainer" style="display:none">
                                <div class="f-group">
                                    <label asp-for="NomeGC" class="f-label"></label>
                                    <input asp-for="NomeGC" class="f-control" placeholder="Nome do seu GC" />
                                    <span asp-validation-for="NomeGC" class="f-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── Botões ──────────────────────────────────── -->
                <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-top:4px">
                    <button type="button" class="btn-step-back" onclick="goToStep(2)">
                        <i class="fas fa-arrow-left"></i> Trocar curso
                    </button>
                    <div style="flex:1">
                        <button type="submit" class="btn-submit-insc" id="btn-submit">
                            <i class="fas fa-paper-plane"></i> Enviar Inscrição
                        </button>
                    </div>
                </div>

            </form>
        </div>

        <p class="insc-footer-txt">© @DateTime.Now.Year EnsinoApp · CCVideira · Todos os direitos reservados</p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        // ════════════════════════════════════════════════════════════════
        //  Estado global do wizard
        // ════════════════════════════════════════════════════════════════
        const state = {
        step: 1,
        campus: null,   // { id, nome, vagasRestantes }
        curso: null,   // { id, nome, descricao, licoes, vagasRestantes }
        };

        // ────────────────────────────────────────────────────────────────
        //  Navegação entre passos
        // ────────────────────────────────────────────────────────────────
        function goToStep(n) {
        // Só permite avançar se o passo anterior estiver completo
        if (n === 2 && !state.campus) return;
        if (n === 3 && (!state.campus || !state.curso)) return;

        state.step = n;

        // Panes
        document.querySelectorAll('.insc-pane').forEach(p => p.classList.remove('active'));
        document.getElementById('pane-' + n).classList.add('active');

        // Dots do stepper
        for (let i = 1; i <= 3; i++) {
        const dot = document.getElementById('dot-' + i);
        dot.classList.remove('active', 'done');
        if (i < n) dot.classList.add('done');
        if (i === n) dot.classList.add('active');

        // Ícone de check nos concluídos
        const num = document.getElementById('dot-num-' + i);
        num.innerHTML = i < n ? '<i class="fas fa-check" style="font-size:.75rem"></i>' : i;
        }

        // Scroll ao topo suave
        window.scrollTo({ top: 0, behavior: 'smooth' });

        updateBreadcrumb();
        updateStepValues();
        }

        // ────────────────────────────────────────────────────────────────
        //  Breadcrumb de seleções anteriores
        // ────────────────────────────────────────────────────────────────
        function updateBreadcrumb() {
        const bc = document.getElementById('breadcrumb');
        const bcCamp = document.getElementById('bc-campus');
        const bcCurs = document.getElementById('bc-curso');
        const sep = document.getElementById('bc-sep-1');
        const hint = document.getElementById('bc-change-hint');

        // Passo 1 — nada para mostrar ainda
        if (state.step === 1) {
        bc.classList.remove('visible');
        return;
        }

        bc.classList.add('visible');

        // Campus sempre visível a partir do passo 2
        if (state.campus) {
        document.getElementById('bc-campus-nome').textContent = state.campus.nome;
        bcCamp.style.display = 'flex';
        }

        // Curso só no passo 3
        if (state.step === 3 && state.curso) {
        document.getElementById('bc-curso-nome').textContent = state.curso.nome;
        bcCurs.style.display = 'flex';
        sep.style.display = 'inline';
        hint.textContent = '← Clique para alterar';
        } else {
        bcCurs.style.display = 'none';
        sep.style.display = 'none';
        hint.textContent = '← Clique para alterar o campus';
        }
        }

        function updateStepValues() {
        const v1 = document.getElementById('dot-val-1');
        const v2 = document.getElementById('dot-val-2');
        const v3 = document.getElementById('dot-val-3');

        v1.textContent = state.campus ? state.campus.nome : 'Escolha o campus';
        v2.textContent = state.curso ? state.curso.nome : 'Escolha o curso';
        v3.textContent = state.step === 3 ? 'Seus dados' : 'Seus dados';
        }

        // ────────────────────────────────────────────────────────────────
        //  Passo 1 — Carregar campus disponíveis
        // ────────────────────────────────────────────────────────────────
        function carregarCampus() {
        const grid = document.getElementById('campus-grid');
        const loading = document.getElementById('campus-loading');
        const empty = document.getElementById('campus-empty');

        loading.style.display = 'flex';
        grid.style.display = 'none';
        empty.style.display = 'none';

        $.getJSON('@Url.Action("GetCampusAbertos", "Inscricao")', function (data) {
        loading.style.display = 'none';

        if (!data || data.length === 0) {
        empty.style.display = 'block';
        return;
        }

        grid.innerHTML = '';
        data.forEach(function (c) {
        const card = document.createElement('div');
        card.className = 'campus-card';
        card.dataset.id = c.id;
        card.dataset.nome = c.nome;
        card.innerHTML = `
        <div class="campus-icon"><i class="fas fa-building"></i></div>
        <div>
        <p class="campus-card-name">${c.nome}</p>
        <p class="campus-vagas">
        <span>${c.vagasRestantes}</span> vaga(s) disponível(is)
        </p>
        </div>`;

        card.addEventListener('click', function () {
        selecionarCampus(c.id, c.nome, c.vagasRestantes);
        });

        grid.appendChild(card);
        });

        grid.style.display = 'grid';
        }).fail(function () {
        loading.style.display = 'none';
        empty.style.display = 'block';
        });
        }

        function selecionarCampus(id, nome, vagasRestantes) {
        state.campus = { id, nome, vagasRestantes };
        state.curso = null; // reset curso ao trocar campus

        // Feedback visual no card selecionado
        document.querySelectorAll('.campus-card').forEach(c => c.classList.remove('selected'));
        const sel = document.querySelector(`.campus-card[data-id="${id}"]`);
        if (sel) sel.classList.add('selected');

        // Preenche campo oculto
        document.getElementById('hid-campus').value = id;

        // Atualiza subtítulo do passo 2
        document.getElementById('pane2-sub').textContent =
        'Cursos disponíveis em ' + nome + ':';

        // Avança automaticamente após pequena pausa visual
        setTimeout(function () {
        carregarCursos(id);
        goToStep(2);
        }, 180);
        }

        // ────────────────────────────────────────────────────────────────
        //  Passo 2 — Carregar cursos disponíveis para o campus
        // ────────────────────────────────────────────────────────────────
        function carregarCursos(campusId) {
        const grid = document.getElementById('curso-grid');
        const loading = document.getElementById('curso-loading');
        const empty = document.getElementById('curso-empty');

        loading.style.display = 'flex';
        grid.innerHTML = '';
        grid.style.display = 'none';
        empty.style.display = 'none';

        $.getJSON('@Url.Action("GetCursosAbertos", "Inscricao")', { campusId: campusId }, function (data) {
        loading.style.display = 'none';

        if (!data || data.length === 0) {
        empty.style.display = 'block';
        return;
        }

        data.forEach(function (c, idx) {
        const licoesTags = (c.licoes || []).slice(0, 8).map(l =>
        `<span class="licao-tag">${escapeHtml(l)}</span>`
        ).join('');

        const maisLicoes = c.licoes && c.licoes.length > 8
        ? `<span class="licao-tag">+${c.licoes.length - 8} mais</span>`
        : '';

        const card = document.createElement('div');
        card.className = 'curso-card';
        card.innerHTML = `
        <div class="curso-card-top">
        <div class="curso-card-icon">
        <i class="fas fa-graduation-cap"></i>
        </div>
        <p class="curso-card-name">${escapeHtml(c.nome)}</p>
        <p class="curso-card-vagas">
        <i class="fas fa-ticket-alt" style="margin-right:4px"></i>
        ${c.vagasRestantes} vaga(s) restante(s)
        </p>
        </div>
        <div class="curso-card-body">
        <p class="curso-desc">${escapeHtml(c.descricao || '')}</p>
        ${licoesTags || maisLicoes ? `
        <div>
        <p class="curso-licoes-title"><i class="fas fa-list" style="margin-right:4px"></i>Temas abordados</p>
        <div class="curso-licoes-list">${licoesTags}${maisLicoes}</div>
        </div>` : ''}
        </div>
        <div class="curso-card-footer">
        <span style="font-size:.75rem;color:var(--gray-400);font-weight:600">
        <i class="fas fa-book-open" style="margin-right:4px"></i>
        ${(c.licoes || []).length} lição(ões)
        </span>
        <button class="btn-selecionar">
        Selecionar <i class="fas fa-arrow-right"></i>
        </button>
        </div>`;

        card.querySelector('.btn-selecionar').addEventListener('click', function (e) {
        e.stopPropagation();
        selecionarCurso(c.id, c.nome, c.descricao, c.licoes, c.vagasRestantes);
        });

        card.addEventListener('click', function () {
        selecionarCurso(c.id, c.nome, c.descricao, c.licoes, c.vagasRestantes);
        });

        grid.appendChild(card);
        });

        grid.style.display = 'grid';
        }).fail(function () {
        loading.style.display = 'none';
        empty.style.display = 'block';
        });
        }

        function selecionarCurso(id, nome, descricao, licoes, vagasRestantes) {
        state.curso = { id, nome, descricao, licoes, vagasRestantes };

        // Feedback visual
        document.querySelectorAll('.curso-card').forEach(c => c.classList.remove('selected'));
        // Identifica o card pelo índice que contém o nome (simplificado)
        document.querySelectorAll('.curso-card').forEach(function (c) {
        if (c.querySelector('.curso-card-name') &&
        c.querySelector('.curso-card-name').textContent.trim() === nome) {
        c.classList.add('selected');
        }
        });

        // Preenche campo oculto
        document.getElementById('hid-curso').value = id;

        setTimeout(function () {
        goToStep(3);
        }, 180);
        }

        // ────────────────────────────────────────────────────────────────
        //  Utilidades
        // ────────────────────────────────────────────────────────────────
        function escapeHtml(str) {
        if (!str) return '';
        return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
        }

        // ────────────────────────────────────────────────────────────────
        //  GC toggle
        // ────────────────────────────────────────────────────────────────
        function toggleGC() {
        const val = document.getElementById('ParticipaGC').value;
        const container = document.getElementById('nomeGCContainer');
        const hidGC = document.getElementById('hid-participa-gc');

        container.style.display = val === 'true' ? 'block' : 'none';
        hidGC.value = val === 'true' ? 'true' : 'false';

        if (val !== 'true') {
        document.getElementById('NomeGC').value = '';
        }
        }

        // ────────────────────────────────────────────────────────────────
        //  CEP autocomplete
        // ────────────────────────────────────────────────────────────────
        function buscarCep() {
        var cep = document.getElementById('Cep').value.replace(/\D/g, '');
        if (cep.length !== 8) return;

        document.getElementById('cepSpin').style.display = 'block';
        $.getJSON('https://viacep.com.br/ws/' + cep + '/json/', function (data) {
        if (!data.erro) {
        document.getElementById('Rua').value = data.logradouro || '';
        document.getElementById('Bairro').value = data.bairro || '';
        document.getElementById('Cidade').value = data.localidade || '';
        document.getElementById('Estado').value = data.uf || '';
        }
        }).always(function () {
        document.getElementById('cepSpin').style.display = 'none';
        });
        }

        // ────────────────────────────────────────────────────────────────
        //  Submit — garante hidden fields antes de enviar
        // ────────────────────────────────────────────────────────────────
        document.getElementById('formInscricao').addEventListener('submit', function (e) {
        if (!state.campus || !state.curso) {
        e.preventDefault();
        alert('Selecione o campus e o curso antes de enviar.');
        goToStep(1);
        return;
        }
        document.getElementById('hid-campus').value = state.campus.id;
        document.getElementById('hid-curso').value = state.curso.id;
        });

        // ────────────────────────────────────────────────────────────────
        //  Inicialização
        // ────────────────────────────────────────────────────────────────
        $(document).ready(function () {
        // Máscara telefone
        $('.telefone').mask('(00) 00000-0000');

        // GC
        $('#ParticipaGC').on('change', toggleGC);

        // CEP
        $('#Cep').on('blur', buscarCep);

        // Carrega campus ao iniciar
        carregarCampus();

        @if (ViewBag.ErroValidacao != null)
        {
            // Se o formulário voltou com erro de servidor, vai direto pro passo 3
            <text>
                // Recupera o estado salvo na sessão/TempData se disponível
                state.campus = {id: @(ViewBag.IdCampus ?? 0), nome: '@(ViewBag.NomeCampus ?? "")', vagasRestantes: 0 };
                state.curso  = {id: @(ViewBag.IdCurso ?? 0), nome: '@(ViewBag.NomeCurso ?? "")', vagasRestantes: 0 };
                document.getElementById('hid-campus').value = state.campus.id;
                document.getElementById('hid-curso').value  = state.curso.id;
                goToStep(3);
            </text>
        }
        });
    </script>

</body>

</html>
