@model EnsinoApp.ViewModels.Inscricao.ConfirmacaoInscricaoViewModel;
@{
    Layout = null;
    ViewData["Title"] = "Inscrição Recebida";
}

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

    <style>
                                body {
                                    background: linear-gradient(135deg, #f8f9fa, #e9ecef);
                                    min-height: 100vh;
                                    font-family: 'Segoe UI', sans-serif;
                                }

                                .card {
                                    border-radius: 12px;
                                    border: none;
                                    padding: 40px 30px;
                                }

                                .logo {
                                    font-size: 28px;
                                    font-weight: 700;
                                    color: #0d6efd;
                                }

                                .icon-success {
                                    font-size: 60px;
                                    color: #198754;
                                }

                                .message-title {
                                    font-weight: 600;
                                    margin-top: 20px;
                                    font-size: 24px;
                                }

                                .message-subtitle {
                                    font-size: 16px;
                                    margin-top: 10px;
                                    color: #6c757d;
                                }

                                .btn-home {
                                    margin-top: 30px;
                                }
    </style>
</head>

<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-6">

                <!-- Card de Confirmação -->
                <div class="card shadow text-center">
                    <div class="card-body">

                        <div class="logo mb-3">
                            <i class="fas fa-heart"></i> EnsinoApp
                        </div>

                        <div class="icon-success mb-3">
                            <i class="fas fa-check-circle"></i>
                        </div>

                        <div class="message-title">Inscrição Recebida com Sucesso!</div>
                        <div class="message-subtitle mb-4">
                            Obrigado, @Model.NomeMarido e @Model.NomeEsposa.<br />
                            Sua inscrição para os cursos foi registrada.
                            Entraremos em contato para confirmar a matrícula.
                        </div>

                        <ul class="list-group list-group-flush text-start mb-4">
                            <li class="list-group-item"><strong>Campus:</strong> @Model.NomeCampus</li>
                            <li class="list-group-item"><strong>Curso:</strong> @Model.NomeCurso</li>
                            <li class="list-group-item"><strong>Participa de GC:</strong> @(Model.ParticipaGC ? "Sim" :
                                                                                                                                                                                                                                "Não")</li>
                                @if (Model.ParticipaGC)
                                {
                                    <li class="list-group-item"><strong>Nome do GC:</strong> @Model.NomeGC</li>
                                }
                                <li class="list-group-item"><strong>Data da Inscrição:</strong>
                                    @Model.DataInscricao.ToString("dd/MM/yyyy")</li>
                                </ul>

                                <a href="/" class="btn btn-primary btn-lg btn-home">
                                    <i class="fas fa-home"></i> Voltar para a página inicial
                                </a>

                            </div>
                        </div>

                        <!-- Rodapé -->
                        <div class="text-center mt-4 text-muted small">
                            © @DateTime.Now.Year - EnsinoApp • Todos os direitos reservados
                        </div>

                    </div>
                </div>
            </div>

            <!-- Bootstrap -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        </body>

    </html>