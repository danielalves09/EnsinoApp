@model EnsinoApp.ViewModels.Inscricao.ConfirmacaoInscricaoViewModel
@{
    Layout = null;
    ViewData["Title"] = "Inscrição Recebida";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnsinoApp</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <!-- Nunito -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
          rel="stylesheet" />
    <!-- CSS compartilhado -->
    <link rel="stylesheet" href="~/css/inscricao-online.css" />
</head>

<body>
    <div class="confirm-wrap">
        <div class="confirm-card">

            <!-- Topo verde -->
            <div class="confirm-top">
                <div class="confirm-logo">
                    <img src="~/images/logoVideira.png" alt="Logo" />
                    <span>EnsinoApp</span>
                </div>
                <div class="confirm-icon">
                    <i class="fas fa-check"></i>
                </div>
                <h1>Inscrição Recebida!</h1>
                <p>Sua inscrição foi registrada com sucesso.</p>
            </div>

            <!-- Body -->
            <div class="confirm-body">

                <div class="confirm-names">
                    <p>
                        Obrigado, <strong>@Model.NomeMarido</strong> e <strong>@Model.NomeEsposa</strong>.<br />
                        Entraremos em contato para confirmar a matrícula.
                    </p>
                </div>

                <div class="confirm-list">

                    <div class="confirm-list-item">
                        <div class="confirm-list-icon"><i class="fas fa-building"></i></div>
                        <div>
                            <p class="confirm-list-label">Campus</p>
                            <p class="confirm-list-value">@Model.NomeCampus</p>
                        </div>
                    </div>

                    <div class="confirm-list-item">
                        <div class="confirm-list-icon"><i class="fas fa-graduation-cap"></i></div>
                        <div>
                            <p class="confirm-list-label">Curso</p>
                            <p class="confirm-list-value">@Model.NomeCurso</p>
                        </div>
                    </div>

                    <div class="confirm-list-item">
                        <div class="confirm-list-icon"
                             style="background:@(Model.ParticipaGC ? "var(--success-light)" : "var(--gray-100)");color:@(Model.ParticipaGC ? "var(--success)" : "var(--gray-500)")">
                            <i class="fas fa-users"></i>
                        </div>
                        <div>
                            <p class="confirm-list-label">Participa de GC</p>
                            <p class="confirm-list-value">@(Model.ParticipaGC ? "Sim" : "Não")</p>
                        </div>
                    </div>

                    @if (Model.ParticipaGC)
                    {
                        <div class="confirm-list-item">
                            <div class="confirm-list-icon"><i class="fas fa-sitemap"></i></div>
                            <div>
                                <p class="confirm-list-label">Nome do GC</p>
                                <p class="confirm-list-value">@Model.NomeGC</p>
                            </div>
                        </div>
                    }

                    <div class="confirm-list-item">
                        <div class="confirm-list-icon"><i class="fas fa-calendar-alt"></i></div>
                        <div>
                            <p class="confirm-list-label">Data da Inscrição</p>
                            <p class="confirm-list-value">@Model.DataInscricao.ToString("dd/MM/yyyy")</p>
                        </div>
                    </div>

                </div>

                <a href="/" class="btn-confirm-home">
                    <i class="fas fa-arrow-left"></i> Voltar para a página inicial
                </a>

            </div>

        </div>

        <div class="insc-footer" style="position:absolute;bottom:20px;left:0;right:0">
            © @DateTime.Now.Year EnsinoApp · Todos os direitos reservados
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>