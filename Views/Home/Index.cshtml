@model EnsinoApp.ViewModels.Home.DashboardViewModel
@using System.Text.Json
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@{
    ViewData["Title"] = "Home";
}

<!-- Content Header (Page header) -->
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Bem Vindo, @ViewBag.NomeUsuario!</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#">Home</a></li>
                    <li class="breadcrumb-item active">Visão geral</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        <!-- Small boxes -->
        <div class="row">
            <div class="col-lg-3 col-6">
                <div class="small-box card-outline card-info shadow">
                    <div class="inner">
                        <h3>@ViewBag.QtdCampus</h3>
                        <p>Campus</p>
                    </div>
                    <div class="icon"><i class="fas fa-building nav-icon"></i></div>
                    <a href="/campus/" class="small-box-footer bg-light">Gerenciar <i
                        class="fas fa-arrow-circle-right"></i></a>
                    </div>
                </div>
                <div class="col-lg-3 col-6">
                    <div class="small-box card-outline card-success shadow">
                        <div class="inner">
                            <h3>@ViewBag.QtdSupervisoes</h3>
                            <p>Supervisões</p>
                        </div>
                        <div class="icon"><i class="fas fa-users nav-icon"></i></div>
                        <a href="/supervisao/" class="small-box-footer bg-light">Gerenciar <i
                            class="fas fa-arrow-circle-right"></i></a>
                        </div>
                    </div>
                    <div class="col-lg-3 col-6">
                        <div class="small-box card-outline card-warning shadow">
                            <div class="inner">
                                <h3>@ViewBag.QtdLideres</h3>
                                <p>Líderes de curso</p>
                            </div>
                            <div class="icon"><i class="fas fa-user nav-icon"></i></div>
                            <a href="/usuarios/" class="small-box-footer bg-light">Gerenciar <i
                                class="fas fa-arrow-circle-right"></i></a>
                            </div>
                        </div>
                        <div class="col-lg-3 col-6">
                            <div class="small-box card-outline card-danger shadow">
                                <div class="inner">
                                    <h3>@ViewBag.QtdCasaisMatriculados</h3>
                                    <p>Casais Matriculados</p>
                                </div>
                                <div class="icon"><i class="fas fa-graduation-cap nav-icon"></i></div>
                                <a href="/matricula/" class="small-box-footer bg-light">Gerenciar <i
                                    class="fas fa-arrow-circle-right"></i></a>
                                </div>
                            </div>
                        </div>

                        <!-- Info Boxes -->
                        <div class="row">
                            <div class="col-md-3 col-sm-6 col-12">
                                <div class="info-box shadow">
                                    <span class="info-box-icon bg-info"><i class="fas fa-users"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Casais Cadastrados</span>
                                        <span class="info-box-number">@Model.TotalCasais</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6 col-12">
                                <div class="info-box shadow">
                                    <span class="info-box-icon bg-primary"><i class="fas fa-file-signature"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Inscrições Realizadas</span>
                                        <span class="info-box-number">@Model.TotalInscricoes</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6 col-12">
                                <div class="info-box shadow">
                                    <span class="info-box-icon bg-success"><i class="fas fa-user-graduate"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Matrículas Ativas</span>
                                        <span class="info-box-number">@Model.MatriculasAtivas</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6 col-12">
                                <div class="info-box shadow">
                                    <span class="info-box-icon bg-dark"><i class="fas fa-layer-group"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Turmas Em Andamento</span>
                                        <span class="info-box-number">@Model.TurmasAtivas</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Gráficos -->
                        <div class="row">
                            <!-- Inscrições por mês -->
                            <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
                                <div class="card shadow-sm h-100">
                                    <div class="card-header">📅 Inscrições por Mês</div>
                                    <div class="card-body">
                                        <canvas id="inscricoesPorMesChart"></canvas>
                                    </div>
                                </div>
                            </div>

                            <!-- Matrículas por curso -->
                            <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
                                <div class="card shadow-sm h-100">
                                    <div class="card-header">🎓 Matrículas por Curso</div>
                                    <div class="card-body">
                                        <canvas id="matriculasPorCursoChart"></canvas>
                                    </div>
                                </div>
                            </div>

                            <!-- Casais por campus -->
                            <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
                                <div class="card shadow-sm h-100">
                                    <div class="card-header">🏫 Casais por Campus</div>
                                    <div class="card-body">
                                        <canvas id="casaisPorCampusChart"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                @section Scripts {
                    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
                    <script>
                        // --- Inscrições por mês ---
                        var ctxInscricoes = document.getElementById('inscricoesPorMesChart').getContext('2d');
                        new Chart(ctxInscricoes, {
                        type: 'line',
                        data: {
                        labels: @Html.Raw(JsonSerializer.Serialize(Model.InscricoesPorMes.Select(x => x.MesAno))),
                        datasets: [{
                        label: 'Inscrições',
                        data: @Html.Raw(JsonSerializer.Serialize(Model.InscricoesPorMes.Select(x => x.Total))),
                        borderColor: 'rgba(54, 162, 235, 1)',
                        backgroundColor: 'rgba(54, 162, 235, 0.2)',
                        fill: true,
                        tension: 0.3
                        }]
                        },
                        options: { responsive: true, plugins: { legend: { display: false } } }
                        });

                        // --- Matrículas por curso ---
                        var ctxMatriculas = document.getElementById('matriculasPorCursoChart').getContext('2d');
                        new Chart(ctxMatriculas, {
                        type: 'bar',
                        data: {
                        labels: @Html.Raw(JsonSerializer.Serialize(Model.MatriculasPorCurso.Select(x => x.Curso))),
                        datasets: [{
                        label: 'Matrículas Ativas',
                        data: @Html.Raw(JsonSerializer.Serialize(Model.MatriculasPorCurso.Select(x => x.Total))),
                        backgroundColor: 'rgba(40, 167, 69, 0.7)',
                        borderColor: 'rgba(40, 167, 69, 1)',
                        borderWidth: 1
                        }]
                        },
                        options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
                        });

                        // --- Casais por campus ---
                        var ctxCasais = document.getElementById('casaisPorCampusChart').getContext('2d');
                        new Chart(ctxCasais, {
                        type: 'doughnut',
                        data: {
                        labels: @Html.Raw(JsonSerializer.Serialize(Model.CasaisPorCampus.Select(x => x.Campus))),
                        datasets: [{
                        label: 'Casais',
                        data: @Html.Raw(JsonSerializer.Serialize(Model.CasaisPorCampus.Select(x => x.Total))),
                        backgroundColor: ['#FFC107', '#17A2B8', '#6F42C1', '#DC3545', '#28A745']
                        }]
                        },
                        options: { responsive: true }
                        });
                    </script>
                }