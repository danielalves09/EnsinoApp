@model IEnumerable<EnsinoApp.Models.Entities.RelatorioSemanal>

@{
    ViewData["Title"] = "Relatórios";
}

<h2 class="mb-4">Histórico de Relatórios</h2>

<table class="table table-striped table-bordered">
    <thead class="table-light">
        <tr>
            <th>Data</th>
            <th>Lição</th>
            <th>Casal</th>
            <th>Presença</th>
            <th>Observações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.DataRegistro.ToString("dd/MM/yyyy")</td>
                <td>@r.Licao.Titulo</td>
                <td>@r.Matricula.Casal.NomeConjuge1 e @r.Matricula.Casal.NomeConjuge2</td>
                <td>@r.Presenca</td>
                <td>@r.Observacoes</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Turma" asp-route-id="@Model.First().Matricula.IdTurma" class="btn btn-secondary">
    Voltar para Turma
</a>