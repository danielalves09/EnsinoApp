@using EnsinoApp.Models.Enums
@model EnsinoApp.ViewModels.Turmas.TurmaDashboardViewModel
@{
    ViewData["Title"] = "Gerenciar Turma";
}

<section class="content-header" style="padding-bottom:0">
    <div class="container-fluid">
        <a asp-action="Index" class="ea-btn-back"><i class="fas fa-arrow-left"></i> Voltar para Turmas</a>
        <div class="ea-welcome">
            <div class="ea-welcome-text">
                <h1><i class="fas fa-graduation-cap" style="margin-right:8px;opacity:.85"></i>@Model.NomeCurso</h1>
                <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:6px">
                    <span
                        style="display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,.15);border-radius:20px;padding:3px 10px;font-size:.75rem;color:rgba(255,255,255,.9);font-weight:600">
                        <i class="fas fa-map-marker-alt"></i>@Model.NomeCampus
                    </span>
                    <span
                        style="display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,.15);border-radius:20px;padding:3px 10px;font-size:.75rem;color:rgba(255,255,255,.9);font-weight:600">
                        <i class="fas fa-user-tie"></i>@Model.NomeLider
                    </span>
                    <span
                        style="display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,.15);border-radius:20px;padding:3px 10px;font-size:.75rem;color:rgba(255,255,255,.9);font-weight:600">
                        <i class="fas fa-calendar"></i>@Model.DiaSemanaLabel
                    </span>
                </div>
            </div>
            <div>
                <img src="@(string.IsNullOrWhiteSpace(Model.imgLider)?"/images/avatar-default.jpg":Model.imgLider)"
                     alt="Líder"
                     style="width:60px;height:60px;border-radius:50%;object-fit:cover;border:2px solid var(--gray-200);flex-shrink:0" />
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

      
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;margin-bottom:20px">

        
            <div class="ea-form-card ea-fade ea-fade-1">
                <div class="ea-form-card-header">
                    <div class="ea-form-header-icon" style="background:var(--primary-light);color:var(--primary)">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3 class="ea-form-card-title">Casais Matriculados</h3>
                </div>
                <div class="ea-form-card-body" style="display:flex;align-items:center;gap:14px">
                    <span
                    style="font-family:var(--font);font-size:2.8rem;font-weight:900;color:var(--gray-800);line-height:1;letter-spacing:-1px">@Model.CasaisMatriculados.Count</span>
                    <span style="font-size:.78rem;color:var(--gray-400);font-weight:600">casais<br>matriculados</span>
                </div>
            </div>

            
            <div class="ea-chart-card ea-fade ea-fade-2">
                <div class="ea-chart-header">
                    <div class="ea-chart-header-icon" style="background:var(--success-light);color:var(--success)">
                        <i class="fas fa-chart-bar"></i>
                    </div>
                    <h3 class="ea-chart-title">Progresso de Presença</h3>
                </div>
                <div class="ea-chart-body" style="padding:12px 14px">
                    <canvas id="chartPresenca" style="max-height:160px"></canvas>
                </div>
            </div>

            
            <div class="ea-form-card ea-fade ea-fade-3">
                <div class="ea-form-card-header">
                    <div class="ea-form-header-icon" style="background:var(--warning-light);color:var(--warning)">
                        <i class="fas fa-info-circle"></i>
                    </div>
                    <h3 class="ea-form-card-title">Status da Turma</h3>
                </div>
                <div class="ea-form-card-body" style="display:flex;flex-direction:column;gap:10px">
                    @{
                        string sb = "acomecar", sl = "A começar";
                        if (Model.Status == StatusTurma.EmAndamento) { sb = "emandamento"; sl = "Em andamento"; }
                        else if (Model.Status == StatusTurma.Concluida) { sb = "concluida"; sl = "Concluída"; }
                        else if (Model.Status == StatusTurma.Cancelada) { sb = "cancelada"; sl = "Cancelada"; }
                    }
                    <span class="ea-badge @sb">@sl</span>
                    <div>
                        <p style="font-size:.78rem;color:var(--gray-500);margin:0 0 3px"><strong>Início:</strong>
                            @Model.DataInicio.ToShortDateString()</p>
                            <p style="font-size:.78rem;color:var(--gray-500);margin:0"><strong>Fim:</strong>
                                @Model.DataFim.ToShortDateString()</p>
                            </div>
                            <div>
                                <div class="ea-progress-track">
                                    <div class="ea-progress-fill @(Model.Progresso >= 100 ? "complete" : "")"
                                         style="width:@(Math.Min(Model.Progresso,100))%"></div>
                                </div>
                                <div class="ea-progress-label" style="text-align:right;margin-top:3px">@Model.Progresso%
                                    concluído</div>
                                </div>
                            </div>
                        </div>

                    </div>

                    
                    @if (Model.Status == StatusTurma.Acomecar)
                    {
                        <div style="background:linear-gradient(90deg,var(--info-light) 0%,#fff 100%);
                            border:1.5px solid #93c5fd;border-left:4px solid var(--info);
                            border-radius:var(--radius-lg);padding:18px 22px;
                            display:flex;align-items:center;gap:16px;margin-bottom:20px;
                            flex-wrap:wrap" class="ea-fade">
                            <div style="width:50px;height:50px;border-radius:50%;
                                background:var(--info-light);display:flex;align-items:center;
                                justify-content:center;flex-shrink:0;border:1.5px solid #93c5fd">
                                <i class="fas fa-play-circle" style="font-size:1.4rem;color:var(--info)"></i>
                            </div>
                            <div style="flex:1;min-width:200px">
                                <p
                                    style="font-family:var(--font);font-size:.95rem;font-weight:800;color:var(--gray-800);margin:0 0 3px">
                                    Esta turma ainda não foi iniciada
                                </p>
                                <p style="font-size:.8rem;color:var(--gray-500);margin:0;line-height:1.5">
                                    Clique em <strong>Iniciar Turma</strong> para alterar o status para
                                    <span
                                        style="background:var(--purple-light);color:var(--purple);border-radius:20px;padding:1px 8px;font-size:.72rem;font-weight:700">Em
                                        Andamento</span>
                                        e habilitar o lançamento de relatórios semanais.
                                    </p>
                                </div>
                                <form asp-action="IniciarTurma" method="post" style="display:contents">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit"
                                            onclick="return confirm('Deseja realmente iniciar esta turma? O status será alterado para Em Andamento.')"
                                            style="display:inline-flex;align-items:center;justify-content:center;
                                        gap:8px;background:var(--info);color:#fff;border:none;
                                        border-radius:var(--radius);padding:11px 22px;
                                        font-size:.85rem;font-weight:700;cursor:pointer;
                                        font-family:var(--font);white-space:nowrap;
                                        transition:background .18s;flex-shrink:0">
                                        <i class="fas fa-play"></i> Iniciar Turma
                                    </button>
                                </form>
                            </div>
                        }

                       
                        <div class="ea-toolbar ea-fade">
                            <a class="ea-btn-new" href="@Url.Action("GerarCertificados","Lider")" style="background:var(--primary)">
                                <i class="fas fa-award"></i> Gerar Certificados
                                @if (Model.TotalCertificadosPendentes > 0)
                                {
                                    <span
                                    style="background:rgba(255,255,255,.25);color:#fff;font-size:.68rem;font-weight:800;border-radius:20px;padding:1px 7px">@Model.TotalCertificadosPendentes</span>
                                }
                            </a>
                            <a asp-action="Relatorios" asp-route-idTurma="@Model.Id"
                               style="display:inline-flex;align-items:center;gap:6px;background:var(--info-light);color:var(--info);border:1px solid #a5f3fc;border-radius:var(--radius);padding:9px 16px;font-size:.82rem;font-weight:700;text-decoration:none">
                                <i class="fas fa-search"></i> Ver Relatórios
                            </a>
                            <a asp-action="CriarRelatorio" asp-route-idTurma="@Model.Id"
                               style="display:inline-flex;align-items:center;gap:6px;background:var(--success-light);color:var(--success);border:1px solid #bbf7d0;border-radius:var(--radius);padding:9px 16px;font-size:.82rem;font-weight:700;text-decoration:none">
                                <i class="fas fa-plus"></i> Novo Relatório Semanal
                            </a>
                            <a asp-controller="Agenda" asp-action="Index" asp-route-idTurma="@Model.Id"
                               style="display:inline-flex;align-items:center;gap:6px;background:var(--info-light);color:var(--info);border:1px solid #a5f3fc;border-radius:var(--radius);padding:9px 16px;font-size:.82rem;font-weight:700;text-decoration:none">
                                <i class="fas fa-calendar-alt"></i> Ver Agenda
                            </a>
                        </div>

                 
                        <div class="ea-table-card ea-fade">
                            <div class="ea-table-card-header">
                                <div class="ea-table-header-icon"><i class="fas fa-heart"></i></div>
                                <h3 class="ea-table-card-title">Casais Matriculados</h3>
                            </div>
                            <div style="overflow-x:auto">
                                <table class="ea-table">
                                    <thead>
                                        <tr>
                                            <th></th>
                                            <th>Casal</th>
                                            <th>Última Lição</th>
                                            <th>Presença</th>
                                            <th>Status Matrícula</th>
                                            <th>Certificado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var casal in Model.CasaisMatriculados)
                                        {
                                            <tr>
                                                <td>
                                                    <button type="button" class="btn-ver-casal" data-id="@casal.Id"
                                                            title="Ver detalhes do casal">
                                                        <i class="fas fa-eye"></i> Ver
                                                    </button>
                                                </td>
                                                <td style="font-weight:700;color:var(--gray-800)">
                                                    <i class="fas fa-heart"
                                                       style="color:#fca5a5;margin-right:6px;font-size:.7rem"></i>@casal.Nome
                                                </td>
                                                <td>
                                                    @if (casal.UltimaLicao.HasValue)
                                                    {
                                                        <span class="ea-date-pill"><i
                                                            class="fas fa-calendar-alt"></i>@casal.UltimaLicao.Value.ToShortDateString()</span>
                                                        }
                                    else
                                                        {
                                                            <span style="color:var(--gray-300)">—</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <span
                                                            style="display:inline-flex;align-items:center;gap:5px;font-size:.75rem;font-weight:700;background:var(--gray-100);border:1px solid var(--gray-200);border-radius:var(--radius-sm);padding:3px 9px;color:var(--gray-600)">
                                                            <i class="fas fa-calendar-check"
                                                               style="color:var(--success);font-size:.65rem"></i>@casal.Presenca
                                                        </span>
                                                    </td>
                                                    <td>
                                                        @if (casal.Matricula.Status == StatusMatricula.Ativa)
                                                        {
                                                            <a asp-action="ConcluirCurso" asp-route-idMatricula="@casal.Matricula.Id"
                                                               style="display:inline-flex;align-items:center;gap:5px;background:var(--success-light);color:var(--success);border:1px solid #bbf7d0;border-radius:var(--radius-sm);padding:5px 10px;font-size:.74rem;font-weight:700;text-decoration:none">
                                                                <i class="fas fa-check"></i> Concluir
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <span class="ea-badge concluida">Concluída</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (casal.Matricula.CertificadoEmitido)
                                                        {
                                                            <a asp-action="VerCertificado" asp-controller="Lider"
                                                               asp-route-idMatricula="@casal.Matricula.Id"
                                                               asp-route-turmaId="@casal.Matricula.IdTurma" target="_blank"
                                                               style="display:inline-flex;align-items:center;gap:5px;background:var(--primary-light);color:var(--primary);border:1px solid var(--primary-mid);border-radius:var(--radius-sm);padding:5px 10px;font-size:.74rem;font-weight:700;text-decoration:none">
                                                                <i class="fas fa-file-pdf"></i> Ver Certificado
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <span class="ea-badge naoemitido">Não gerado</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </section>

                    @* {{-- ══ MODAL DETALHES DO CASAL ══════════════════════════════════ --}} *@
                    <div class="modal fade" id="modalCasal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-lg modal-dialog-centered">
                            <div class="modal-content" style="border:none;border-radius:var(--radius-lg);overflow:hidden">

                                @* {{-- Header --}} *@
                                <div class="modal-header"
                                     style="background:linear-gradient(135deg,#1e40af,#2563eb);border:none;padding:20px 24px">
                                    <div style="display:flex;align-items:center;gap:12px">
                                        <div
                                            style="width:40px;height:40px;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:.9rem;flex-shrink:0">
                                            <i class="fas fa-heart"></i>
                                        </div>
                                        <div>
                                            <h5 class="modal-title" id="modalCasalNome"
                                                style="font-family:var(--font);font-size:1rem;font-weight:800;color:#fff;margin:0"></h5>
                                            <p id="modalCasalCampus" style="font-size:.75rem;color:rgba(255,255,255,.7);margin:0"></p>
                                        </div>
                                    </div>
                                    <button type="button" class="close" data-dismiss="modal"
                                            style="color:#fff;opacity:.7;font-size:1.4rem;padding:0;margin:0">
                                        <span>&times;</span>
                                    </button>
                                </div>

                                @* {{-- Body --}} *@
                                <div class="modal-body" style="padding:0">

                                    @* {{-- Loading --}} *@
                                    <div id="modalCasalLoading"
                                         style="display:flex;align-items:center;justify-content:center;padding:48px;gap:10px;color:var(--gray-400)">
                                        <i class="fas fa-circle-notch fa-spin"></i>
                                        <span style="font-size:.85rem">Carregando...</span>
                                    </div>

                                    @* {{-- Conteúdo (oculto até carregar) --}} *@
                                    <div id="modalCasalConteudo" style="display:none">

                                        @* {{-- Grid principal: contato + endereço --}} *@
                                        <div
                                            style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-bottom:1px solid var(--gray-100)">

                                            @* {{-- Cônjuge 1 --}} *@
                                            <div style="padding:20px 24px;border-right:1px solid var(--gray-100)">
                                                <p
                                                    style="font-size:.68rem;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.4px;margin:0 0 12px">
                                                    Homem</p>
                                                    <p id="mc-nome1"
                                                       style="font-family:var(--font);font-size:.9rem;font-weight:800;color:var(--gray-800);margin:0 0 8px">
                                                    </p>
                                                    <div style="display:flex;flex-direction:column;gap:5px">
                                                        <span id="mc-email1" style="font-size:.78rem;color:var(--gray-500)"></span>
                                                        <span id="mc-fone1" style="font-size:.78rem;color:var(--gray-500)"></span>
                                                    </div>
                                                </div>

                                                @* {{-- Cônjuge 2 --}} *@
                                                <div style="padding:20px 24px">
                                                    <p
                                                        style="font-size:.68rem;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.4px;margin:0 0 12px">
                                                        Mulher</p>
                                                        <p id="mc-nome2"
                                                           style="font-family:var(--font);font-size:.9rem;font-weight:800;color:var(--gray-800);margin:0 0 8px">
                                                        </p>
                                                        <div style="display:flex;flex-direction:column;gap:5px">
                                                            <span id="mc-email2" style="font-size:.78rem;color:var(--gray-500)"></span>
                                                            <span id="mc-fone2" style="font-size:.78rem;color:var(--gray-500)"></span>
                                                        </div>
                                                    </div>

                                                </div>

                                                @* {{-- Endereço --}} *@
                                                <div
                                                    style="padding:16px 24px;border-bottom:1px solid var(--gray-100);display:flex;align-items:center;gap:10px">
                                                    <div
                                                        style="width:28px;height:28px;background:var(--primary-light);color:var(--primary);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:.7rem;flex-shrink:0">
                                                        <i class="fas fa-map-marker-alt"></i>
                                                    </div>
                                                    <span id="mc-endereco" style="font-size:.82rem;color:var(--gray-600)"></span>
                                                </div>

                                                @* {{-- Histórico de matrículas --}} *@
                                                <div style="padding:16px 24px 4px">
                                                    <p
                                                        style="font-size:.68rem;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.4px;margin:0 0 10px">
                                                        Histórico de matrículas</p>
                                                        <div id="mc-matriculas"></div>
                                                    </div>

                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>



                                @section Scripts {
                                    <style>
                                        .btn-ver-casal {
                                            display: inline-flex;
                                            align-items: center;
                                            gap: 5px;
                                            background: var(--primary-light);
                                            color: var(--primary);
                                            border: 1px solid var(--primary-mid);
                                            border-radius: var(--radius-sm);
                                            padding: 5px 11px;
                                            font-size: .75rem;
                                            font-weight: 700;
                                            cursor: pointer;
                                            transition: background .18s;
                                            font-family: var(--font);
                                        }

                                        .btn-ver-casal:hover {
                                            background: var(--primary-mid);
                                        }

                                        .mc-matricula-item {
                                            display: flex;
                                            align-items: center;
                                            gap: 10px;
                                            padding: 10px 0;
                                            border-bottom: 1px solid var(--gray-100);
                                            font-size: .82rem;
                                        }

                                        .mc-matricula-item:last-child {
                                            border-bottom: none;
                                        }

                                        .mc-curso-icon {
                                            width: 32px;
                                            height: 32px;
                                            border-radius: var(--radius-sm);
                                            background: var(--success-light);
                                            color: var(--success);
                                            display: flex;
                                            align-items: center;
                                            justify-content: center;
                                            font-size: .7rem;
                                            flex-shrink: 0;
                                        }

                                        .mc-badge {
                                            display: inline-flex;
                                            align-items: center;
                                            font-size: .68rem;
                                            font-weight: 700;
                                            border-radius: 20px;
                                            padding: 2px 8px;
                                            margin-left: auto;
                                            white-space: nowrap;
                                        }

                                        .mc-badge.ativa {
                                            background: var(--success-light);
                                            color: var(--success);
                                            border: 1px solid #bbf7d0;
                                        }

                                        .mc-badge.concluida {
                                            background: var(--primary-light);
                                            color: var(--primary);
                                            border: 1px solid var(--primary-mid);
                                        }

                                        .mc-badge.desistente {
                                            background: var(--danger-light);
                                            color: var(--danger);
                                            border: 1px solid #fca5a5;
                                        }
                                    </style>

                                    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
                                    <script>
                                        Chart.defaults.font.family = "'Nunito','Segoe UI',sans-serif";
                                        Chart.defaults.font.size = 11;
                                        Chart.defaults.color = '#64748b';
                                        new Chart(document.getElementById('chartPresenca'), {
                                        type: 'bar',
                                        data: {
                                        labels: @Html.Raw(Json.Serialize(Model.CasaisMatriculados.Select(c => c.PrimeiroNome))),
                                        datasets: [
                                        {
                                        label: 'Presenças',
                                        data: @Html.Raw(Json.Serialize(Model.CasaisMatriculados.Select(c => c.QtdPresencas))),
                                        backgroundColor: 'rgba(22,163,74,0.15)', borderColor: '#16a34a',
                                        borderWidth: 2, borderRadius: 5, borderSkipped: false
                                        },
                                        {
                                        label: 'Faltas',
                                        data: @Html.Raw(Json.Serialize(Model.CasaisMatriculados.Select(c => c.QtdFaltas))),
                                        backgroundColor: 'rgba(220,38,38,0.1)', borderColor: '#dc2626',
                                        borderWidth: 2, borderRadius: 5, borderSkipped: false
                                        }
                                        ]
                                        },
                                        options: {
                                        responsive: true,
                                        plugins: { legend: { position: 'bottom', labels: { padding: 12, boxWidth: 10, borderRadius: 4 } } },
                                        scales: {
                                        y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { precision: 0 } },
                                        x: { grid: { display: false } }
                                        }
                                        }
                                        });
                                    </script>

                                    <script>
                                        $(function () {

                                        // ── Abre o modal e busca os dados via fetch ──────────────────────
                                        $(document).on('click', '.btn-ver-casal', function () {
                                        var id = $(this).data('id');

                                        // Reseta o modal antes de abrir
                                        $('#modalCasalNome').text('Carregando...');
                                        $('#modalCasalCampus').text('');
                                        $('#modalCasalLoading').show();
                                        $('#modalCasalConteudo').hide();

                                        $('#modalCasal').modal('show');

                                        // Busca os dados do endpoint JSON
                                        $.getJSON('/Lider/Detalhes/' + id)
                                        .done(function (d) {
                                        preencherModal(d);
                                        })
                                        .fail(function () {
                                        $('#modalCasalLoading').html(
                                        '<span style="color:var(--danger);font-size:.85rem">' +
                                        '<i class="fas fa-exclamation-circle" style="margin-right:6px"></i>' +
                                        'Erro ao carregar os dados. Tente novamente.</span>'
                                        );
                                        });
                                        });

                                        // ── Preenche o modal com os dados recebidos ──────────────────────
                                        function preencherModal(d) {
                                        // Header
                                        $('#modalCasalNome').text(d.nomeConjuge1 + ' e ' + d.nomeConjuge2);
                                        $('#modalCasalCampus').html(
                                        '<i class="fas fa-map-marker-alt" style="margin-right:4px"></i>' +
                                        d.nomeCampus + ' &nbsp;·&nbsp; ' + traduzirStatus(d.status)
                                        );

                                        // Cônjuges
                                        $('#mc-nome1').text(d.nomeConjuge1);
                                        $('#mc-email1').html('<i class="fas fa-envelope" style="margin-right:5px;color:var(--gray-300)"></i>' + d.emailConjuge1);
                                        $('#mc-fone1').html('<i class="fas fa-phone" style="margin-right:5px;color:var(--gray-300)"></i>' + d.telefoneConjuge1);

                                        $('#mc-nome2').text(d.nomeConjuge2);
                                        $('#mc-email2').html('<i class="fas fa-envelope" style="margin-right:5px;color:var(--gray-300)"></i>' + d.emailConjuge2);
                                        $('#mc-fone2').html('<i class="fas fa-phone" style="margin-right:5px;color:var(--gray-300)"></i>' + d.telefoneConjuge2);

                                        // Endereço
                                        var partes = [d.rua, d.numero, d.complemento, d.bairro, d.cidade + ' - ' + d.estado, d.cep]
                                        .filter(function (p) { return p && p.trim() !== ''; });
                                        $('#mc-endereco').text(partes.join(', '));

                                        // Histórico de matrículas
                                        var $container = $('#mc-matriculas');
                                        $container.empty();

                                        if (!d.matriculas || d.matriculas.length === 0) {
                                        $container.html(
                                        '<p style="font-size:.8rem;color:var(--gray-400);font-style:italic;padding:8px 0 16px">' +
                                        'Nenhuma matrícula registrada.</p>'
                                        );
                                        } else {
                                        d.matriculas.forEach(function (m) {
                                        var badgeClass = m.status.toLowerCase() === 'ativa' ? 'ativa'
                                        : m.status.toLowerCase().includes('conclu') ? 'concluida'
                                        : 'desistente';

                                        var certificadoHtml = m.certificadoEmitido
                                        ? '<span style="font-size:.7rem;color:var(--success);margin-left:6px">' +
                                        '<i class="fas fa-certificate"></i> Certificado</span>'
                                        : '';

                                        var dataHtml = '<span style="font-size:.75rem;color:var(--gray-400);margin-left:6px">' +
                                        formatarData(m.dataMatricula) +
                                        (m.dataConclusao ? ' → ' + formatarData(m.dataConclusao) : '') +
                                        '</span>';

                                        $container.append(
                                        '<div class="mc-matricula-item">' +
                                        '<div class="mc-curso-icon"><i class="fas fa-graduation-cap"></i></div>' +
                                        '<div style="flex:1;min-width:0">' +
                                        '<span style="font-weight:700;color:var(--gray-800)">' + m.nomeCurso + '</span>' +
                                        certificadoHtml +
                                        '<br>' + dataHtml +
                                        '</div>' +
                                        '<span class="mc-badge ' + badgeClass + '">' + traduzirStatus(m.status) + '</span>' +
                                        '</div>'
                                        );
                                        });
                                        $container.css('padding-bottom', '8px');
                                        }

                                        // Exibe o conteúdo
                                        $('#modalCasalLoading').hide();
                                        $('#modalCasalConteudo').show();
                                        }

                                        // ── Helpers ──────────────────────────────────────────────────────
                                        function traduzirStatus(s) {
                                        var mapa = {
                                        'Ativo': 'Ativo', 'Ativa': 'Ativa',
                                        'Desistente': 'Desistente',
                                        'Concluido': 'Concluído', 'Concluída': 'Concluída',
                                        'Cancelada': 'Cancelada'
                                        };
                                        return mapa[s] || s;
                                        }

                                        function formatarData(iso) {
                                        if (!iso) return '';
                                        var d = new Date(iso);
                                        return d.toLocaleDateString('pt-BR');
                                        }

                                        });
                                    </script>

                                    
                                }